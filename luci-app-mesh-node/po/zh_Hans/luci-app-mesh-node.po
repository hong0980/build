# Mesh Protocol
msgid "Mesh Protocol"
msgstr "Mesh 协议"

msgid "802.11s native: kernel-level forwarding, simpler setup. batman-adv: advanced L2 routing on top of 802.11s, better multi-hop performance. When switching modes, save and reboot all nodes."
msgstr "802.11s 原生：内核级转发，设置简单。batman-adv：基于 802.11s 的高级 L2 路由，多跳性能更佳。切换模式时，请保存并重启所有节点。"

msgid "802.11s native — kernel mesh forwarding (default)"
msgstr "802.11s 原生 — 内核 Mesh 转发（默认）"

msgid "batman-adv — 802.11s backhaul + batadv L2 routing"
msgstr "batman-adv — 802.11s 回程 + batadv L2 路由"

# batman-adv Routing Algorithm
msgid "batman-adv Routing Algorithm"
msgstr "batman-adv 路由算法"

msgid "BATMAN_IV: based on link quality (TQ), compatible with all devices. All nodes in the same mesh must use the same algorithm."
msgstr "BATMAN_IV：基于链路质量（TQ），兼容所有设备。同一 Mesh 网络中的所有节点必须使用相同算法。"

msgid "BATMAN_IV — link quality (recommended)"
msgstr "BATMAN_IV — 链路质量（推荐）"

msgid "BATMAN_V — throughput based"
