msgid "Mesh Node Setup"
msgstr "Mesh 节点设置"

msgid "AP + Mesh Deployment"
msgstr "AP + Mesh 部署"

msgid "Quickly create a Mesh. <span style='color: red;'><b>All mesh child nodes must be exactly identical.</b></span>"
msgstr "快捷的建立 Mesh。<span style='color: red;'><b>所有 Mesh 子节点必须完全一致</b></span>"

msgid "Mesh Backhaul"
msgstr "Mesh 回程"

msgid "Other"
msgstr "其他"

msgid "Network Mode"
msgstr "网络模式"

msgid "WAN Protocol"
msgstr "WAN 协议"

msgid "Bridge to LAN"
msgstr "桥接至 LAN"

msgid "DHCP client"
msgstr "DHCP 客户端"

msgid "PPPoE Username"
msgstr "PPPoE 用户名"

msgid "PPPoE Password"
msgstr "PPPoE 密码"

msgid "LAN Mode"
msgstr "LAN 模式"

msgid "Static address"
msgstr "静态地址"

msgid "Default"
msgstr "默认"

msgid "Node Static IP"
msgstr "节点静态 IP"

msgid "Static IPv4 address for this node's LAN bridge. Must be unique per node, e.g. 192.168.2.2 / .3 / .4"
msgstr "本节点 LAN 桥的静态 IPv4 地址，每个节点必须唯一，例如 192.168.2.2 / .3 / .4"

msgid "Gateway / DNS"
msgstr "网关 / DNS"

msgid "Upstream router IP, used as the default gateway and DNS server for this node"
msgstr "上游路由器 IP，用作本节点的默认网关和 DNS 服务器"

msgid "DHCP Assigned IP"
msgstr "DHCP 分配的 IP"

msgid "IP address assigned to this node by the upstream DHCP server; shown for reference only"
msgstr "由上游 DHCP 服务器分配给本节点的 IP 地址，仅供参考"

msgid "Dual-band Merge"
msgstr "多频合一"

msgid "Enabled: one SSID/password applied to both 2.4 GHz and 5 GHz %s radios."
msgstr "启用后，2.4 GHz 和 5 GHz %s 共用同一 SSID 和密码。"

msgid "Enable usteer Smart Steering"
msgstr "启用 usteer 智能频段导向"

msgid "Uses usteer to steer clients to the best radio for optimal performance."
msgstr "使用 usteer 将客户端引导至最佳无线频段以获得最优性能。"

msgid "Must exactly match the main router SSID to enable seamless roaming"
msgstr "所有路由器 SSID 完全一致，以实现无缝漫游"

msgid "%s WiFi Password"
msgstr "%s WiFi 密码"

msgid "Encryption: psk2+ccmp (WPA2). Minimum 8 characters."
msgstr "加密方式：psk2+ccmp（WPA2），最少 8 个字符。"

msgid "WiFi Password"
msgstr "WiFi 密码"

msgid "Mesh Backhaul Band"
msgstr "Mesh 回程频段"

msgid "Select the radio band used for the 802.11s mesh backhaul link. <b>Must match on all nodes.</b>"
msgstr "选择用于 802.11s Mesh 回程链路的无线频段。<b>必须与所有节点一致。</b>"

msgid "recommended, best throughput"
msgstr "推荐，吞吐量最高"

msgid "longer range, lower throughput"
msgstr "覆盖范围更广，吞吐量较低"

msgid "All bands"
msgstr "全频段"

msgid "all radios participate in the mesh"
msgstr "所有无线频段均参与 Mesh"

msgid "Backhaul Mode"
msgstr "回程模式"

msgid "Wired Only"
msgstr "有线"

msgid "Wireless"
msgstr "无线"

msgid "Wireless + Wired"
msgstr "无线 + 有线"

msgid "Mesh Password"
msgstr "Mesh 密码"

msgid "Mesh Status"
msgstr "Mesh 状态"

msgid "View Mesh Status"
msgstr "查看 Mesh 状态"

msgid "No active mesh interface found."
msgstr "未找到活跃的 Mesh 接口。"

msgid "(No neighbor nodes connected)"
msgstr "（当前无邻居节点连接）"

msgid "(No mesh paths established)"
msgstr "（尚未建立 Mesh 转发路径）"

msgid "Mesh Interface"
msgstr "Mesh 接口"

msgid "FORWARDING PATH DUMP (mpath)"
msgstr "转发路径信息（mpath）"

msgid "Execution failed: %s"
msgstr "执行失败：%s"

msgid "mesh11sd Status"
msgstr "mesh11sd 状态"

msgid "Running"
msgstr "运行中"

msgid "Stopped"
msgstr "未运行"

msgid "Hostname"
msgstr "主机名"

msgid "Disabled Services"
msgstr "禁用的服务"

msgid "Services selected here will be stopped and disabled on save"
msgstr "此处勾选的服务将在保存时被停止并禁止开机自启"

msgid "Bridge + DHCP (AP/Mesh node: WAN bridged to LAN, IP assigned by upstream router)"
msgstr "桥接 + DHCP（AP/Mesh 节点：WAN 桥接至 LAN，IP 由上游路由器分配）"

msgid "Bridge + Static IP"
msgstr "桥接 + 静态 IP"

msgid "PPPoE + Default"
msgstr "PPPoE + 默认"

msgid "DHCP WAN + Default"
msgstr "DHCP WAN + 默认"

msgid "Custom"
msgstr "自定义"

msgid "AP/Mesh node: WAN bridged to LAN, IP assigned by upstream router"
msgstr "AP/Mesh 节点：WAN 桥接至 LAN，IP 由上游路由器分配"

msgid "AP/Mesh node: WAN bridged to LAN, fixed node IP"
msgstr "AP/Mesh 节点：WAN 桥接至 LAN，固定节点 IP"

msgid "Gateway: dial-up on this device, LAN managed by system"
msgstr "网关：本机拨号，LAN 由系统管理"

msgid "Gateway: WAN via DHCP, LAN managed by system"
msgstr "网关：WAN 通过 DHCP 获取 IP，LAN 由系统管理"

msgid "configure WAN and LAN manually"
msgstr "手动配置 WAN 和 LAN"

# Mesh Protocol
msgid "Mesh Protocol"
msgstr "Mesh 协议"

msgid "native — kernel mesh forwarding"
msgstr "原生 — 内核级 Mesh 转发"

msgid "802.11s backhaul + batadv L2 routing"
msgstr "802.11s 回程 + batadv L2 路由"

msgid "All nodes in the same mesh must use the same algorithm."
msgstr "同一 Mesh 网络中的所有节点必须使用相同算法。"

msgid "link quality (recommended)"
msgstr "链路质量（推荐）"

msgid "throughput based"
msgstr "基于吞吐量"

msgid "STATISTICS"
msgstr "统计数据"

msgid "NEIGHBORS"
msgstr "邻居节点"

msgid "ORIGINATORS"
msgstr "源节点路由表"

msgid "none"
msgstr "无"

msgid "Mesh Status (batman-adv)"
msgstr "Mesh 状态 (batman-adv)"

msgid "NEIGHBOR STATION DUMP"
msgstr "邻居站点信息"

msgid "Mesh Status (802.11s)"
msgstr "Mesh 状态 (802.11s)"

msgid "Network"
msgstr "网络"

msgid "Close"
msgstr "关闭"

msgid "Routing Algorithm"
msgstr "路由算法"

msgid "Aggregate Originator Messages"
msgstr "聚合源节点消息"

msgid "reduces overhead by collecting and aggregating originator messages in a single packet rather than many small ones"
msgstr "将多个源节点消息合并到单个数据包中发送，减少协议开销。"

msgid "Originator Interval"
msgstr "源节点广播间隔"

msgid "The value specifies the interval (milliseconds) in which batman-adv floods the network with its protocol information."
msgstr "batman-adv 向网络广播自身协议信息的间隔时间（毫秒）。"

msgid "Access Point Isolation"
msgstr "AP 客户端隔离"

msgid "Prevents one wireless client to talk to another. This setting only affects packets without any VLAN tag (untagged packets)."
msgstr "禁止同一 AP 下的无线客户端之间直接通信。仅影响无 VLAN 标签的未标记数据包。"

msgid "Bonding Mode"
msgstr "聚合模式"

msgid "When running the mesh over multiple WiFi interfaces per node batman-adv is capable of optimizing the traffic flow to gain maximum performance."
msgstr "节点有多个无线接口时，batman-adv 可跨接口优化流量分配以获得最大吞吐量。"

msgid "Avoid Bridge Loops"
msgstr "避免桥接环路"

msgid "In bridged LAN setups it is advisable to enable the bridge loop avoidance in order to avoid broadcast loops that can bring the entire LAN to a standstill."
msgstr "在桥接 LAN 场景中建议启用，防止广播环路导致整个局域网瘫痪。"

msgid "Distributed ARP Table"
msgstr "分布式 ARP 表"

msgid "When enabled the distributed ARP table forms a mesh-wide ARP cache that helps non-mesh clients to get ARP responses much more reliably and without much delay."
msgstr "启用后，batman-adv 在整个 Mesh 网络范围内维护一张分布式 ARP 缓存表，使非 Mesh 客户端的 ARP 查询更快速可靠。"

msgid "Fragmentation"
msgstr "分片"

msgid "Hop Penalty"
msgstr "跳数惩罚"

msgid "Multicast Mode"
msgstr "组播模式"

msgid "Enables more efficient, group aware multicast forwarding infrastructure in batman-adv."
msgstr "启用 batman-adv 的感知组成员的高效组播转发机制。"

msgid "MESH INFO"
msgstr "Mesh 信息"

msgid "INTERFACES"
msgstr "接口列表"

msgid "Usteer Settings"
msgstr "Usteer 设置"

msgid "Hostapd Log Level"
msgstr "Hostapd 日志级别"

msgid "Global setting for all Wi-Fi radios"
msgstr "全局设置，应用于所有 Wi-Fi 无线模块"

msgid ""
"4-hex-digit domain identifier shared by all APs that participate in fast "
"roaming (FT). Must be identical on every node. Change this if you have "
"multiple independent mesh networks in the same area to avoid cross-domain FT conflicts."
msgstr ""
"由所有参与快速漫游 (FT) 的 AP 共享的 4 位十六进制域标识符。所有节点必须保持一"
"致。如果你在同一区域拥有多个独立的 Mesh 网络，请修改此值以避免跨域 FT 冲突。"

msgid ""
"Distributed FT (advanced) — APs exchange FT keys via RRB protocol. Requires "
"manual r0kh/r1kh peer lists in each AP's wireless config."
msgstr ""
"分布式 FT (高级) — AP 通过 RRB 协议交换 FT 密钥。需要在每个 AP 的无线配置中手"
"动设置 r0kh/r1kh 邻居列表。"

msgid ""
"Local key derivation (recommended) — each AP derives FT keys independently; "
"no inter-AP key sync required. Works correctly out of the box."
msgstr ""
"本地密钥派生 (推荐) — 各 AP 独立生成 FT 密钥；无需 AP 间密钥同步。开箱即用，无"
"需额外配置。"

msgid "Usteer Status"
msgstr "Usteer 状态"

msgid "batadv Settings"
msgstr "batadv 设置"

msgid "mesh11sd Settings"
msgstr "mesh11sd 设置"

msgid "Live Status"
msgstr "实时状态"

msgid "No output. please retry in a moment."
msgstr "无输出。请稍后重试。"

msgid "Enable Daemon"
msgstr "启用守护进程"

msgid "Debug Level"
msgstr "日志级别"

msgid "Silent"
msgstr "静默"

msgid "Notice"
msgstr "通知"

msgid "Info"
msgstr "详细"

msgid "Debug"
msgstr "调试"

msgid "Check Interval (s)"
msgstr "检查间隔（秒）"

msgid "How often the daemon dynamically checks and updates the mesh configuration."
msgstr "守护进程动态检查并更新网状配置的频率。"

msgid "Interface Timeout (s)"
msgstr "接口就绪超时（秒）"

msgid "Seconds to wait for a wireless interface to become ready."
msgstr "等待无线接口就绪的超时时间。"

msgid "Auto Config"
msgstr "自动配置"

msgid "When enabled, the daemon automatically configures wireless interfaces for the mesh — no manual wireless config needed. When disabled, the daemon only monitors an existing mesh configuration.<br><b>Warning:</b> Incorrect manual mesh configuration can soft-brick the router."
msgstr "启用后，守护进程自动配置无线接口加入网状网络，无需手动修改 wireless 配置。禁用时，守护进程仅监控已有网状配置。<br><b>警告：</b>手动配置错误可能导致路由器变砖。"

msgid "Hashed to generate the actual mesh network ID. <b>Must match on all nodes.</b>"
msgstr "经哈希生成实际的网状网络标识。<b>必须与所有节点一致。</b>"

msgid "SHA256-hashed to produce the mesh encryption key. <b>Must match on all nodes.</b>"
msgstr "经 SHA256 哈希生成网状加密密钥。<b>必须与所有节点一致。</b>"

msgid "This can be set differently on each meshnode as required."
msgstr "可以根据需要在每个网格节点上进行不同的设置。"

msgid "Force Radio Index"
msgstr "指定无线网卡序号"

msgid "Leave empty for auto-selection. Only needed on devices with multiple radios on the same band (e.g. enter 2 to force phy2)."
msgstr "留空则自动选择。仅在设备有多个同频段无线网卡时需要指定（如填 2 代表 phy2）。"

msgid "Country Code"
msgstr "国家/地区代码"

msgid "Overrides the country code in the wireless config (e.g. CN, US, DE). Defaults to DFS-ETSI if not set."
msgstr "覆盖 wireless 配置中的国家代码（如 CN、US、DE）。未设置时默认使用 DFS-ETSI。"

msgid "Mesh Interface Base Name"
msgstr "网状接口基础名"

msgid "Used to build the interface name m-<name>-0. Max 8 characters. Default: 11s → interface m-11s-0."
msgstr "用于构造接口名称 m-<名称>-0，最多 8 个字符。默认：11s → 接口名 m-11s-0。"

msgid "Node Mode"
msgstr "节点模式"

msgid "Select the operating mode for this node in the mesh network"
msgstr "选择节点在网状网络中的工作模式"

msgid "Auto Detect (Recommended)"
msgstr "自动检测（推荐）"

msgid "Automatically detects WAN status:<br/>• WAN available = MRP (Routed Portal)<br/>• No WAN = MPE (Mesh Peer)"
msgstr "自动检测WAN状态：<br/>• 有WAN = MRP（路由门户）<br/>• 无WAN = MPE（对等节点）"

msgid "Forced Routed Portal (MRP)"
msgstr "强制路由门户(MRP)"

msgid "Forces routed portal mode:<br/>• Always provides DHCP/NAT<br/>• Must have WAN connection"
msgstr "强制作为路由门户：<br/>• 始终提供DHCP/NAT<br/>• 必须有WAN连接"

msgid "Client Equipment (CPE)"
msgstr "客户端设备(CPE)"

msgid "Peer mode, mesh as WAN:<br/>• Creates independent NAT subnet<br/>• Supports multiple IPv6 modes"
msgstr "对等模式，网状作为WAN：<br/>• 创建独立NAT子网<br/>• 支持多种IPv6模式"

msgid "Bridged Portal (MBP)"
msgstr "桥接门户(MBP)"

msgid "Bridge mode, WAN joins VXLAN:<br/>• No NAT translation<br/>• WAN port added to br-tun69"
msgstr "桥接模式，WAN加入VXLAN：<br/>• 不进行NAT<br/>• WAN口加入br-tun69"

msgid "Trunk Peer Node (TPN)"
msgstr "汇聚节点(TPN)"

msgid "Special peer node:<br/>• WAN port is VXLAN endpoint<br/>• Compatible with mode 0/1/4 portals"
msgstr "特殊对等节点：<br/>• WAN口是VXLAN端点<br/>• 兼容模式0/1/4门户"

msgid "Portal Detect Watchdog"
msgstr "门户检测看门狗"

msgid "Number of check intervals a peer node can fail to detect the portal before the watchdog triggers a reboot. 0 = disabled."
msgstr "对等节点连续多少个检查间隔未检测到门户后，看门狗触发重启。0 = 禁用。"

msgid "Portal Channel (2.4 GHz only)"
msgstr "门户信道（仅 2.4 GHz）"

msgid "Peer nodes automatically track the portal channel regardless of auto_mesh_band."
msgstr "对等节点会自动跟踪门户信道，与 auto_mesh_band 设置无关。"

msgid "Use channel from wireless config"
msgstr "使用 wireless 配置中的信道"

msgid "Auto select"
msgstr "自动选择"

msgid "Channel "
msgstr "信道 "

msgid "Channel Tracking Start Interval (s)"
msgstr "信道跟踪开始间隔（秒）"

msgid "Minimum interval after which channel tracking begins on peer nodes. Values less than checkinterval are ignored."
msgstr "对等节点开始跟踪门户信道的最小间隔，小于检查间隔的值将被忽略。"

msgid "Use Default IPv4 Address"
msgstr "使用默认 IPv4 地址"

msgid "When enabled, the portal node uses the IPv4 address from /etc/config/network. When disabled, the subnet is auto-calculated from the label MAC address."
msgstr "启用后，门户节点使用 /etc/config/network 中定义的 IPv4 地址。禁用时，根据标签 MAC 地址自动计算子网。"

msgid "CPE IPv6 Mode"
msgstr "CPE IPv6 模式"

msgid "Applies only when Node Role is CPE (3)."
msgstr "仅在节点角色为 CPE（3）时生效。"

msgid "NAT66 (default, compatible with Android)"
msgstr "NAT66（默认，兼容 Android）"

msgid "Prefix Delegation"
msgstr "前缀委派"

msgid "Relay"
msgstr "中继"

msgid "AP Gate"
msgstr "AP 接入点开关"

msgid "Controls whether this node creates a Wi-Fi access point (SSID)."
msgstr "控制本节点是否创建 Wi-Fi 接入点（SSID）。"

msgid "Disabled"
msgstr "禁用"

msgid "Enabled on all radios"
msgstr "在所有无线网卡上启用"

msgid "Enabled only on radios not shared with mesh"
msgstr "仅在非网状回程独占的无线网卡上启用"

msgid "AP SSID"
msgstr "AP 接入点 SSID"

msgid "Base SSID for the access point. Max 22 chars with suffix enabled, 30 without. Leave empty to use the SSID from wireless config."
msgstr "AP 的基础 SSID 名称。启用后缀时最长 22 字符，禁用时最长 30 字符。留空则使用 wireless 配置中的 SSID。"

msgid "SSID Suffix"
msgstr "SSID 后缀"

msgid "Append the last 4 digits of the mesh interface MAC to the SSID to distinguish nodes."
msgstr "在 SSID 末尾追加网状接口 MAC 地址的最后 4 位，便于区分不同节点的 AP。"

msgid "AP Encryption"
msgstr "AP 加密方式"

msgid "OWE — Opportunistic Wireless Encryption"
msgstr "OWE — 机会性无线加密"

msgid "None / OWE transition"
msgstr "不加密 / OWE 过渡模式"

msgid "SAE-Mixed (WPA2+WPA3)"
msgstr "SAE 混合（WPA2+WPA3）"

msgid "WPA2 PSK"
msgstr "WPA2 PSK"

msgid "AP Password"
msgstr "AP 接入点密码"

msgid "Mesh Path Cost (STP)"
msgstr "网状路径代价（STP）"

msgid "STP link cost for the mesh network. Range 0–65534. 0 disables STP."
msgstr "网状网络的 STP 链路代价，范围 0–65534。设为 0 则禁用 STP。"

msgid "Node Mobility Level"
msgstr "节点移动性级别"

msgid "Tunes path-selection aggressiveness. Use 1 for fixed deployments; increase for mobile nodes."
msgstr "调整路径选择算法的激进程度。固定部署使用 1（低），移动场景酌情调高。"

msgid "Stationary (not recommended)"
msgstr "固定部署（不推荐）"

msgid "Low (default, up to 1.5 m/s)"
msgstr "低速（默认，≤1.5 m/s）"

msgid "Medium"
msgstr "中速"

msgid "High"
msgstr "高速"

msgid "Very High"
msgstr "极高速"

msgid "Path Stabilisation"
msgstr "路径稳定化"

msgid "Prevents path flapping caused by multipath signal-strength jitter. Usually not needed above mobility level 1."
msgstr "防止因多路径信号抖动导致路径频繁切换。移动性级别 > 1 时通常无需启用。"

msgid "Reactive Path Stabilisation Threshold"
msgstr "响应式路径稳定化阈值"

msgid "Number of check intervals an unstable neighbour path must persist before path stabilisation activates."
msgstr "邻居节点路径不稳定持续多少个检查间隔后才激活路径稳定化。"

msgid "MAC Forced Forwarding"
msgstr "MAC 强制转发"

msgid "Enable MAC forced forwarding on the mesh interface to improve Layer 2 forwarding reliability."
msgstr "在网状接口上启用 MAC 强制转发，提升二层转发可靠性。"

msgid "Gateway Proxy ARP"
msgstr "网关代理 ARP"

msgid "Enable proxy ARP on the gateway bridge interface to improve ARP resolution."
msgstr "在网关桥接接口上启用代理 ARP，改善 ARP 解析可靠性。"

msgid "Leech Mode"
msgstr "寄生模式"

msgid "TX Power (dBm)"
msgstr "发射功率（dBm）"

msgid "Transmit power for the mesh radio. Values outside the regulatory domain are ignored. Leave empty for driver/wireless default."
msgstr "网状无线电的发射功率。超出监管域限制的值将被忽略。留空则使用驱动/wireless 默认值。"

msgid "Enable VXLAN Tunnel"
msgstr "启用 VXLAN 隧道"

msgid "Point-to-multipoint VXLAN tunnel between the portal and all compatible peers. Requires <b>ip-full</b> and <b>vxlan</b> packages; ignored otherwise. Disabled by default when Node Role is CPE (3)."
msgstr "在门户与所有兼容对等节点之间建立点对多点 VXLAN 隧道。需要安装 <b>ip-full</b> 和 <b>vxlan</b> 软件包，否则忽略此选项。节点角色为 CPE（3）时默认禁用。"

msgid "Tunnel ID"
msgstr "隧道 ID"

msgid "VXLAN tunnel identifier. Decimal, range 1–16777216 (24-bit)."
msgstr "VXLAN 隧道标识符，十进制，范围 1–16777216（24 位）。"

msgid "VXLAN Tunnel IPv4 Gateway"
msgstr "VXLAN 隧道 IPv4 网关"

msgid "IPv4 gateway address for the vxlan tunnel bridge. Active only when this node becomes a portal."
msgstr "vxlan 隧道桥的 IPv4 网关地址，仅在本节点成为门户时生效。"

msgid "VXLAN Tunnel Subnet Mask"
msgstr "VXLAN 隧道子网掩码"

msgid "IPv4 subnet mask for the vxlan tunnel bridge. Active only when this node becomes a portal. Default: 255.255.255.0."
msgstr "vxlan 隧道桥的 IPv4 子网掩码，仅在本节点成为门户时生效。默认：255.255.255.0。"

msgid "VXLAN Path Cost (STP)"
msgstr "VXLAN 路径代价（STP）"

msgid "STP link cost for the vxlan tunnel network. Range 0–65534. 0 disables STP."
msgstr "vxlan 隧道网络的 STP 链路代价，范围 0–65534。设为 0 则禁用 STP。"

msgid "VXLAN AP SSID"
msgstr "VXLAN AP SSID"

msgid "Base SSID for the AP attached to the vxlan tunnel. Max 22 chars with suffix, 30 without."
msgstr "连接到 vxlan 隧道的 AP 基础 SSID。启用后缀时最长 22 字符，禁用时最长 30 字符。"

msgid "VXLAN AP Encryption"
msgstr "VXLAN AP 加密方式"

msgid "Encryption for the AP attached to the vxlan tunnel."
msgstr "连接到 vxlan 隧道的 AP 加密方式。"

msgid "VXLAN AP Password"
msgstr "VXLAN AP 密码"

msgid "Encryption key for the vxlan-attached AP. Minimum 8 characters."
msgstr "连接到 vxlan 隧道的 AP 加密密钥，最少 8 个字符。"

msgid "Reboot on Error"
msgstr "出错时自动重启"

msgid "Reboot the node when the watchdog detects IPv4 communication failure with the portal."
msgstr "当看门狗检测到与门户的 IPv4 通信失败时，自动重启本节点。"

msgid "When the watchdog detects a portal communication failure, the daemon goes idle instead of rebooting. Useful for nodes without a reset button. Takes priority over Reboot on Error."
msgstr "当看门狗检测到门户通信失败时，守护进程进入空闲而非重启。适用于无复位按钮的节点。此选项优先于"出错重启"。"

msgid "Stop on Error (overrides Reboot on Error)"
msgstr "出错时停止服务（覆盖）"

msgid "Enable AP Monitor (apmond)"
msgstr "启用 AP 监控守护进程（apmond）"

msgid "Collects AP interface data from this node and sends it to the portal. Requires uhttpd and px5g-mbedtls packages."
msgstr "收集本节点 AP 接口数据并上报门户节点。需要安装 uhttpd 和 px5g-mbedtls 软件包。"

msgid "apmond CGI Directory"
msgstr "apmond CGI 目录"

msgid "Path for apmond CGI scripts when this node becomes a portal. Default: /www/cgi-bin."
msgstr "本节点成为门户时 apmond CGI 脚本的存放路径。默认：/www/cgi-bin。"

msgid "Mesh Backhaul LED"
msgstr "网状回程 LED"

msgid "LED is solid when the mesh interface is up; switches to Linux heartbeat when peers are connected. Set to <b>none</b> to disable, or enter an LED name from /sys/class/leds/ (e.g. blue:run). Default: auto (uses power/system LED)."
msgstr "网状接口启动时 LED 常亮，有对等节点连接后变为 Linux 心跳信号。填写 <b>none</b> 禁用，或填写 /sys/class/leds/ 下的 LED 名称（如 blue:run）。默认：auto（使用电源/系统 LED）。"

msgid "Manage openNDS Startup"
msgstr "管理 openNDS 启动顺序"

msgid "If openNDS is installed, mesh11sd manages its startup and synchronises nft rulesets. Disabling may cause crash loops because the openNDS gateway interface may not be ready in time."
msgstr "若安装了 openNDS，由 mesh11sd 管理其启动顺序并同步 nft 规则集。禁用可能因 openNDS 网关接口未就绪而导致崩溃循环。"

msgid "Watchdog Non-volatile Log (debug only)"
msgstr "看门狗非易失性日志（仅用于调试）"

msgid "<b>Warning:</b> Writes watchdog actions to non-volatile storage (/mesh11sd_log/mesh11sd.log). Leaving this enabled long-term may cause irreparable flash wear and consume storage. <b>Disable immediately after debugging.</b>"
msgstr "<b>警告：</b>将看门狗操作写入非易失性存储（/mesh11sd_log/mesh11sd.log）。长期启用可能导致 Flash 不可修复磨损并占用存储空间。<b>调试完成后请立即关闭。</b>"

msgid "RSSI Threshold (dBm)"
msgstr "RSSI 门限（dBm）"

msgid "Minimum signal strength required to establish a peer link (e.g. -70). Range: -100 to 0."
msgstr "建立对等链路所需的最低信号强度（如 -70）。范围：-100 到 0。"

msgid "Max Peer Links"
msgstr "最大对等链路数"

msgid "Maximum number of peer links allowed per node."
msgstr "每个节点允许建立的最大对等链路数量。"

