msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "Mesh11sd"
msgstr "Mesh11sd 网状网络"

msgid "Configure the IEEE 802.11s mesh network daemon. Options marked \"must match on all nodes\" must be set identically on every device in the mesh."
msgstr "配置 IEEE 802.11s 无线网状网络守护进程。标注"必须与所有节点一致"的选项需在网络中每台设备上设置相同的值。"

msgid "RUNNING"
msgstr "运行中"

msgid "NOT RUNNING"
msgstr "未运行"

msgid "Live Status"
msgstr "实时状态"

msgid "Mesh Status"
msgstr "网状状态"

msgid "mesh11sd Status"
msgstr "mesh11sd 状态"

msgid "Mesh Status (802.11s)"
msgstr "网状状态（802.11s）"

msgid "No output. The daemon may still be starting; please retry in a moment."
msgstr "无输出。守护进程可能仍在启动，请稍后重试。"

msgid "Execution failed: %s"
msgstr "执行失败：%s"

msgid "No active mesh interface found."
msgstr "未找到活跃的网状接口。"

msgid "Mesh Interface"
msgstr "网状接口"

msgid "NEIGHBOR STATION DUMP"
msgstr "邻居节点信息"

msgid "FORWARDING PATH DUMP (mpath)"
msgstr "转发路径信息（mpath）"

msgid "(No neighbor nodes connected)"
msgstr "（无邻居节点连接）"

msgid "(No mesh paths established)"
msgstr "（尚未建立网状路径）"

msgid "Close"
msgstr "关闭"

msgid "Enable Daemon"
msgstr "启用守护进程"

msgid "Debug Level"
msgstr "日志级别"

msgid "Silent"
msgstr "静默"

msgid "Notice (default)"
msgstr "通知（默认）"

msgid "Info"
msgstr "详细"

msgid "Debug"
msgstr "调试"

msgid "Check Interval (s)"
msgstr "检查间隔（秒）"

msgid "How often the daemon dynamically checks and updates the mesh configuration. Default: 10 s."
msgstr "守护进程动态检查并更新网状配置的频率。默认：10 秒。"

msgid "Interface Timeout (s)"
msgstr "接口就绪超时（秒）"

msgid "Seconds to wait for a wireless interface to become ready. Default: 10 s."
msgstr "等待无线接口就绪的超时时间。默认：10 秒。"

msgid "Auto Config"
msgstr "自动配置"

msgid "When enabled, the daemon automatically configures wireless interfaces for the mesh — no manual wireless config needed. When disabled, the daemon only monitors an existing mesh configuration.<br><b>Warning:</b> Incorrect manual mesh configuration can soft-brick the router."
msgstr "启用后，守护进程自动配置无线接口加入网状网络，无需手动修改 wireless 配置。禁用时，守护进程仅监控已有网状配置。<br><b>警告：</b>手动配置错误可能导致路由器变砖。"

msgid "Mesh ID Seed"
msgstr "网状 ID 种子"

msgid "Hashed to generate the actual mesh network ID. <b>Must match on all nodes.</b> Default: --__"
msgstr "经哈希生成实际的网状网络标识。<b>必须与所有节点一致。</b>默认：--__"

msgid "Mesh Encryption Key Seed"
msgstr "网状加密密钥种子"

msgid "SHA256-hashed to produce the mesh encryption key. <b>Must match on all nodes.</b>"
msgstr "经 SHA256 哈希生成网状加密密钥。<b>必须与所有节点一致。</b>"

msgid "Mesh Band"
msgstr "网状工作频段"

msgid "Wireless band used for the mesh backhaul. <b>Must match on all nodes.</b>"
msgstr "用于网状回程的无线频段。<b>必须与所有节点一致。</b>"

msgid "2.4 GHz (20 MHz)"
msgstr "2.4 GHz（20 MHz）"

msgid "2.4 GHz (40 MHz, default)"
msgstr "2.4 GHz（40 MHz，默认）"

msgid "5 GHz"
msgstr "5 GHz"

msgid "6 GHz"
msgstr "6 GHz"

msgid "60 GHz"
msgstr "60 GHz"

msgid "Force Radio Index"
msgstr "指定无线网卡序号"

msgid "Leave empty for auto-selection. Only needed on devices with multiple radios on the same band (e.g. enter 2 to force phy2)."
msgstr "留空则自动选择。仅在设备有多个同频段无线网卡时需要指定（如填 2 代表 phy2）。"

msgid "Country Code"
msgstr "国家/地区代码"

msgid "Overrides the country code in the wireless config (e.g. CN, US, DE). Defaults to DFS-ETSI if not set."
msgstr "覆盖 wireless 配置中的国家代码（如 CN、US、DE）。未设置时默认使用 DFS-ETSI。"

msgid "Mesh Interface Base Name"
msgstr "网状接口基础名"

msgid "Used to build the interface name m-<name>-0. Max 8 characters. Default: 11s → interface m-11s-0."
msgstr "用于构造接口名称 m-<名称>-0，最多 8 个字符。默认：11s → 接口名 m-11s-0。"

msgid "Node Role"
msgstr "节点角色"

msgid "Defines the role this node plays in the mesh network."
msgstr "决定本节点在网状网络中担任的角色。"

msgid "Auto detect (recommended)\nPortal (MRP) if WAN is up; Peer (MPE) otherwise"
msgstr "自动检测（推荐）\nWAN 在线时为门户（MRP），否则为对等节点（MPE）"

msgid "Force MRP — Routed Portal\nAlways runs as IPv4 NAT routed portal regardless of upstream"
msgstr "强制 MRP — 路由门户\n始终以 IPv4 NAT 路由门户模式运行，不检测上行"

msgid "CPE — Customer Premises Equipment\nUses mesh backhaul as WAN; creates its own NAT IPv4 subnet"
msgstr "CPE — 用户侧设备\n将网状回程作为 WAN，创建独立 IPv4 子网的 NAT 网络"

msgid "MBP — Bridge VXLAN Portal\nBridged portal; adds WAN port into the vxlan tunnel bridge (br-tun69)"
msgstr "MBP — 桥接 VXLAN 门户\n桥接模式门户，将 WAN 口加入 vxlan 隧道桥（br-tun69）"

msgid "TPN — Trunk Peer Node\nPeer mode; WAN port is a vxlan endpoint (compatible with portal modes 0/1/4)"
msgstr "TPN — 汇聚对等节点\n对等模式，WAN 口作为 vxlan 端点（兼容门户模式 0/1/4）"

msgid "Portal Detect Watchdog"
msgstr "门户检测看门狗"

msgid "Number of check intervals a peer node can fail to detect the portal before the watchdog triggers a reboot. 0 = disabled."
msgstr "对等节点连续多少个检查间隔未检测到门户后，看门狗触发重启。0 = 禁用。"

msgid "Portal Channel (2.4 GHz only)"
msgstr "门户信道（仅 2.4 GHz）"

msgid "Peer nodes automatically track the portal channel regardless of auto_mesh_band."
msgstr "对等节点会自动跟踪门户信道，与 auto_mesh_band 设置无关。"

msgid "Use channel from wireless config (default)"
msgstr "使用 wireless 配置中的信道（默认）"

msgid "Auto select"
msgstr "自动选择"

msgid "Channel "
msgstr "信道 "

msgid "Channel Tracking Start Interval (s)"
msgstr "信道跟踪开始间隔（秒）"

msgid "Minimum interval after which channel tracking begins on peer nodes. Values less than checkinterval are ignored. Default: 30 s."
msgstr "对等节点开始跟踪门户信道的最小间隔，小于检查间隔的值将被忽略。默认：30 秒。"

msgid "Use Default IPv4 Address"
msgstr "使用默认 IPv4 地址"

msgid "When enabled, the portal node uses the IPv4 address from /etc/config/network. When disabled (default), the subnet is auto-calculated from the label MAC address."
msgstr "启用后，门户节点使用 /etc/config/network 中定义的 IPv4 地址。禁用时（默认），根据标签 MAC 地址自动计算子网。"

msgid "CPE IPv6 Mode"
msgstr "CPE IPv6 模式"

msgid "Applies only when Node Role is CPE (3)."
msgstr "仅在节点角色为 CPE（3）时生效。"

msgid "NAT66 (default, compatible with Android)"
msgstr "NAT66（默认，兼容 Android）"

msgid "Prefix Delegation"
msgstr "前缀委派"

msgid "Relay"
msgstr "中继"

msgid "AP Gate"
msgstr "AP 接入点开关"

msgid "Controls whether this node creates a Wi-Fi access point (SSID)."
msgstr "控制本节点是否创建 Wi-Fi 接入点（SSID）。"

msgid "Disabled"
msgstr "禁用"

msgid "Enabled on all radios (default)"
msgstr "在所有无线网卡上启用（默认）"

msgid "Enabled only on radios not shared with mesh"
msgstr "仅在非网状回程独占的无线网卡上启用"

msgid "AP SSID"
msgstr "AP 接入点 SSID"

msgid "Base SSID for the access point. Max 22 chars with suffix enabled, 30 without. Leave empty to use the SSID from wireless config."
msgstr "AP 的基础 SSID 名称。启用后缀时最长 22 字符，禁用时最长 30 字符。留空则使用 wireless 配置中的 SSID。"

msgid "SSID Suffix"
msgstr "SSID 后缀"

msgid "Append the last 4 digits of the mesh interface MAC to the SSID to distinguish nodes."
msgstr "在 SSID 末尾追加网状接口 MAC 地址的最后 4 位，便于区分不同节点的 AP。"

msgid "AP Encryption"
msgstr "AP 加密方式"

msgid "OWE — Opportunistic Wireless Encryption (default)"
msgstr "OWE — 机会性无线加密（默认）"

msgid "None / OWE transition"
msgstr "不加密 / OWE 过渡模式"

msgid "SAE (WPA3)"
msgstr "SAE（WPA3）"

msgid "SAE-Mixed (WPA2+WPA3)"
msgstr "SAE 混合（WPA2+WPA3）"

msgid "WPA2 PSK"
msgstr "WPA2 PSK"

msgid "AP Password"
msgstr "AP 接入点密码"

msgid "Mesh Path Cost (STP)"
msgstr "网状路径代价（STP）"

msgid "STP link cost for the mesh network. Range 0–65534. 0 disables STP. Default: 10."
msgstr "网状网络的 STP 链路代价，范围 0–65534。设为 0 则禁用 STP。默认：10。"

msgid "Node Mobility Level"
msgstr "节点移动性级别"

msgid "Tunes path-selection aggressiveness. Use 1 for fixed deployments; increase for mobile nodes."
msgstr "调整路径选择算法的激进程度。固定部署使用 1（低），移动场景酌情调高。"

msgid "0 - Stationary (not recommended)"
msgstr "0 - 固定部署（不推荐）"

msgid "1 - Low (default, up to 1.5 m/s)"
msgstr "1 - 低速（默认，≤1.5 m/s）"

msgid "2 - Medium"
msgstr "2 - 中速"

msgid "3 - High"
msgstr "3 - 高速"

msgid "4 - Very High"
msgstr "4 - 极高速"

msgid "Path Stabilisation"
msgstr "路径稳定化"

msgid "Prevents path flapping caused by multipath signal-strength jitter. Usually not needed above mobility level 1. Default: disabled."
msgstr "防止因多路径信号抖动导致路径频繁切换。移动性级别 > 1 时通常无需启用。默认：禁用。"

msgid "Reactive Path Stabilisation Threshold"
msgstr "响应式路径稳定化阈值"

msgid "Number of check intervals an unstable neighbour path must persist before path stabilisation activates. Default: 10."
msgstr "邻居节点路径不稳定持续多少个检查间隔后才激活路径稳定化。默认：10。"

msgid "MAC Forced Forwarding"
msgstr "MAC 强制转发"

msgid "Enable MAC forced forwarding on the mesh interface to improve Layer 2 forwarding reliability. Default: enabled."
msgstr "在网状接口上启用 MAC 强制转发，提升二层转发可靠性。默认：启用。"

msgid "Gateway Proxy ARP"
msgstr "网关代理 ARP"

msgid "Enable proxy ARP on the gateway bridge interface to improve ARP resolution. Default: enabled."
msgstr "在网关桥接接口上启用代理 ARP，改善 ARP 解析可靠性。默认：启用。"

msgid "Leech Mode"
msgstr "寄生模式"

msgid "Node acts as AP only: uses mesh backhaul but does not contribute to routing or forwarding. Useful when the node is within range of 2+ peer nodes to avoid unstable multi-hop paths. Requires mobility level 0 and non-portal role."
msgstr "节点仅作为 AP，借用网状回程但不参与路由或转发。适用于覆盖范围内有 2 个以上对等节点、避免产生不稳定多跳路径的场景。需要移动性级别 0 且为非门户节点。"

msgid "TX Power (dBm)"
msgstr "发射功率（dBm）"

msgid "Transmit power for the mesh radio. Values outside the regulatory domain are ignored. Leave empty for driver/wireless default."
msgstr "网状无线电的发射功率。超出监管域限制的值将被忽略。留空则使用驱动/wireless 默认值。"

msgid "Enable VXLAN Tunnel"
msgstr "启用 VXLAN 隧道"

msgid "Point-to-multipoint VXLAN tunnel between the portal and all compatible peers. Requires <b>ip-full</b> and <b>vxlan</b> packages; ignored otherwise. Disabled by default when Node Role is CPE (3)."
msgstr "在门户与所有兼容对等节点之间建立点对多点 VXLAN 隧道。需要安装 <b>ip-full</b> 和 <b>vxlan</b> 软件包，否则忽略此选项。节点角色为 CPE（3）时默认禁用。"

msgid "Tunnel ID"
msgstr "隧道 ID"

msgid "VXLAN tunnel identifier. Decimal, range 1–16777216 (24-bit). Default: 69."
msgstr "VXLAN 隧道标识符，十进制，范围 1–16777216（24 位）。默认：69。"

msgid "VXLAN Tunnel IPv4 Gateway"
msgstr "VXLAN 隧道 IPv4 网关"

msgid "IPv4 gateway address for the vxlan tunnel bridge. Active only when this node becomes a portal. Default: auto-generated."
msgstr "vxlan 隧道桥的 IPv4 网关地址，仅在本节点成为门户时生效。默认：自动生成。"

msgid "VXLAN Tunnel Subnet Mask"
msgstr "VXLAN 隧道子网掩码"

msgid "IPv4 subnet mask for the vxlan tunnel bridge. Active only when this node becomes a portal. Default: 255.255.255.0."
msgstr "vxlan 隧道桥的 IPv4 子网掩码，仅在本节点成为门户时生效。默认：255.255.255.0。"

msgid "VXLAN Path Cost (STP)"
msgstr "VXLAN 路径代价（STP）"

msgid "STP link cost for the vxlan tunnel network. Range 0–65534. 0 disables STP. Default: 10."
msgstr "vxlan 隧道网络的 STP 链路代价，范围 0–65534。设为 0 则禁用 STP。默认：10。"

msgid "VXLAN AP SSID"
msgstr "VXLAN AP SSID"

msgid "Base SSID for the AP attached to the vxlan tunnel. Max 22 chars with suffix, 30 without. Default: VTunnel."
msgstr "连接到 vxlan 隧道的 AP 基础 SSID。启用后缀时最长 22 字符，禁用时最长 30 字符。默认：VTunnel。"

msgid "VXLAN AP Encryption"
msgstr "VXLAN AP 加密方式"

msgid "Encryption for the AP attached to the vxlan tunnel."
msgstr "连接到 vxlan 隧道的 AP 加密方式。"

msgid "VXLAN AP Password"
msgstr "VXLAN AP 密码"

msgid "Encryption key for the vxlan-attached AP. Minimum 8 characters."
msgstr "连接到 vxlan 隧道的 AP 加密密钥，最少 8 个字符。"

msgid "Reboot on Error"
msgstr "出错时自动重启"

msgid "Reboot the node when the watchdog detects IPv4 communication failure with the portal. Default: enabled."
msgstr "当看门狗检测到与门户的 IPv4 通信失败时，自动重启本节点。默认：启用。"

msgid "Stop on Error (overrides Reboot on Error)"
msgstr "出错时停止服务（覆盖"出错重启"选项）"

msgid "When the watchdog detects a portal communication failure, the daemon goes idle instead of rebooting. Useful for nodes without a reset button. Takes priority over Reboot on Error."
msgstr "当看门狗检测到门户通信失败时，守护进程进入空闲而非重启。适用于无复位按钮的节点。此选项优先于"出错重启"。"

msgid "Enable AP Monitor (apmond)"
msgstr "启用 AP 监控守护进程（apmond）"

msgid "Collects AP interface data from this node and sends it to the portal. Requires uhttpd and px5g-mbedtls packages."
msgstr "收集本节点 AP 接口数据并上报门户节点。需要安装 uhttpd 和 px5g-mbedtls 软件包。"

msgid "apmond CGI Directory"
msgstr "apmond CGI 目录"

msgid "Path for apmond CGI scripts when this node becomes a portal. Default: /www/cgi-bin."
msgstr "本节点成为门户时 apmond CGI 脚本的存放路径。默认：/www/cgi-bin。"

msgid "Mesh Backhaul LED"
msgstr "网状回程 LED"

msgid "LED is solid when the mesh interface is up; switches to Linux heartbeat when peers are connected. Set to <b>none</b> to disable, or enter an LED name from /sys/class/leds/ (e.g. blue:run). Default: auto (uses power/system LED)."
msgstr "网状接口启动时 LED 常亮，有对等节点连接后变为 Linux 心跳信号。填写 <b>none</b> 禁用，或填写 /sys/class/leds/ 下的 LED 名称（如 blue:run）。默认：auto（使用电源/系统 LED）。"

msgid "Manage openNDS Startup"
msgstr "管理 openNDS 启动顺序"

msgid "If openNDS is installed, mesh11sd manages its startup and synchronises nft rulesets. Disabling may cause crash loops because the openNDS gateway interface may not be ready in time."
msgstr "若安装了 openNDS，由 mesh11sd 管理其启动顺序并同步 nft 规则集。禁用可能因 openNDS 网关接口未就绪而导致崩溃循环。"

msgid "Watchdog Non-volatile Log (debug only)"
msgstr "看门狗非易失性日志（仅用于调试）"

msgid "<b>Warning:</b> Writes watchdog actions to non-volatile storage (/mesh11sd_log/mesh11sd.log). Leaving this enabled long-term may cause irreparable flash wear and consume storage. <b>Disable immediately after debugging.</b>"
msgstr "<b>警告：</b>将看门狗操作写入非易失性存储（/mesh11sd_log/mesh11sd.log）。长期启用可能导致 Flash 不可修复磨损并占用存储空间。<b>调试完成后请立即关闭。</b>"

msgid "Mesh Driver Parameters"
msgstr "网状驱动参数"

msgid "Dynamic parameters passed directly to the wireless driver and continuously re-applied every check interval. Run \"mesh11sd status\" for the full list of supported parameters."
msgstr "直接传递给无线驱动的动态参数，每个检查间隔持续重新应用。运行 \"mesh11sd status\" 可查看完整的支持参数列表。"

msgid "RSSI Threshold (dBm)"
msgstr "RSSI 门限（dBm）"

msgid "Minimum signal strength required to establish a peer link (e.g. -70). Range: -100 to 0."
msgstr "建立对等链路所需的最低信号强度（如 -70）。范围：-100 到 0。"

msgid "Max Peer Links"
msgstr "最大对等链路数"

msgid "Maximum number of peer links allowed per node."
msgstr "每个节点允许建立的最大对等链路数量。"
