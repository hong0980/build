#!/bin/sh

chmod +x /etc/init.d/nikki \
         /etc/nikki/scripts/debug.sh \
         /etc/nikki/scripts/include.sh \
         /etc/nikki/scripts/firewall_include.sh

. /lib/functions.sh
. /etc/nikki/scripts/include.sh
mkdir -p "$PROFILES_DIR" "$SUBSCRIPTIONS_DIR" "$RULE_PROVIDERS_DIR" "$PROXY_PROVIDERS_DIR"
config_load nikki

# since v1.18.0

config_get val mixin rule
[ -z "$val" ] && uci -q set nikki.mixin.rule=0

config_get val mixin rule_provider
[ -z "$val" ] && uci -q set nikki.mixin.rule_provider=0

# since v1.19.0

uci show nikki | grep -E 'nikki\.@rule\[[[:digit:]]+\].match=' | \
	sed 's/nikki.@rule\[\([[:digit:]]\+\)\].match=.*/rename nikki.@rule[\1].match=matcher/' | \
	uci batch

# since v1.19.1

config_get val proxy fake_ip_ping_hijack
[ -z "$val" ] && uci -q set nikki.proxy.fake_ip_ping_hijack=0

# since v1.20.0

config_get val mixin api_port
[ -n "$val" ] && {
	uci -q del nikki.mixin.api_port
	uci -q set nikki.mixin.api_listen="[::]:$val"
}

config_get val mixin dns_port
[ -n "$val" ] && {
	uci -q del nikki.mixin.dns_port
	uci -q set nikki.mixin.dns_listen="[::]:$val"
}

# since v1.22.0

config_get val proxy transparent_proxy
[ -n "$val" ] && {
	uci -q rename nikki.proxy.transparent_proxy=enabled
	uci -q rename nikki.proxy.tcp_transparent_proxy_mode=tcp_mode
	uci -q rename nikki.proxy.udp_transparent_proxy_mode=udp_mode
	uci -q add nikki router_access_control
	uci -q set nikki.@router_access_control[-1].enabled=1

	config_get val proxy bypass_user
	[ -n "$val" ] && {
		for router_access_control_user in $val; do
			uci -q add_list nikki.@router_access_control[-1].user="$router_access_control_user"
		done
	}
	config_get val proxy bypass_group
	[ -n "$val" ] && {
		for router_access_control_group in $val; do
			uci -q add_list nikki.@router_access_control[-1].group="$router_access_control_group"
		done
	}
	config_get val proxy bypass_cgroup
	[ -n "$val" ] && {
		for router_access_control_cgroup in $val; do
			uci -q add_list nikki.@router_access_control[-1].cgroup="$router_access_control_cgroup"
		done
	}
	uci -q set nikki.@router_access_control[-1].proxy=0
	uci -q add nikki router_access_control
	uci -q set nikki.@router_access_control[-1].enabled=1
	uci -q set nikki.@router_access_control[-1].proxy=1
	uci -q add_list nikki.proxy.lan_inbound_interface=lan

	config_get val proxy access_control_mode

	[ "$val" != "all" ] && {
		config_get proxy_acl_ip proxy acl_ip
		[ -n "$proxy_acl_ip" ] && {
			for ip in $proxy_acl_ip; do
				uci -q add nikki lan_access_control
				uci -q set nikki.@lan_access_control[-1].enabled=1
				uci -q add_list nikki.@lan_access_control[-1].ip="$ip"
				[ "$val" = "allow" ] && uci -q set nikki.@lan_access_control[-1].proxy=1
				[ "$val" = "block" ] && uci -q set nikki.@lan_access_control[-1].proxy=0
			done
		}
		config_get proxy_acl_ip6 proxy acl_ip6
		[ -n "$proxy_acl_ip6" ] && {
			for ip6 in $proxy_acl_ip6; do
				uci -q add nikki lan_access_control
				uci -q set nikki.@lan_access_control[-1].enabled=1
				uci -q add_list nikki.@lan_access_control[-1].ip6="$ip6"
				[ "$val" = "allow" ] && uci -q set nikki.@lan_access_control[-1].proxy=1
				[ "$val" = "block" ] && uci -q set nikki.@lan_access_control[-1].proxy=0
			done
		}
		config_get proxy_acl_mac proxy acl_mac
		[ -n "$proxy_acl_mac" ] && {
			for mac in $proxy_acl_mac; do
				uci -q add nikki lan_access_control
				uci -q set nikki.@lan_access_control[-1].enabled=1
				uci -q add_list nikki.@lan_access_control[-1].mac="$mac"
				[ "$val" = "allow" ] && uci -q set nikki.@lan_access_control[-1].proxy=1
				[ "$val" = "block" ] && uci -q set nikki.@lan_access_control[-1].proxy=0
			done
		}
	}

	[ "$val" != "allow" ] && {
		uci -q add nikki lan_access_control
		uci -q set nikki.@lan_access_control[-1].enabled=1
		uci -q set nikki.@lan_access_control[-1].proxy=1
	}

	uci -q batch <<-EOF > /dev/null
		del nikki.proxy.access_control_mode
		del nikki.proxy.acl_ip
		del nikki.proxy.acl_ip6
		del nikki.proxy.acl_mac
		del nikki.proxy.acl_interface
		del nikki.proxy.bypass_user
		del nikki.proxy.bypass_group
		del nikki.proxy.bypass_cgroup
	EOF
}

# since v1.23.0

config_get val routing ''
[ -z "$val" ] && {
	uci -q batch <<-EOF > /dev/null
		set nikki.routing=routing
		set nikki.routing.tproxy_fw_mark=0x80
		set nikki.routing.tun_fw_mark=0x81
		set nikki.routing.tproxy_rule_pref=1024
		set nikki.routing.tun_rule_pref=1025
		set nikki.routing.tproxy_route_table=80
		set nikki.routing.tun_route_table=81
		set nikki.routing.cgroup_id=0x12061206
		set nikki.routing.cgroup_name=nikki
	EOF
}

config_get val proxy tun_timeout
[ -z "$val" ] && uci -q set nikki.proxy.tun_timeout=30

config_get val proxy tun_interval
[ -z "$val" ] && uci -q set nikki.proxy.tun_interval=1

# since v1.23.1

migrate_rac_cgroup_item() {
	local cgroup="$1" cfg="$2"
	[ -d "/sys/fs/cgroup/$cgroup" ] && return
	[ -d "/sys/fs/cgroup/services/$cgroup" ] && {
		uci -q del_list "nikki.$cfg.cgroup=$cgroup"
		uci -q add_list "nikki.$cfg.cgroup=services/$cgroup"
	}
}

migrate_router_access_control_cgroup() {
	local cfg="$1"
	config_list_foreach "$cfg" cgroup migrate_rac_cgroup_item "$cfg"
}

config_foreach migrate_router_access_control_cgroup router_access_control

# since v1.23.3

sync_dns_from_proxy() {
	local cfg="$1"
	local proxy dns
	config_get proxy "$cfg" proxy
	config_get dns   "$cfg" dns
	[ -z "$dns" ] && uci -q set "nikki.$cfg.dns=$proxy"
}

config_foreach sync_dns_from_proxy router_access_control
config_foreach sync_dns_from_proxy lan_access_control

# since v1.24.0

config_get val proxy reserved_ip
[ -z "$val" ] && {
	uci -q batch <<-EOF > /dev/null
		add_list nikki.proxy.reserved_ip=0.0.0.0/8
		add_list nikki.proxy.reserved_ip=10.0.0.0/8
		add_list nikki.proxy.reserved_ip=127.0.0.0/8
		add_list nikki.proxy.reserved_ip=100.64.0.0/10
		add_list nikki.proxy.reserved_ip=169.254.0.0/16
		add_list nikki.proxy.reserved_ip=172.16.0.0/12
		add_list nikki.proxy.reserved_ip=192.168.0.0/16
		add_list nikki.proxy.reserved_ip=224.0.0.0/4
		add_list nikki.proxy.reserved_ip=240.0.0.0/4
	EOF
}

config_get val proxy reserved_ip6
[ -z "$val" ] && {
	uci -q batch <<-EOF > /dev/null
		add_list nikki.proxy.reserved_ip6=::/128
		add_list nikki.proxy.reserved_ip6=::1/128
		add_list nikki.proxy.reserved_ip6=::ffff:0:0/96
		add_list nikki.proxy.reserved_ip6=100::/64
		add_list nikki.proxy.reserved_ip6=64:ff9b::/96
		add_list nikki.proxy.reserved_ip6=2001::/32
		add_list nikki.proxy.reserved_ip6=2001:10::/28
		add_list nikki.proxy.reserved_ip6=2001:20::/28
		add_list nikki.proxy.reserved_ip6=2001:db8::/32
		add_list nikki.proxy.reserved_ip6=2002::/16
		add_list nikki.proxy.reserved_ip6=fc00::/7
		add_list nikki.proxy.reserved_ip6=fe80::/10
		add_list nikki.proxy.reserved_ip6=ff00::/8
	EOF
}

# since v1.24.3

config_get proxy_bypass_china_mainland_ip  proxy bypass_china_mainland_ip
config_get val proxy bypass_china_mainland_ip6
[ -z "$val" ] && uci -q set nikki.proxy.bypass_china_mainland_ip6=$proxy_bypass_china_mainland_ip

config_get val routing tproxy_fw_mask
[ -z "$val" ] && uci -q set nikki.routing.tproxy_fw_mask=0xFF

config_get val routing tun_fw_mask
[ -z "$val" ] && uci -q set nikki.routing.tun_fw_mask=0xFF

config_get section_procd procd ''
[ -z "$section_procd" ] && {
	uci -q set nikki.procd=procd
	config_get val config fast_reload
	uci -q set nikki.procd.fast_reload=$val
	config_get val env safe_paths
	uci -q set nikki.procd.env_safe_paths=$val
	config_get val env disable_loopback_detector
	uci -q set nikki.procd.env_disable_loopback_detector=$val
	config_get val env disable_quic_go_gso
	uci -q set nikki.procd.env_disable_quic_go_gso=$val
	config_get val env disable_quic_go_ecn
	uci -q set nikki.procd.env_disable_quic_go_ecn=$val
	config_get val env skip_system_ipv6_check
	uci -q set nikki.procd.env_skip_system_ipv6_check=$val
	uci -q del nikki.config.fast_reload
	uci -q del nikki.env
}

# since v1.25.1

config_get val routing dummy_device
[ -z "$val" ] && uci -q set nikki.routing.dummy_device=nikki-dummy

# since v1.25.2

config_get val core ''
[ -z "$val" ] && {
	uci -q batch <<-EOF > /dev/null
		set nikki.core=core
		set nikki.core.redirect_listener_name=redir-in
		set nikki.core.tproxy_listener_name=tproxy-in
		set nikki.core.tun_listener_name=tun-in
	EOF
}

# since v1.25.3

config_get val config scheduled_restart_cron
[ -z "$val" ] && uci -q rename nikki.config.cron_expression=scheduled_restart_cron

config_get val log scheduled_clear
[ -z "$val" ] && uci -q set nikki.log.scheduled_clear=1

config_get val log scheduled_clear_cron
[ -z "$val" ] && uci -q set nikki.log.scheduled_clear_cron="*/5 * * * *"

config_get val log scheduled_clear_size_limit
[ -z "$val" ] && uci -q set nikki.log.scheduled_clear_size_limit=1

config_get val log scheduled_clear_size_limit_unit
[ -z "$val" ] && uci -q set nikki.log.scheduled_clear_size_limit_unit=MB

# since v1.25.4

config_get val log clear_at_stop
[ -z "$val" ] && uci -q set nikki.log.clear_at_stop=1

# check nikki.config.init
config_get init config init
[ -n "$init" ] && {
	# generate random string for api secret and authentication password
	random=$(awk 'BEGIN{srand(); printf "%06d", int(rand() * 1000000)}')
	uci -q set nikki.mixin.api_secret="$random"
	uci -q set nikki.@authentication[0].password="$random"
	uci -q del nikki.config.init
}

# commit
uci -q commit nikki

uci -q batch <<-EOF > /dev/null
	del firewall.nikki
	set firewall.nikki=include
	set firewall.nikki.type=script
	set firewall.nikki.path=$FIREWALL_INCLUDE_SH
	set firewall.nikki.fw4_compatible=1
	commit firewall
EOF

rm -f /tmp/luci-*

exit 0
