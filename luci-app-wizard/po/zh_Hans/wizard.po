# 中文翻译 — luci-app-wizard
# 仅包含 wizard.js / file.js 中实际存在的字符串，以及菜单标题。

# ── 菜单 ──────────────────────────────────────────────────────────────────
msgid "Wizard"
msgstr "快捷设置"

msgid "Configuration"
msgstr "基本设置"

msgid "Files"
msgstr "文件编辑"

# ── wizard.js — 页面标题 ──────────────────────────────────────────────────
msgid "Inital Router Setup"
msgstr "路由器初始设置"

msgid "If you are using this router for the first time, please configure it here."
msgstr "如果您是第一次使用此路由器，请在此进行配置。"

msgid "Wan Settings"
msgstr "WAN 设置"

msgid "There are several different ways to access the Internet, please choose according to your own situation."
msgstr "几种不同的上网方式，请您根据自身情况进行选择。"

msgid "Lan Settings"
msgstr "内网设置"

msgid "Wireless Settings"
msgstr "无线设置"

msgid "Set the router's wireless name and password. For more advanced settings, please go to the Network-Wireless page."
msgstr "设置路由器的无线名称和密码。如需更高级的设置，请前往网络-无线页面。"

# ── wizard.js — 协议选择 ──────────────────────────────────────────────────
msgid "Protocol"
msgstr "上网协议"

msgid "Select the network access protocol to determine how the router connects to the Internet."
msgstr "选择上网协议，决定路由器如何连接到互联网。"

msgid "DHCP client"
msgstr "DHCP 客户端（自动获取）"

msgid "PPPoE"
msgstr "PPPoE 拨号"

msgid "Access Point (AP)"
msgstr "AP 模式（无线接入点）"

msgid "Side Router"
msgstr "旁路由"

# ── wizard.js — PPPoE ─────────────────────────────────────────────────────
msgid "PAP/CHAP username"
msgstr "PPPoE 用户名"

msgid "Username for PPPoE dial-up."
msgstr "宽带拨号的用户名（由运营商提供）。"

msgid "PAP/CHAP password"
msgstr "PPPoE 密码"

msgid "Password for PPPoE dial-up."
msgstr "宽带拨号的密码（由运营商提供）。"

msgid "Obtain IPv6 address"
msgstr "获取 IPv6 地址"

msgid "Enable IPv6 negotiation on the PPP link"
msgstr "在 PPP 链路上启用 IPv6 协商"

msgid "Automatic"
msgstr "自动"

msgid "Disabled"
msgstr "禁用"

msgid "Manual"
msgstr "手动"

# ── wizard.js — AP 模式 ───────────────────────────────────────────────────
msgid "AP management IP"
msgstr "AP 管理 IP 分配方式"

msgid "In AP mode all ports are bridged to the main router. Choose \"Auto (DHCP)\" to let the main router assign a management IP automatically (recommended). Choose \"Static\" only if you need a fixed IP to access this device."
msgstr "AP 模式下，本机将所有端口桥接到主路由器，不做路由和 NAT。\n推荐选"自动获取"：管理 IP 由主路由器自动分配，无需手动填写任何参数。\n仅在需要固定管理 IP 时才选"静态 IP"。"

msgid "Auto (DHCP) — recommended"
msgstr "自动获取 (DHCP) — 推荐"

msgid "Static IP"
msgstr "静态 IP"

msgid "Bridge IP address"
msgstr "桥接管理 IP"

msgid "Static management IP for this router in AP mode. Must be in the same subnet as the main router."
msgstr "AP 模式下本机的静态管理 IP，须与主路由器在同一子网内（如 192.168.1.2）。"

msgid "Bridge netmask"
msgstr "桥接子网掩码"

msgid "Subnet mask matching the main network (e.g. 255.255.255.0)."
msgstr "与主路由器网络相同的子网掩码（如 255.255.255.0）。"

msgid "Bridge gateway"
msgstr "桥接网关"

msgid "Main router IP address (e.g. 192.168.1.1). Used as default gateway for management traffic."
msgstr "主路由器的 IP 地址（如 192.168.1.1），作为本机管理流量的默认网关。"

msgid "DHCP server"
msgstr "DHCP 服务"

msgid "Should be disabled in AP mode — the main router handles DHCP for all clients."
msgstr "AP 模式下应禁用本机 DHCP，由主路由器统一为所有设备分配 IP。"

msgid "Disabled (recommended)"
msgstr "禁用（推荐）"

msgid "Enabled"
msgstr "启用"

msgid "Bridge interfaces"
msgstr "桥接接口"

msgid "Interfaces to include in the bridge (typically LAN ports and wireless interfaces). The WAN port connects to the main router."
msgstr "加入桥接的接口（通常为 LAN 口和无线接口）。WAN 口用于连接主路由器。"

msgid "At least one interface must be selected"
msgstr "至少需要选择一个接口"

# ── wizard.js — 旁路由模式 ────────────────────────────────────────────────
msgid "WAN IP address"
msgstr "WAN 口静态 IP"

msgid "Static IP for this router's WAN port on the main network (e.g. 192.168.1.2). Clients that want to use this router as gateway will point to this IP."
msgstr "本机 WAN 口在主路由器网段内的静态 IP（如 192.168.1.2）。\n需要使用本机作为网关的客户端，将其默认网关设为此 IP。"

msgid "WAN netmask"
msgstr "WAN 子网掩码"

msgid "Subnet mask of the main network."
msgstr "与主路由器相同的子网掩码。"

msgid "Main router IP"
msgstr "主路由器 IP"

msgid "IP address of the main router (e.g. 192.168.1.1). Used as the default gateway for upstream traffic."
msgstr "主路由器的 IP 地址（如 192.168.1.1），本机将通过主路由器访问互联网。"

msgid "LAN IP address"
msgstr "本机 LAN IP"

msgid "This router's LAN IP. Clients set their gateway to this address to route through this device. Must be in a different subnet from the main router (e.g. 192.168.2.1)."
msgstr "本机 LAN 口的 IP 地址。需要使用旁路由功能的客户端，将其网关设为此地址。\n必须与主路由器在不同子网（例如主路由为 192.168.1.x，本机设 192.168.2.1）。"

msgid "The LAN IP must be in a different subnet from the main router IP (%s). Try e.g. 192.168.2.1."
msgstr "LAN IP 必须与主路由器 IP（%s）处于不同子网。建议设为 192.168.2.1 等其他网段。"

msgid "LAN netmask"
msgstr "LAN 子网掩码"

msgid "This router's LAN segment subnet mask."
msgstr "本机 LAN 网段的子网掩码。"

msgid "LAN DHCP server"
msgstr "LAN DHCP 服务"

msgid "Enable to let this router assign IPs to its own LAN clients (recommended when clients connect directly to this router). Disable if clients are managed by the main router."
msgstr "启用：本机为自己 LAN 段的客户端分配 IP（推荐）。\n禁用：由主路由器统一管理所有设备。"

msgid "Enabled (recommended)"
msgstr "启用（推荐）"

msgid "WAN interface"
msgstr "WAN 接口"

msgid "The interface connected to the main router (typically the WAN port)."
msgstr "连接到主路由器的接口（通常为 WAN 口）。"

# ── wizard.js — DNS ───────────────────────────────────────────────────────
msgid "WAN DNS servers"
msgstr "WAN DNS 服务器"

msgid "Custom DNS servers for the WAN interface. Leave empty to use the ISP-assigned DNS."
msgstr "WAN 接口使用的自定义 DNS 服务器。留空则使用运营商自动下发的 DNS。"

msgid "LAN DNS servers"
msgstr "LAN DNS 服务器"

msgid "DNS servers pushed to LAN clients via DHCP."
msgstr "通过 DHCP 下发给局域网客户端的 DNS 服务器地址。"

msgid "AliDNS: 223.5.5.5"
msgstr "阿里 DNS：223.5.5.5"

msgid "AliDNS: 223.6.6.6"
msgstr "阿里 DNS：223.6.6.6"

msgid "DNSPod: 101.226.4.6"
msgstr "DNS派：101.226.4.6"

msgid "DNSPod: 218.30.118.6"
msgstr "DNS派：218.30.118.6"

msgid "BaiduDNS: 180.76.76.76"
msgstr "百度 DNS：180.76.76.76"

msgid "114DNS: 114.114.114.114"
msgstr "114DNS：114.114.114.114"

msgid "114DNS: 114.114.115.115"
msgstr "114DNS：114.114.115.115"

# ── wizard.js — LAN 设置 ──────────────────────────────────────────────────
msgid "IPv4 address"
msgstr "IPv4 地址"

msgid "IPv4 address for the LAN interface."
msgstr "路由器 LAN 口的 IPv4 地址。"

msgid "IPv4 netmask"
msgstr "子网掩码"

msgid "Subnet mask for the LAN interface."
msgstr "路由器 LAN 接口的子网掩码。"

# ── wizard.js — 无线设置 ──────────────────────────────────────────────────
msgid "<abbr title='Extended Service Set Identifier'>ESSID</abbr>"
msgstr "<abbr title='无线网络名称'>ESSID</abbr>"

msgid "SSID of the wireless network, with a maximum length of 32 characters."
msgstr "无线网络名称（SSID），最长 32 个字符。"

msgid "Key"
msgstr "无线密码"

msgid "Password for the wireless network, compliant with WPA key requirements."
msgstr "无线网络密码，需符合 WPA 密钥规范（至少 8 位）。"

# ── file.js ───────────────────────────────────────────────────────────────
msgid "The configuration file is directly edited and saved! Unless you know what you are doing, please do not modify these configuration files. Incorrect configurations may cause issues such as failure to boot or network errors."
msgstr "⚠️ 此处直接编辑并保存配置文件！除非您清楚自己在做什么，否则请勿随意修改。配置错误可能导致路由器无法启动或无法联网。"

msgid "It is recommended to back up the file before making changes. Comments can be added by starting a line with #."
msgstr "修改前建议先备份原始文件。可以在行首添加 # 来注释掉某行。"

msgid "Choose File"
msgstr "选择文件"

msgid "-- Please choose --"
msgstr "-- 请选择 --"

msgid "Readonly"
msgstr "只读"

msgid "Last modified: %s, Size: %s bytes"
msgstr "最后修改：%s，文件大小：%s 字节"

msgid "Error: File configuration not found."
msgstr "错误：未找到对应的文件配置。"

msgid "No modifications detected. The content remains unchanged."
msgstr "未检测到修改，内容未发生变化。"

msgid "Contents have been saved."
msgstr "内容已保存。"

msgid "Service %s reloaded successfully."
msgstr "服务 %s 重载成功。"

msgid "Service reload failed: %s"
msgstr "服务重载失败：%s"

msgid "Unable to save contents: %s"
msgstr "无法保存内容：%s"

msgid "Network configuration (network)"
msgstr "网络配置（network）"

msgid "Firewall configuration (firewall)"
msgstr "防火墙配置（firewall）"

msgid "DHCP configuration (dhcp)"
msgstr "DHCP 配置（dhcp）"

msgid "DNS configuration (dnsmasq)"
msgstr "DNS 配置（dnsmasq）"

msgid "Web server configuration (uhttpd)"
msgstr "Web 服务器配置（uhttpd）"

msgid "Wireless configuration (wireless)"
msgstr "无线配置（wireless）"

msgid "Host configuration (hosts)"
msgstr "主机名配置（hosts）"

msgid "Scheduled tasks (crontabs)"
msgstr "定时任务（crontabs）"

msgid "Startup script (rc.local)"
msgstr "开机启动脚本（rc.local）"
