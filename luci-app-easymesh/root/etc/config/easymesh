config easymesh 'global'
	option enabled '0'
	option role 'master'
	option backhaul 'wired'
	option mesh_id 'OpenWrt-Mesh'
	option mesh_key 'meshpassword'
	option mesh_band '5g'
	option ssid 'OpenWrt'
	option key 'password'
	option ieee80211r '1'
	option mobility_domain 'aabb'
	option ieee80211k '1'
	option ieee80211v '1'
	option wireless_onboard '0'
	# Dedicated backhaul radio (tri-band: use second 5GHz radio for backhaul only)
	option dedicated_backhaul '0'
	option backhaul_channel '149'
	# DFS/ACS
	option dfs_enable '1'
	# batman-adv routing algorithm: BATMAN_IV (default) or BATMAN_V
	option routing_algo 'BATMAN_V'
	option band_merge '1'
	# 非合并模式下的分频段配置（band_merge=0时生效）
	#option ssid_5g 'HomeNetwork_5G'
	#option ssid_2g 'HomeNetwork_2.4G'
	#option key_5g 'password5g'
	#option key_2g 'password2g'
	# WAN口模式：router=正常路由（WAN口独立），switch=全部作为LAN口
	option wan_mode 'router'
