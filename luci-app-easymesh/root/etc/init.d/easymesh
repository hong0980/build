#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

. /lib/functions/network.sh

UCI_APP=easymesh
LOGFILE="/tmp/easymesh.log"
lang=$(uci get luci.main.lang 2>/dev/null)
translate() {
    local template="$1"
    shift

    local lua_script=$(cat <<LUA
    require "luci.i18n".setlanguage("$lang")
    print(require "luci.i18n".translate([==[$template]==]))
LUA
    )
    local translated=$(lua -e "$lua_script")

    if [ $# -gt 0 ]; then
        printf "$translated" "$@"
    else
        echo "$translated"
    fi
}
_emlog() {
    local level="$1" tag="$2"; shift 2
    local ts; ts=$(date "+%Y-%m-%d %H:%M:%S")
    printf "%s [%-5s] [%-8s] %s\n" "$ts" "$level" "$tag" "$*" >> "$LOGFILE"
}
log()  { _emlog "INFO"  "initd" $(translate "$*"); }
loge() { _emlog "ERROR" "initd" $(translate "$*"); }

# ── Find radio for given band ─────────────────────────────────────────────────
_band_target=""; _found=""
_find_radio() {
    local _n="$1" _b
    config_get _b "$_n" band
    case "$_b" in
        2g|2.4GHz|bgn|bg|b) [ "$_band_target" = "2g" ] && _found="$_n" ;;
        5g|5GHz|an|a)        [ "$_band_target" = "5g" ] && _found="$_n" ;;
    esac
}
get_radio() {
    local _v="$1" _b="$2"
    _found=""; _band_target="$_b"
    config_load wireless
    config_foreach _find_radio wifi-device
    eval "$_v='$_found'"
}

# ── Remove only easymesh-managed wireless interfaces ─────────────────────────
_del_managed() {
    local _n="$1" _m
    config_get _m "$_n" easymesh_managed
    [ "$_m" = "1" ] && uci -q del wireless."$_n" && log "Removed managed iface: %s" "$_n"
}
cleanup_wireless() {
    config_load wireless
    config_foreach _del_managed wifi-iface
    uci commit wireless
}

# ── Undo only the network changes easymesh made ──────────────────────────────
cleanup_network() {
    # Remove mesh network entries we created
    uci -q del network.mesh
    uci -q del network.bat0
    uci commit network

    # Restore DHCP server on LAN (was disabled on slave nodes)
    uci -q del dhcp.lan.ignore
    uci commit dhcp

    log "Network config cleaned up"
}

apply_mesh_config() {
    local role backhaul mesh_id mesh_key mesh_band ssid key
    local ieee80211r mobility_domain ft_over_ds reassociation_deadline
    local ieee80211k ieee80211v routing_algo mesh_fwding

    config_load "$UCI_APP"
    config_get role                   global role                  'master'
    config_get backhaul               global backhaul              'wired'
    config_get mesh_id                global mesh_id               'OpenWrt-Mesh'
    config_get mesh_key               global mesh_key              ''
    config_get mesh_band              global mesh_band             '5g'
    config_get ssid                   global ssid                  'OpenWrt'
    config_get key                    global key                   ''
    config_get ieee80211r             global ieee80211r            '1'
    config_get mobility_domain        global mobility_domain       'aabb'
    config_get ft_over_ds             global ft_over_ds            '1'
    config_get reassociation_deadline global reassociation_deadline '1000'
    config_get ieee80211k             global ieee80211k            '1'
    config_get ieee80211v             global ieee80211v            '1'
    config_get routing_algo           global routing_algo          'BATMAN_IV'
    config_get mesh_fwding            global mesh_fwding           '0'

    # Remove previously created wireless interfaces
    cleanup_wireless

    local radio_mesh
    get_radio radio_mesh "$mesh_band"
    [ -z "$radio_mesh" ] && radio_mesh="radio0"
    log "apply_mesh_config: role=%s backhaul=%s radio=%s" "$role" "$backhaul" "$radio_mesh"

    # ── network: mesh hardif (physical → batman-adv) ──────────────────────────
    # mesh0 is the 802.11s wifi-iface or eth interface feeding batman-adv
    uci set network.mesh=interface
    uci set network.mesh.proto='batadv_hardif'
    uci set network.mesh.master='bat0'
    uci set network.mesh.mtu='1536'

    # ── network: bat0 virtual interface ──────────────────────────────────────
    # Master: bat0 is a plain batadv interface. The daemon will do
    #         `brctl addif br-lan bat0` at runtime once bat0 is up.
    #         DO NOT touch network.lan here.
    # Slave:  bat0 gets its IP via DHCP from the master.
    uci set network.bat0=interface
    uci set network.bat0.ifname='bat0'
    uci set network.bat0.proto='batadv'          # 主从节点 bat0 都是 batadv 接口
    uci set network.bat0.routing_algo="$routing_algo"
    if [ "$role" = "master" ]; then
        # 主节点：br-lan 包含 eth0+bat0，由主节点做 DHCP server
        uci -q del dhcp.lan.ignore
        uci commit dhcp
        log "Role: master - LAN DHCP enabled, bat0=batadv"
    else
        # 从节点：br-lan 只含 eth0，从节点不做 DHCP，由主节点分配 IP
        # bat0 up 后与主节点 bat0 形成 L2 mesh，br-lan 走 DHCP client
        uci set dhcp.lan.ignore='1'
        uci commit dhcp
        log "Role: agent - LAN DHCP disabled, bat0=batadv, IP from master"
    fi
    uci commit network

    # ── wireless: mesh backhaul interface ────────────────────────────────────
    uci set wireless.mesh0=wifi-iface
    uci set wireless.mesh0.device="$radio_mesh"
    uci set wireless.mesh0.mode='mesh'
    uci set wireless.mesh0.mesh_id="$mesh_id"
    uci set wireless.mesh0.mesh_fwding="$mesh_fwding"
    uci set wireless.mesh0.mesh_rssi_threshold='-80'
    uci set wireless.mesh0.network='mesh'
    uci set wireless.mesh0.easymesh_managed='1'
    if [ -n "$mesh_key" ]; then
        uci set wireless.mesh0.encryption='sae'
        uci set wireless.mesh0.key="$mesh_key"
    else
        uci set wireless.mesh0.encryption='none'
    fi
    # Wired backhaul = disable wireless mesh; wireless/auto = enable it
    uci set wireless.mesh0.disabled=$([ "$backhaul" = "wired" ] && echo '1' || echo '0')

    # ── wireless: client AP ───────────────────────────────────────────────────
    uci set wireless.easymesh_ap=wifi-iface
    uci set wireless.easymesh_ap.device="$radio_mesh"
    uci set wireless.easymesh_ap.mode='ap'
    uci set wireless.easymesh_ap.ssid="$ssid"
    uci set wireless.easymesh_ap.network='lan'
    uci set wireless.easymesh_ap.easymesh_managed='1'
    uci set wireless.easymesh_ap.disabled='0'
    if [ -n "$key" ]; then
        uci set wireless.easymesh_ap.encryption='psk2+ccmp'
        uci set wireless.easymesh_ap.key="$key"
    else
        uci set wireless.easymesh_ap.encryption='none'
    fi
    [ "$ieee80211r" = "1" ] && {
        uci set wireless.easymesh_ap.ieee80211r='1'
        uci set wireless.easymesh_ap.mobility_domain="$mobility_domain"
        uci set wireless.easymesh_ap.ft_over_ds="$ft_over_ds"
        uci set wireless.easymesh_ap.ft_psk_generate_local='1'
        uci set wireless.easymesh_ap.reassociation_deadline="$reassociation_deadline"
    }
    [ "$ieee80211k" = "1" ] && {
        uci set wireless.easymesh_ap.ieee80211k='1'
        uci set wireless.easymesh_ap.rrm_neighbor_report='1'
        uci set wireless.easymesh_ap.rrm_beacon_report='1'
    }
    [ "$ieee80211v" = "1" ] && {
        uci set wireless.easymesh_ap.ieee80211v='1'
        uci set wireless.easymesh_ap.bss_transition='1'
    }
    uci commit wireless
    log "apply_mesh_config done"
}

# ── procd service ─────────────────────────────────────────────────────────────
start_service() {
    local enabled role
    config_load "$UCI_APP"
    config_get_bool enabled global enabled 0

    if [ "$enabled" -eq 0 ]; then
        return 0
    fi

    config_get role global role 'master'
    log "EasyMesh starting (role=%s)" "$role"

    apply_mesh_config
    ubus call uci commit '{"config":"network"}' 2>/dev/null
    /etc/init.d/network reload 2>/dev/null &

    ( sleep 3; wifi reload ) &

    log "Starting EasyMesh daemon (role=%s)..." "$role"

    procd_open_instance "easymesh-${role}"
    procd_set_param command /usr/sbin/easymesh-${role}
    procd_set_param respawn 10 3 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    log "EasyMesh stopping..."
    for pattern in easymesh-master easymesh-agent; do
        for pid in $(pgrep -f "$pattern"); do
            kill $pid 2>/dev/null || true
        done
    done
    # Remove managed wireless interfaces and mesh network config
    cleanup_wireless
    cleanup_network
    # Reload wifi and network to apply the cleanup
    ( sleep 1; wifi reload ) &
    ( sleep 1; /etc/init.d/network reload ) &
    rm -rf /tmp/easymesh* /tmp/em_req_* /tmp/em_resp_* 2>/dev/null
}

reload_service() {
    stop
    sleep 2
    start
}

service_triggers() {
    procd_add_reload_trigger "$UCI_APP"
}
