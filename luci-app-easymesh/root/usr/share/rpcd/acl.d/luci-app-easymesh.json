{
	"luci-app-easymesh": {
		"description": "Grant UCI and ubus access for EasyMesh",
		"read": {
			"uci": [ "easymesh", "wireless", "network", "batman-adv" ],
			"ubus": {
				"uci": [ "get", "changes" ],
				"network.interface": [ "status", "dump" ],
				"network.wireless": [ "status" ],
				"file": [ "read", "stat" ],
				"easymesh": [ "pending", "approved", "topology", "log_read" ]
			},
			"file": {
				"/tmp/easymesh.log": [ "read", "write" ],
				"/sys/kernel/debug/batman_adv/bat0/originators": [ "read" ],
				"/sys/kernel/debug/batman_adv/bat0/neighbors": [ "read" ],
				"/sys/kernel/debug/batman_adv/bat0/transtable_global": [ "read" ]
			}
		},
		"write": {
			"uci": [ "easymesh", "wireless", "network", "batman-adv" ],
			"ubus": {
				"uci": [ "add", "set", "delete", "apply", "confirm", "order" ],
				"network.interface": [ "up", "down" ],
				"easymesh": [ "approve", "reject", "log_clear" ]
			},
			"file": {
				"/tmp/easymesh.log": [ "read", "write" ]
			}
		}
	}
}
