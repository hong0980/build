#!/bin/sh
. /lib/functions.sh

# -- Files --
PROFILE_FILE="/tmp/easymesh_profile.json"
TOPO_FILE="/tmp/easymesh_topo.json"
NEIGHBOR_FILE="/tmp/easymesh_neighbors.conf"
ROAM_COOLDOWN_DIR="/tmp/em_cooldown"
export ROLE_FILE="/tmp/easymesh_role"
export MASTER_IP_FILE="/tmp/easymesh_master_ip"
export NODE_DB="/tmp/easymesh_nodes"
export PENDING_DB="/tmp/easymesh_pending"
export EM_PID_DIR="/tmp/easymesh_pids"

# -- Constants --
_is_dsa() {
    ip link show 2>/dev/null | grep -qE 'lan[0-9]+@eth'
}

_get_eth_if() {
    if _is_dsa; then
        local _parent
        _parent=$(ip link show 2>/dev/null \
            | awk -F'[@: ]+' '/lan[0-9]+@eth/{print $3; exit}')
        [ -n "$_parent" ] && echo "$_parent" && return
        echo "eth0"
    else
        local _raw _i=0 _name
        while true; do
            _name=$(uci -q get "network.@device[${_i}].name" 2>/dev/null) || break
            if [ "$_name" = "br-lan" ]; then
                _raw=$(uci -q get "network.@device[${_i}].ports" 2>/dev/null \
                    | awk '{print $1}')
                break
            fi
            _i=$((_i + 1))
        done
        [ -z "$_raw" ] && _raw=$(uci -q get network.lan.ifname 2>/dev/null \
            | awk '{print $1}')
        echo "${_raw%%.*}"
    fi
}

ETH_IF=$(_get_eth_if)
[ -z "$ETH_IF" ] && ETH_IF="eth0"
export ETH_IF
BRIDGE_IF="br-lan"
export BRIDGE_IF
AP_IF="wlan0"
MESH_IF="bat0"
export MESH_IF
LOG_MAX_LINES=300
_log_seq=0
export MASTER_PORT=4304
export DISC_PORT=4305
export DISC_REPLY_PORT=4306
export LOGFILE="/tmp/easymesh.log"

# -- Tuning --
BATMAN_OGM_INTERVAL=500
BATMAN_HOP_PENALTY=30
BATMAN_GW_MODE="client"
ROAM_RSSI_KICK=-72
ROAM_RSSI_HARD=-78
ROAM_HYSTERESIS=5
ROAM_PROBE_INTERVAL=5
ROAM_COOLDOWN_TIME=30
LB_CLIENT_THRESHOLD=15
CHANNEL_SCAN_INTERVAL=120
ELECTION_INTERVAL=30
GW_WATCHDOG_INTERVAL=10
HTTP_MAX_RETRIES=3
HTTP_TIMEOUT=5

lang=$(uci_get luci main lang en)

translate() {
    local tpl="$1"; shift
    local translated
    translated=$(lua -e "require \"luci.i18n\".setlanguage(\"${lang}\"); print(require \"luci.i18n\".translate([==[${tpl}]==]))" 2>/dev/null)
    [ -z "$translated" ] && translated="$tpl"
    [ $# -gt 0 ] && printf "$translated" "$@" || printf '%s' "$translated"
}

# _t: 只翻译不格式化，返回翻译后的模板字符串
# 用于把翻译结果存入变量再格式化
_t() { translate "$1"; }

_dbg_init() {
    _dbg_export() {
        local raw="$1"
        local key; key=$(printf '%s' "$raw" | tr -cd 'a-zA-Z0-9' | cut -c1-40)
        local val; val=$(translate "$raw")
        export "_DT_${key}=${val}"
    }
    _dbg_export "__handle_hello invoked"
    _dbg_export "__handle_hello: empty or timeout"
    _dbg_export "__handle_hello: unknown cmd"
    _dbg_export "__handle_hello: missing fields"
    _dbg_export "__handle_hello: invalid MAC format"
    _dbg_export "__handle_hello: valid HELLO"
    _dbg_export "__handle_hello: updated approved node"
    _dbg_export "__handle_hello: wrote pending"
    _dbg_export "__handle_hello: br-lan has no IP"
    _dbg_export "__handle_hello: br-lan no IP, trying route"
    _dbg_export "__handle_hello: ERROR cannot determine IP"
    _dbg_export "__handle_hello: sending WELCOME"
    _dbg_export "__handle_hello: WELCOME sent"
}

_dbg() {
    local tpl="$1"; shift
    local ts msg translated
    ts=$(date "+%Y-%m-%d %H:%M:%S")
    # 查预翻译表
    local key; key=$(printf '%s' "$tpl" | tr -cd 'a-zA-Z0-9' | cut -c1-40)
    local varname="_DT_${key}"
    eval "translated=\${${varname}:-}"
    [ -z "$translated" ] && translated="$tpl"
    msg=$(printf "$translated" "$@" 2>/dev/null || printf '%s' "$translated $*")
    printf "%s [DEBUG] [dbg     ] %s\n" "$ts" "$msg" >> "${LOGFILE:-/tmp/easymesh.log}"
}

_emlog() {
    local level="$1" tag="$2"; shift 2
    local ts; ts=$(date "+%Y-%m-%d %H:%M:%S")
    (
        flock 200
        printf "%s [%-5s] [%-8s] %s\n" "$ts" "$level" "$tag" "$*" >> "$LOGFILE"
        _log_seq=$(( _log_seq + 1 ))
        if [ $(( _log_seq % 50 )) -eq 0 ]; then
            local lc; lc=$(wc -l < "$LOGFILE" 2>/dev/null || echo 0)
            if [ "$lc" -gt "$LOG_MAX_LINES" ]; then
                local keep=$(( LOG_MAX_LINES * 4 / 5 ))
                tail -n "$keep" "$LOGFILE" > "${LOGFILE}.tmp" && mv "${LOGFILE}.tmp" "$LOGFILE"
            fi
        fi
    ) 200>>"${LOGFILE}.lock"
}

log()  { _emlog "INFO"  "core"  "$(translate "$@")"; }
logr() { _emlog "INFO"  "roam"  "$(translate "$@")"; }
logd() { _emlog "INFO"  "dfs"   "$(translate "$@")"; }
logh() { _emlog "INFO"  "heal"  "$(translate "$@")"; }
logw() { _emlog "WARN"  "core"  "$(translate "$@")"; }
loge() { _emlog "ERROR" "core"  "$(translate "$@")"; }

# -- Basic helpers --
get_mac()  { cat /sys/class/net/${BRIDGE_IF}/address 2>/dev/null || cat /sys/class/net/${ETH_IF}/address 2>/dev/null; }
get_ip()   { ip -4 addr show dev "$BRIDGE_IF" 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1 | head -1; }
get_role() { cat "$ROLE_FILE" 2>/dev/null || echo "agent"; }
master_ip(){ cat "$MASTER_IP_FILE" 2>/dev/null; }
wan_up()   { ubus call network.interface.wan status 2>/dev/null | grep -q '"up": true'; }
get_ap_iface() {
    uci_get wireless easymesh_ap ifname $(uci_get wireless @wifi-iface[0] ifname "$AP_IF")
}

roam_cooldown_key() { echo "$1" | tr ':' '_'; }
roam_cooldown_get() { cat "${ROAM_COOLDOWN_DIR}/${1}" 2>/dev/null || echo 0; }
roam_cooldown_set() { mkdir -p "$ROAM_COOLDOWN_DIR"; printf '%s\n' "$2" > "${ROAM_COOLDOWN_DIR}/${1}"; }

# -- HTTP helpers --
do_http_post() {
    local url="$1" data="$2"
    local retry=0 wait_time resp
    while [ "$retry" -lt "$HTTP_MAX_RETRIES" ]; do
        if command -v curl >/dev/null 2>&1; then
            resp=$(curl -s -m "$HTTP_TIMEOUT" \
                -H "Content-Type: application/json" \
                -d "$data" "$url" 2>/dev/null)
        else
            local tmp; tmp="/tmp/em_http_$$.json"
            resp=$(wget -q -T "$HTTP_TIMEOUT" \
                --post-data="$data" \
                --header='Content-Type: application/json' \
                -O "$tmp" "$url" 2>/dev/null && cat "$tmp" 2>/dev/null)
            rm -f "$tmp"
        fi
        if [ -n "$resp" ]; then echo "$resp"; return 0; fi
        retry=$(( retry + 1 ))
        [ "$retry" -ge "$HTTP_MAX_RETRIES" ] && break
        wait_time=$(( retry < 3 ? retry * 2 : 8 ))
        logw "HTTP POST retry %s/%s in %ss: %s" "$retry" "$HTTP_MAX_RETRIES" "$wait_time" "$url"
        sleep "$wait_time"
    done
    loge "HTTP POST failed after %s retries: %s" "$HTTP_MAX_RETRIES" "$url"
    return 1
}

########################################
# 1. PROCESS MANAGEMENT
########################################
_stop_jobs() {
    [ -d "$EM_PID_DIR" ] || return 0
    local _f _pid
    for _f in "$EM_PID_DIR"/*.pid; do
        [ -f "$_f" ] || continue
        _pid=$(cat "$_f" 2>/dev/null)
        if [ -n "$_pid" ]; then
            kill "$_pid" 2>/dev/null || true
            local _i=0
            while [ $_i -lt 3 ] && kill -0 "$_pid" 2>/dev/null; do
                sleep 1; _i=$(( _i + 1 ))
            done
            kill -9 "$_pid" 2>/dev/null || true
        fi
    done

    local _p _pid _cmd
    for _p in /proc/[0-9]*/cmdline; do
        [ -f "$_p" ] || continue
        _pid="${_p%/cmdline}"
        _pid="${_pid##*/}"
        _cmd=$(tr "\0" " " < "$_p" 2>/dev/null)

        case "$_cmd" in
            *socat*":${MASTER_PORT}"*|*socat*":${DISC_PORT}"*|*socat*":${DISC_REPLY_PORT}"*|*uhttpd*":${MASTER_PORT}"*)
                kill "$_pid" 2>/dev/null || true
                ;;
        esac
    done
}

_bg() {
    local _name="$1"; shift
    mkdir -p "$EM_PID_DIR"
    "$@" &
    echo $! > "${EM_PID_DIR}/${_name}.pid"
}

########################################
# 2. ROLE ELECTION
########################################
elect_role() {
    local cfg_role
    cfg_role=$(uci_get easymesh global role)
    if [ -n "$cfg_role" ]; then
        echo "$cfg_role" > "$ROLE_FILE"
        if [ "$cfg_role" = "master" ]; then
            local _myip; _myip=$(get_ip)
            [ -n "$_myip" ] && echo "$_myip" > "$MASTER_IP_FILE"
        fi
        return 0
    fi
    local mymac myip
    mymac=$(get_mac); myip=$(get_ip)

    if wan_up; then
        echo "master" > "$ROLE_FILE"
        echo "$myip"  > "$MASTER_IP_FILE"
        log "Election: WAN up -> master (%s)" "$mymac"
        return 0
    fi

    local best_mac="$mymac" best_ip="$myip"
    mkdir -p "$NODE_DB"
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue
        local peer_ip peer_mac
        peer_ip=$(jsonfilter  -i "$f" -e '@.ip'  2>/dev/null)
        peer_mac=$(jsonfilter -i "$f" -e '@.mac' 2>/dev/null)
        [ -z "$peer_ip" ] && continue
        local resp
        resp=$(curl -s -m 3 "http://${peer_ip}:${MASTER_PORT}/wan" 2>/dev/null)
        if echo "$resp" | grep -q '"wan":true'; then
            echo "agent"    > "$ROLE_FILE"
            echo "$peer_ip" > "$MASTER_IP_FILE"
            log "Election: peer %s has WAN -> agent" "$peer_ip"
            return 0
        fi

        if [ -n "$peer_mac" ]; then
            local peer_mac_hex best_mac_hex
            peer_mac_hex=$(echo "$peer_mac" | tr -d ':')
            best_mac_hex=$(echo "$best_mac" | tr -d ':')
            [ "$peer_mac_hex" -lt "$best_mac_hex" ] 2>/dev/null && {
                best_mac="$peer_mac"; best_ip="$peer_ip"
            }
        fi
    done

    if [ "$best_mac" = "$mymac" ]; then
        echo "master" > "$ROLE_FILE"
        echo "$myip"  > "$MASTER_IP_FILE"
        log "Election: lowest MAC -> master (%s)" "$mymac"
    else
        echo "agent"    > "$ROLE_FILE"
        echo "$best_ip" > "$MASTER_IP_FILE"
        log "Election: %s wins -> agent (master=%s)" "$best_mac" "$best_ip"
    fi
}

########################################
# 3. BATMAN-ADV TUNING
########################################
tune_batman() {
    batctl meshif "$MESH_IF" orig_interval "$BATMAN_OGM_INTERVAL" 2>/dev/null
    batctl meshif "$MESH_IF" hop_penalty   "$BATMAN_HOP_PENALTY"  2>/dev/null
    local _bmode; _bmode=$(uci_get easymesh global backhaul 'wired')
    local _role; _role=$(get_role)
    # 只在状态真正改变时才写日志（避免每 30s 刷屏）
    local _state_key="${_bmode}:${_role}"
    local _last; _last=$(cat /tmp/easymesh_batman_state 2>/dev/null)
    if [ "$_state_key" != "$_last" ]; then
        if [ "$_bmode" = "wired" ]; then
            echo 0 > /sys/class/net/bat0/mesh/bridge_loop_avoidance 2>/dev/null || true
            echo 0 > /sys/class/net/bat0/mesh/distributed_arp_table  2>/dev/null || true
            log "batman-adv: BLA=off DAT=off (wired mode)"
        fi
        if [ "$_role" = "master" ]; then
            batctl meshif "$MESH_IF" gw_mode server 2>/dev/null
            log "batman-adv: GW mode=server, OGM=%sms" "$BATMAN_OGM_INTERVAL"
        else
            batctl meshif "$MESH_IF" gw_mode "$BATMAN_GW_MODE" 2>/dev/null
            log "batman-adv: GW 模式=%s，OGM=%sms" "$BATMAN_GW_MODE" "$BATMAN_OGM_INTERVAL"
        fi
        printf '%s' "$_state_key" > /tmp/easymesh_batman_state
    else
        # 静默执行，不打日志
        [ "$_bmode" = "wired" ] && {
            echo 0 > /sys/class/net/bat0/mesh/bridge_loop_avoidance 2>/dev/null || true
            echo 0 > /sys/class/net/bat0/mesh/distributed_arp_table  2>/dev/null || true
        }
        [ "$_role" = "master" ] \
            && batctl meshif "$MESH_IF" gw_mode server 2>/dev/null \
            || batctl meshif "$MESH_IF" gw_mode "$BATMAN_GW_MODE" 2>/dev/null
    fi
}

########################################
# 4. BATMAN-ADV RUNTIME SETUP
########################################
setup_wired_backhaul() {
    local role; role=$(get_role)
    log "DBG backhaul: ETH_IF=%s DSA=%s MESH_IF=%s role=%s" \
        "$ETH_IF" "$(_is_dsa && echo yes || echo no)" "$MESH_IF" "$role"

    if ! ip link show "$MESH_IF" >/dev/null 2>&1; then
        modprobe batman-adv 2>/dev/null || true
        sleep 1
        ip link add name "$MESH_IF" type batadv 2>/dev/null || {
            loge "Failed to create bat0 interface"
            return 1
        }
        local _w=0
        while ! ip link show "$MESH_IF" >/dev/null 2>&1; do
            _w=$((_w+1)); [ $_w -ge 15 ] && {
                loge "bat0 not found after 15s - kmod-batman-adv missing?"
                return 1
            }
            sleep 1
        done
    fi
    ip link set "$MESH_IF" up 2>/dev/null
    # 等待 bat0 sysfs mesh 目录就绪（驱动初始化需要片刻）
    local _sw=0
    while [ ! -d "/sys/class/net/$MESH_IF/mesh" ] && [ $_sw -lt 10 ]; do
        sleep 1; _sw=$((_sw+1))
    done
    [ ! -d "/sys/class/net/$MESH_IF/mesh" ] &&         log "WARN: bat0/mesh sysfs not ready after 10s (batman-adv version issue?)"

    local backhaul; backhaul=$(uci_get easymesh global backhaul 'wired')
    log "DBG backhaul: mode=%s" "$backhaul"

    # -- 2. 有线 hardif --
    if [ "$backhaul" = "wired" ] || [ "$backhaul" = "auto" ]; then
        if _is_dsa; then
            log "DBG backhaul: DSA hw, skipping batman-adv hardif (LAN-LAN direct bridge)"
        else
            local bport; bport=$(uci_get easymesh global backhaul_port '')
            if [ -n "$bport" ] && ip link show "$bport" >/dev/null 2>&1; then
                if ! batctl meshif "$MESH_IF" if 2>/dev/null | grep -qw "$bport"; then
                    ip link set "$bport" nomaster 2>/dev/null || \
                        brctl delif "$BRIDGE_IF" "$bport" 2>/dev/null || true
                    ip link set "$bport" up 2>/dev/null
                    batctl meshif "$MESH_IF" interface add "$bport" 2>/dev/null \
                        && log "Wired backhaul: dedicated port %s -> bat0" "$bport" \
                        || loge "DBG backhaul: failed to add %s to bat0" "$bport"
                    ETH_IF="$bport"; export ETH_IF
                fi
            else
                log "DBG backhaul: non-DSA, no dedicated port, relying on br-lan L2"
            fi
        fi
    fi

    # -- 3. 无线 hardif（backhaul=wireless/auto 时）--
    if [ "$backhaul" != "wired" ]; then
        local _mw=0
        while ! ip link show mesh0 >/dev/null 2>&1 && [ $_mw -lt 10 ]; do
            sleep 1; _mw=$((_mw+1))
        done
        if ip link show mesh0 >/dev/null 2>&1; then
            if ! batctl meshif "$MESH_IF" if 2>/dev/null | grep -qw mesh0; then
                ip link set mesh0 up 2>/dev/null
                batctl meshif "$MESH_IF" interface add mesh0 2>/dev/null \
                    && log "Wireless backhaul: mesh0 -> bat0"
            fi
        else
            [ "$backhaul" = "wireless" ] && logw "mesh0 not found, wireless backhaul failed"
        fi
    fi

    # -- 4. bat0 加入 br-lan（仅无线回程需要）--
    local _backhaul_mode; _backhaul_mode=$(uci_get easymesh global backhaul 'wired')
    if [ "$_backhaul_mode" = "wired" ]; then
        # 有线回程：确保 bat0 不在 br-lan 里（防止 BLA 干扰）
        if ip link show "$MESH_IF" 2>/dev/null | grep -q "master br-lan"; then
            ip link set "$MESH_IF" nomaster 2>/dev/null \
                || brctl delif "$BRIDGE_IF" "$MESH_IF" 2>/dev/null || true
            log "Backhaul: bat0 removed from br-lan (wired mode, prevents BLA ARP drop)"
        else
            log "DBG backhaul: bat0 not in br-lan (correct for wired mode)"
        fi
        # 禁用 BLA 和 DAT，避免干扰 LAN 流量
        echo 0 > /sys/class/net/bat0/mesh/bridge_loop_avoidance 2>/dev/null || true
        echo 0 > /sys/class/net/bat0/mesh/distributed_arp_table 2>/dev/null || true
    else
        # 无线/自动回程：bat0 需要在 br-lan 里（通过 bat0 转发 mesh 流量）
        if ! ip link show "$MESH_IF" 2>/dev/null | grep -q "master br-lan"; then
            ip link set "$MESH_IF" master br-lan 2>/dev/null \
                || brctl addif "$BRIDGE_IF" "$MESH_IF" 2>/dev/null
            ip link show "$MESH_IF" 2>/dev/null | grep -q "master br-lan" \
                && log "Backhaul: bat0 joined br-lan (role=%s)" "$(get_role)" \
                || loge "DBG backhaul: FAILED to add bat0 to br-lan"
        else
            log "DBG backhaul: bat0 already in br-lan"
        fi
    fi

    # -- 5. 状态摘要 --
    log "DBG backhaul: bat0 hardifs=[%s]" \
        "$(batctl meshif bat0 if 2>/dev/null | tr '\n' ' ')"
    log "DBG backhaul: br-lan members=[%s]" \
        "$(ip link show 2>/dev/null | awk '/master br-lan/{print $2}' \
           | tr -d ':' | tr '\n' ' ')"
    log "DBG backhaul: br-lan IP=%s" \
        "$(ip -4 addr show br-lan 2>/dev/null | awk '/inet /{print $2}')"
    log "Backhaul ready (role=%s)" "$(get_role)"
}

# -- 停止时清理 batman-adv --
teardown_batman() {
    # 把 bat0 从 br-lan 摘出
    ip link set "$MESH_IF" nomaster 2>/dev/null \
        || brctl delif "$BRIDGE_IF" "$MESH_IF" 2>/dev/null || true

    # 清理 hardif
    if _is_dsa; then
        # DSA：eth0 从 bat0 摘出（eth0 不在 br-lan，不需要还回）
        batctl meshif "$MESH_IF" interface del "$ETH_IF" 2>/dev/null || true
    else
        # 非 DSA 专用回程口：摘出 bat0，还回 br-lan
        local bport; bport=$(uci_get easymesh global backhaul_port '')
        if [ -n "$bport" ]; then
            batctl meshif "$MESH_IF" interface del "$bport" 2>/dev/null || true
            ip link set "$bport" up 2>/dev/null
            ip link set "$bport" master br-lan 2>/dev/null \
                || brctl addif "$BRIDGE_IF" "$bport" 2>/dev/null || true
        fi
    fi

    local backhaul; backhaul=$(uci_get easymesh global backhaul 'wired')
    [ "$backhaul" != "wired" ] \
        && batctl meshif "$MESH_IF" interface del mesh0 2>/dev/null || true
    ip link set "$MESH_IF" down 2>/dev/null || true
    log "batman-adv torn down"
}

########################################
# 5. UDP BROADCAST DISCOVERY
########################################
DISC_HELLO_INTERVAL=5
DISC_TIMEOUT=60

discovery_server() {
    log "Discovery server listening on UDP %s" "$DISC_PORT"
    local _spid=$!
    echo $_spid > "${EM_PID_DIR}/disc_server.pid"
    log "DBG disc_server: socat pid=%s listening UDP %s" "$_spid" "$DISC_PORT"
    # FIX1: 用绝对路径替代 $0，避免 agent 以 easymesh-agent 启动时 $0 指向错误
    socat UDP4-RECVFROM:${DISC_PORT},fork,reuseaddr \
        EXEC:"/usr/sbin/easymesh-master __handle_hello" 2>/dev/null &
}

__handle_hello() {
    # -- 防御性变量补全 --
    [ -z "$NODE_DB"         ] && NODE_DB="/tmp/easymesh_nodes"
    [ -z "$PENDING_DB"      ] && PENDING_DB="/tmp/easymesh_pending"
    [ -z "$LOGFILE"         ] && LOGFILE="/tmp/easymesh.log"
    [ -z "$MASTER_PORT"     ] && MASTER_PORT=4304
    [ -z "$DISC_REPLY_PORT" ] && DISC_REPLY_PORT=4306
    [ -z "$BRIDGE_IF"       ] && BRIDGE_IF="br-lan"

    _dbg "__handle_hello invoked pid=$$"

    # -- 读取 UDP 包内容（加超时防止永久挂起）--
    local msg
    IFS= read -r -t 5 msg 2>/dev/null
    if [ -z "$msg" ]; then
        _dbg "__handle_hello: empty or timeout reading stdin"
        return 0
    fi
    _dbg "__handle_hello: raw msg=[$msg]"

    # -- 解析字段 --
    local cmd mac agent_ip host
    cmd=$(      printf '%s' "$msg" | awk '{print $1}')
    mac=$(      printf '%s' "$msg" | awk '{print $2}')
    agent_ip=$( printf '%s' "$msg" | awk '{print $3}')
    host=$(     printf '%s' "$msg" | awk '{print $4}')

    # -- 验证命令字 --
    if [ "$cmd" != "EASYMESH_HELLO" ]; then
        _dbg "__handle_hello: unknown cmd=[$cmd] ignoring"
        return 0
    fi

    if [ -z "$mac" ] || [ -z "$agent_ip" ]; then
        _dbg "__handle_hello: missing fields mac=[$mac] agent_ip=[$agent_ip]"
        return 0
    fi

    # FIX3: 原正则只匹配小写，加 -i 兼容大写 MAC（理论上 Linux 都小写，但更健壮）
    if ! echo "$mac" | grep -qiE '^([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}$'; then
        _dbg "__handle_hello: invalid MAC format=[$mac]"
        return 0
    fi
    # 统一转小写，保证文件名一致
    mac=$(echo "$mac" | tr 'A-F' 'a-f')

    _dbg "__handle_hello: valid HELLO mac=%s agent_ip=%s host=%s" "$mac" "$agent_ip" "${host:-unknown}"

    # -- 写入 pending 或更新已批准节点 --
    local safe; safe=$(echo "$mac" | tr ':' '_')
    local approved_file="${NODE_DB}/${safe}.json"
    local pending_file="${PENDING_DB}/${safe}.json"
    mkdir -p "$NODE_DB" "$PENDING_DB"

    if [ -f "$approved_file" ]; then
        sed -i "s/\"ip\":\"[^\"]*\"/\"ip\":\"$agent_ip\"/" "$approved_file"
        sed -i "s/\"ts\":[0-9]*/\"ts\":$(date +%s)/" "$approved_file"
        _dbg "__handle_hello: updated approved node %s" "$mac"
    else
        printf '{"mac":"%s","ip":"%s","hostname":"%s","source":"wired","status":"pending","ts":%s}\n' \
            "$mac" "$agent_ip" "${host:-unknown}" "$(date +%s)" > "$pending_file"
        printf "%s [INFO ] [core    ] Pending node: %s (%s) via wired discovery\n" \
            "$(date '+%Y-%m-%d %H:%M:%S')" "$mac" "${host:-unknown}" >> "$LOGFILE"
        _dbg "__handle_hello: wrote pending %s" "$pending_file"
    fi

    # -- 获取本机 IP（master 的 br-lan IP）--
    local myip retry_ip=0
    myip=$(ip -4 addr show dev "${BRIDGE_IF}" 2>/dev/null \
        | awk '/inet /{print $2}' | cut -d/ -f1 | head -1)

    while [ -z "$myip" ] && [ $retry_ip -lt 3 ]; do
        _dbg "__handle_hello: br-lan has no IP yet, waiting (retry $retry_ip/3)..."
        sleep 1
        myip=$(ip -4 addr show dev "${BRIDGE_IF}" 2>/dev/null \
            | awk '/inet /{print $2}' | cut -d/ -f1 | head -1)
        retry_ip=$((retry_ip+1))
    done

    # 尝试用路由表获取 src IP
    if [ -z "$myip" ]; then
        _dbg "__handle_hello: br-lan has no IP, trying route src to %s" "$agent_ip"
        myip=$(ip -4 route get "$agent_ip" 2>/dev/null \
            | awk '/src/{for(i=1;i<=NF;i++) if($i=="src") print $(i+1); exit}')
    fi

    if [ -z "$myip" ]; then
        _dbg "__handle_hello: ERROR cannot determine local IP after retry, giving up"
        return 0
    fi
    _dbg "__handle_hello: myip=%s sending WELCOME to %s:%s" "$myip" "$agent_ip" "$DISC_REPLY_PORT"

    # -- 发送 WELCOME 单播回复 --
    printf 'EASYMESH_WELCOME %s\n' "$myip" | \
        socat - "UDP-DATAGRAM:${agent_ip}:${DISC_REPLY_PORT}" 2>/dev/null
    local _ret=$?
    _dbg "__handle_hello: WELCOME sent ret=%s" "$_ret"
}

_http_ok()  {
    printf "HTTP/1.0 200 OK\r\nContent-Type: application/json\r\nAccess-Control-Allow-Origin: *\r\nConnection: close\r\n\r\n%s" "$1"
}
_http_html(){
    printf "HTTP/1.0 200 OK\r\nContent-Type: text/html; charset=utf-8\r\nAccess-Control-Allow-Origin: *\r\nConnection: close\r\n\r\n"
    cat "$1"
}
_http_403() {
    printf 'HTTP/1.0 403 Forbidden\r\nContent-Type: application/json\r\nConnection: close\r\n\r\n{"status":"pending"}\n'
}
_http_404() {
    printf 'HTTP/1.0 404 Not Found\r\nContent-Type: application/json\r\nConnection: close\r\n\r\n{"error":"not found"}\n'
}

__http_handler() {
    # socat 模式：环境变量由 __socat_http 设置
    # REQUEST_METHOD, PATH_INFO, QUERY_STRING, CONTENT_LENGTH, stdin=body
    local method path query body content_length

    method="${REQUEST_METHOD:-GET}"
    path="${PATH_INFO:-/}"
    [ -z "$path" ] && path="/"
    query="${QUERY_STRING:-}"
    content_length="${CONTENT_LENGTH:-0}"

    [ "$content_length" -gt 0 ] 2>/dev/null && body=$(dd bs=1 count="$content_length" 2>/dev/null)

    [ "$method" = "OPTIONS" ] && { _http_ok "{}"; return; }

    case "$path" in
        /|/index.html)
            local _html="/www/easymesh-pair/index.html"
            if [ -f "$_html" ]; then _http_html "$_html"
            else _http_ok '{"error":"index.html not found"}'; fi
            ;;
        /favicon.ico) _http_404 ;;
        /ping)
            _http_ok "$(printf '{"role":"%s","mac":"%s","ip":"%s"}' \
                "$(get_role)" "$(get_mac)" "$(get_ip)")"
            ;;
        /wan)
            wan_up && _http_ok '{"wan":true}' || _http_ok '{"wan":false}'
            ;;
        /register)
            local src; src=$(echo "$body" | grep -o '"source":"[^"]*"' | cut -d'"' -f4)
            register_node "$body" "${src:-wired}"
            _http_ok '{"status":"ok","msg":"registered"}'
            ;;
        /profile/checksum)
            local req_mac safe
            req_mac=$(echo "$query" | grep -o 'mac=[^&]*' | cut -d= -f2)
            safe=$(echo "$req_mac" | tr ':' '_' | tr 'A-F' 'a-f')
            if [ -f "${PENDING_DB}/${safe}.json" ]; then
                _http_ok '{"status":"pending"}'
            elif [ -f "${NODE_DB}/${safe}.json" ] && [ -f "$PROFILE_FILE" ]; then
                local sum; sum=$(md5sum "$PROFILE_FILE" | cut -d' ' -f1)
                _http_ok "{\"sum\":\"$sum\"}"
            else
                _http_ok '{"status":"unregistered"}'
            fi
            ;;
        /profile/push)
            # master 主动推送 profile 给 agent（由 USR1 信号触发）
            [ "$method" != "POST" ] && { _http_ok '{"status":"ignored"}'; return; }
            local push_ssid
            push_ssid=$(echo "$body" | grep -o '"ssid":"[^"]*"' | cut -d'"' -f4)
            if [ -n "$push_ssid" ]; then
                apply_profile "$body"
                _http_ok '{"status":"ok","msg":"profile applied"}'
                log "Profile received via push from master"
            else
                _http_ok '{"status":"error","msg":"invalid profile"}'
            fi
            ;;
        /profile)
            local req_mac safe
            req_mac=$(echo "$query" | grep -o 'mac=[^&]*' | cut -d= -f2)
            safe=$(echo "$req_mac" | tr ':' '_' | tr 'A-F' 'a-f')
            if [ -f "${PENDING_DB}/${safe}.json" ]; then
                _http_ok '{"status":"pending"}'
            elif [ -f "${NODE_DB}/${safe}.json" ] && [ -f "$PROFILE_FILE" ]; then
                _http_ok "$(cat "$PROFILE_FILE")"
            else
                _http_ok '{"status":"unregistered"}'
            fi
            ;;
        /nodes/approve)
            local req_mac safe
            req_mac=$(echo "$query" | grep -o 'mac=[^&]*' | cut -d= -f2)
            [ -z "$req_mac" ] && req_mac=$(echo "$body" | grep -o '"mac":"[^"]*"' | cut -d'"' -f4)
            # 统一转小写，与 register_node 保持一致
            req_mac=$(echo "$req_mac" | tr 'A-F' 'a-f')
            safe=$(echo "$req_mac" | tr ':' '_')
            local pf="${PENDING_DB}/${safe}.json"
            local af="${NODE_DB}/${safe}.json"
            if [ -f "$pf" ]; then
                sed 's/"status":"pending"/"status":"approved"/' "$pf" > "$af"
                rm -f "$pf"
                _http_ok '{"status":"ok","msg":"approved"}'
                log "Node approved: %s" "$req_mac"
            elif [ -f "$af" ]; then
                _http_ok '{"status":"ok","msg":"already approved"}'
            else
                _http_ok '{"status":"error","msg":"node not found"}'
            fi
            ;;
        /nodes/list)
            local out="[" first=1
            for f in "$PENDING_DB"/*.json "$NODE_DB"/*.json; do
                [ -f "$f" ] || continue
                [ "$first" = "1" ] && first=0 || out="${out},"
                out="${out}$(cat "$f")"
            done
            _http_ok "${out}]"
            ;;
        /channel/apply)
            local new_chan reason
            new_chan=$(echo "$body" | grep -o '"channel":"[^"]*"' | cut -d'"' -f4)
            reason=$(echo "$body"  | grep -o '"reason":"[^"]*"'  | cut -d'"' -f4)
            [ -z "$new_chan" ] && { _http_ok '{"status":"ignored"}'; return; }
            log "Channel sync from master: ch=%s reason=%s" "$new_chan" "${reason:-unknown}"
            local rd; rd=$(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{print $1}' | head -1)
            uci set "${rd}.channel=${new_chan}"; uci_commit wireless
            wifi reload &
            _http_ok "{\"status\":\"ok\",\"channel\":\"$new_chan\"}"
            ;;
        /roam/signal)
            local sta_mac; sta_mac=$(echo "$query" | grep -o 'mac=[^&]*' | cut -d= -f2)
            local ap_iface; ap_iface=$(get_ap_iface)
            local bssid; bssid=$(cat /sys/class/net/${ap_iface}/address 2>/dev/null)
            local sig; sig=$(iw dev "$ap_iface" station get "$sta_mac" 2>/dev/null \
                | awk '/signal:/{print $2}' | head -1)
            if [ -n "$sig" ]; then _http_ok "{\"rssi\":$sig,\"bssid\":\"$bssid\"}"
            else _http_ok '{"rssi":null}'; fi
            ;;
        /roam/neighbors)
            apply_neighbor_list "$body"
            _http_ok '{"status":"ok"}'
            ;;
        *)
            _http_404
            ;;
    esac
}

__socat_http() {
    # -- 读取请求行 --
    local req_line
    IFS= read -r req_line
    # 去掉 \r
    req_line="${req_line%$'\r'}"
    [ -z "$req_line" ] && return

    # 解析 METHOD URL HTTP/x.x
    local method full_url _ver
    method=$(echo "$req_line" | awk '{print $1}')
    full_url=$(echo "$req_line" | awk '{print $2}')

    # 分离 path 和 query
    local path_part query_part
    path_part="${full_url%%\?*}"
    if echo "$full_url" | grep -q '?'; then
        query_part="${full_url#*\?}"
    else
        query_part=""
    fi

    # -- 读取并丢弃所有 headers，找 Content-Length --
    local content_length=0
    while IFS= read -r header; do
        header="${header%$'\r'}"
        [ -z "$header" ] && break   # 空行 = headers 结束
        case "$(echo "$header" | tr 'A-Z' 'a-z')" in
            content-length:*)
                content_length=$(echo "$header" | awk -F': ' '{print $2}' | tr -d '\r\n ')
                ;;
        esac
    done

    # -- 设置 CGI 环境变量，调用 handler --
    export REQUEST_METHOD="$method"
    export PATH_INFO="$path_part"
    export QUERY_STRING="$query_part"
    export CONTENT_LENGTH="$content_length"

    __http_handler
}

run_node_server() {
    log "HTTP server starting on port %s (socat+TCP)" "$MASTER_PORT"

    # 杀掉旧的同端口进程
    pkill -f "socat.*TCP.*${MASTER_PORT}" 2>/dev/null || true
    pkill -f "uhttpd.*${MASTER_PORT}" 2>/dev/null || true
    sleep 1

    # socat TCP listener：每个连接 fork，调用本脚本的 __socat_http 入口
    socat TCP4-LISTEN:${MASTER_PORT},fork,reuseaddr \
        EXEC:"/usr/sbin/easymesh-master __socat_http" \
        2>>"$LOGFILE" &

    sleep 1

    # 验证监听
    local ok=0
    if command -v ss >/dev/null 2>&1; then
        ss -tlnp 2>/dev/null | grep -q ":${MASTER_PORT}" && ok=1
    elif command -v netstat >/dev/null 2>&1; then
        netstat -tlnp 2>/dev/null | grep -q ":${MASTER_PORT}" && ok=1
    fi

    if [ "$ok" = "1" ]; then
        log "✓ HTTP server successfully listening on port ${MASTER_PORT}"
    else
        loge "✗ socat HTTP server failed to start on port ${MASTER_PORT}"
    fi
}
_diagnose_http_connection() {
    local target_ip="$1"
    local port="${2:-4304}"

    log "=== HTTP CONNECTION DIAGNOSTIC ==="
    log "DBG httpdiag: target=$target_ip:$port"

    # -- 1. 检查目标是否可达 --
    log "DBG httpdiag: step 1 - checking if $target_ip is reachable..."
    if ping -c 1 -W 2 -q "$target_ip" >/dev/null 2>&1; then
        log "✓ httpdiag: ping $target_ip OK"
    else
        log "✗ httpdiag: ping $target_ip FAILED"
        return 1
    fi

    # -- 2. 检查端口：直接用 curl 请求 /ping（比 nc 更准确）--
    log "DBG httpdiag: step 2 - checking if port $port is open..."
    local port_check_resp
    port_check_resp=$(curl -s -m 3 "http://${target_ip}:${port}/ping" 2>/dev/null)
    if echo "$port_check_resp" | grep -q '"role"'; then
        log "✓ httpdiag: port $port on $target_ip is OPEN (got ping response)"
    else
        log "✗ httpdiag: port $port on $target_ip is CLOSED or FILTERED"
        return 1
    fi

    # -- 3. 尝试发送 HTTP 请求，详细输出 --
    log "DBG httpdiag: step 3 - sending HTTP GET request..."
    local response
    response=$(curl -s -m 3 "http://${target_ip}:${port}/ping" 2>&1)
    local curl_ret=$?

    if [ $curl_ret -eq 0 ]; then
        log "✓ httpdiag: HTTP request OK"
        log "  response: $response"
        return 0
    else
        log "✗ httpdiag: HTTP request FAILED (curl exit: $curl_ret)"
        log "  response: $response"

        return 1
    fi
}

# 改进的网络诊断
_diagnose_network_improved() {
    local myip; myip=$(get_ip)
    local prefix; prefix=$(echo "$myip" | cut -d. -f1-3)
    local role; role=$(uci_get easymesh global role 'master')

    log "=== NETWORK DIAGNOSIS START (role=$role, my_ip=$myip) ==="

    # -- 1. 检查 br-lan 状态 --
    log "DBG netdiag: checking br-lan interface..."
    local br_status; br_status=$(ip link show br-lan 2>/dev/null)
    if [ -n "$br_status" ]; then
        log "✓ netdiag: br-lan exists"
        log "  status: $(echo "$br_status" | head -1)"
    else
        log "✗ netdiag: br-lan NOT found"
        return 1
    fi

    # -- 2. 检查 br-lan IP --
    log "DBG netdiag: checking br-lan IP..."
    local br_ip; br_ip=$(ip -4 addr show dev br-lan 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1 | head -1)
    if [ -n "$br_ip" ]; then
        log "✓ netdiag: br-lan IP = $br_ip"
    else
        log "✗ netdiag: br-lan has NO IP"
        return 1
    fi

    # -- 3. 如果是 agent，诊断与主节点的连接 --
    if [ "$role" = "agent" ]; then
        local master_default="${prefix}.1"
        log "DBG netdiag: agent mode - testing connection to master $master_default..."
        _diagnose_http_connection "$master_default" 4304
    fi

    log "=== NETWORK DIAGNOSIS END ==="
}
########################################
# 7. NODE REGISTRATION
########################################
register_node() {
    local body="$1" source="$2"
    local mac ip hostname
    mac=$(      echo "$body" | grep -o '"mac":"[^"]*"'      | cut -d'"' -f4)
    ip=$(       echo "$body" | grep -o '"ip":"[^"]*"'       | cut -d'"' -f4)
    hostname=$( echo "$body" | grep -o '"hostname":"[^"]*"' | cut -d'"' -f4)

    [ -z "$mac" ] && { loge "register_node: missing mac in body=[%s]" "$body"; return 1; }
    [ -z "$ip"  ] && { loge "register_node: missing ip in body=[%s]"  "$body"; return 1; }

    mac=$(echo "$mac" | tr 'A-F' 'a-f')
    local safe; safe=$(echo "$mac" | tr ':' '_')
    mkdir -p "$NODE_DB" "$PENDING_DB"
    local approved_file="${NODE_DB}/${safe}.json"
    local pending_file="${PENDING_DB}/${safe}.json"

    if [ -f "$approved_file" ]; then
        sed -i "s/\"ip\":\"[^\"]*\"/\"ip\":\"${ip:-?}\"/" "$approved_file"
        sed -i "s/\"ts\":[0-9]*/\"ts\":$(date +%s)/" "$approved_file"
        log "Node re-registered (approved): %s (%s) ip=%s" "$mac" "${hostname:-?}" "$ip"
    else
        printf '{"mac":"%s","ip":"%s","hostname":"%s","source":"%s","status":"pending","ts":%s}\n' \
            "$mac" "${ip:-?}" "${hostname:-?}" "${source:-wired}" "$(date +%s)" \
            > "$pending_file"
        log "Pending node: %s (%s) ip=%s via %s" "$mac" "${hostname:-?}" "$ip" "$source"
    fi
}

########################################
# 8. AGENT: FIND MASTER & JOIN
########################################
# IP 冲突由 initd 在守护进程启动前处理，这里无需再处理

find_master() {
    local my_ip my_mac
    my_ip=$(get_ip)
    my_mac=$(cat /sys/class/net/${BRIDGE_IF}/address 2>/dev/null)
    log "DBG find_master: start my_ip=%s my_mac=%s" "$my_ip" "$my_mac"

    local backhaul; backhaul=$(uci_get easymesh global backhaul 'wired')
    local prefix; prefix=$(echo "$my_ip" | cut -d. -f1-3)

    # 无线回程等 batman-adv 邻居；有线直连跳过
    if [ "$backhaul" != "wired" ]; then
        local _bwait=0
        log "DBG find_master: waiting batman-adv (wireless)"
        while [ $_bwait -lt 40 ]; do
            local _nb
            _nb=$(batctl meshif bat0 neighbors 2>/dev/null \
                | grep -vcE "^B\.A\.T|^No |^$" 2>/dev/null || echo 0)
            [ "$_nb" -gt 0 ] && { log "batman neighbor after %ss" "$_bwait"; break; }
            sleep 2; _bwait=$((_bwait + 2))
        done
        [ $_bwait -ge 40 ] && logw "No batman neighbor in 40s, continuing"
    fi

    # -- 1. 缓存的 master IP --
    local cached; cached=$(master_ip)
    if [ -n "$cached" ] && [ "$cached" != "$my_ip" ]; then
        if curl -s -m 3 "http://${cached}:${MASTER_PORT}/ping" 2>/dev/null \
                | grep -q '"role":"master"'; then
            log "DBG find_master: cached master OK at %s" "$cached"
            return 0
        fi
        rm -f "$MASTER_IP_FILE"
    fi

    # -- 2. 有线直连：尝试 prefix.1（主路由器固定 IP）--
    # 不能用默认网关！agent 可能有无线上行（phy1-sta0），默认网关是上游路由器，不是 master
    local master_candidate="${prefix}.1"
    if [ "$master_candidate" != "$my_ip" ]; then
        log "DBG find_master: wired direct - trying %s" "$master_candidate"
        local _try=0
        while [ $_try -lt 3 ]; do
            if curl -s -m 3 "http://${master_candidate}:${MASTER_PORT}/ping" 2>/dev/null \
                    | grep -q '"role":"master"'; then
                echo "$master_candidate" > "$MASTER_IP_FILE"
                log "Master found at %s (wired direct)" "$master_candidate"
                return 0
            fi
            _try=$((_try+1))
            log "DBG find_master: attempt %s/3 to %s failed, waiting 3s..." "$_try" "$master_candidate"
            sleep 3
        done
        log "DBG find_master: wired direct .1 failed"
        # 诊断：是网络不通还是 uhttpd 有问题
        if ping -c 1 -W 2 -q "$master_candidate" >/dev/null 2>&1; then
            local _cr
            _cr=$(curl -s -m 3 "http://${master_candidate}:${MASTER_PORT}/ping" 2>&1)
            log "DBG find_master: ping OK, curl=[%s]" "$(echo "$_cr" | head -c 200)"
        else
            log "DBG find_master: ping %s FAILED - no L3 link (check cable/VLAN)" "$master_candidate"
        fi
    fi

    # -- 3. 快速扫描常见备用 IP --
    # .250 是 wireless onboard AP（easymesh-pair0）的固定网关 IP
    for s in 2 254 250 100 101; do
        local c="${prefix}.${s}"
        [ "$c" = "$my_ip" ] && continue
        if curl -s -m 2 "http://${c}:${MASTER_PORT}/ping" 2>/dev/null \
                | grep -q '"role":"master"'; then
            echo "$c" > "$MASTER_IP_FILE"
            log "Master found at %s (quick scan)" "$c"
            return 0
        fi
    done

    # -- 4. 全子网扫描（后台非阻塞，找到后写 MASTER_IP_FILE，main_loop 轮询时生效）--
    log "DBG find_master: launching background full scan %s.0/24" "$prefix"
    (
        local j c
        for j in $(seq 3 253); do
            c="${prefix}.${j}"
            [ "$c" = "$my_ip" ] && continue
            [ -f "$MASTER_IP_FILE" ] && break
            [ $(( j % 50 )) -eq 0 ] && printf "%s [INFO ] [core    ] DBG find_master: bg scan .%d\n" \
                "$(date '+%Y-%m-%d %H:%M:%S')" "$j" >> "$LOGFILE"
            if curl -s -m 1 "http://${c}:${MASTER_PORT}/ping" 2>/dev/null \
                    | grep -q '"role":"master"'; then
                echo "$c" > "$MASTER_IP_FILE"
                printf "%s [INFO ] [core    ] Master found at %s (bg scan)\n" \
                    "$(date '+%Y-%m-%d %H:%M:%S')" "$c" >> "$LOGFILE"
                break
            fi
        done
    ) &

    return 1
}


do_register() {
    local mip; mip=$(master_ip)
    [ -z "$mip" ] && { find_master || return 1; mip=$(master_ip); }
    [ -z "$mip" ] && return 1

    local mac ip hostname
    mac=$(get_mac)
    hostname=$(uci_get system @system[0] hostname node)

    # 判断注册来源：master IP 是 .250 说明是通过无线 onboard AP 发现的
    local reg_source="wired"
    echo "$mip" | grep -qE '\.250$' && reg_source="wireless"

    if [ "$reg_source" = "wireless" ]; then
        # 无线 onboard：br-lan 可能与 master IP 冲突（都是 .1）
        # 优先取 wlan 接口拿到的临时 IP（DHCP 来自 onboard AP）作为注册 IP
        local wlan_ip
        wlan_ip=$(ip -4 addr show 2>/dev/null             | awk '/inet /{ip=$2} /wlan/{print ip; exit}'             | cut -d/ -f1)
        # 若 wlan IP 在 master 同子网（onboard DHCP 范围 .200-.249），用它
        local mprefix; mprefix=$(echo "$mip" | cut -d. -f1-3)
        if echo "$wlan_ip" | grep -q "^${mprefix}\."; then
            ip="$wlan_ip"
            log "DBG do_register: onboard mode, using wlan IP=%s" "$ip"
        else
            ip=$(get_ip)
        fi
    else
        ip=$(get_ip)
    fi
    log "DBG do_register: to master=%s mac=%s ip=%s via=%s" "$mip" "$mac" "$ip" "$reg_source"
    local resp
    resp=$(do_http_post \
        "http://${mip}:${MASTER_PORT}/register" \
        "{\"mac\":\"$mac\",\"ip\":\"$ip\",\"hostname\":\"$hostname\",\"source\":\"$reg_source\"}") || {
        loge "Failed to register with master %s" "$mip"
        return 1
    }
    log "Registered with master %s via %s (resp=%s)" "$mip" "$reg_source" "$resp"
}

_last_profile_sum=""
poll_for_approval() {
    local mip; mip=$(master_ip)
    [ -z "$mip" ] && return 1

    local sum_resp remote_sum
    sum_resp=$(curl -s -m 3 \
        "http://${mip}:${MASTER_PORT}/profile/checksum?mac=$(get_mac)" 2>/dev/null)
    remote_sum=$(echo "$sum_resp" | grep -o '"sum":"[^"]*"' | cut -d'"' -f4)

    if [ -n "$remote_sum" ] && [ -n "$_last_profile_sum" ] \
            && [ "$remote_sum" = "$_last_profile_sum" ]; then
        return 0
    fi

    local resp
    resp=$(curl -s -m 5 "http://${mip}:${MASTER_PORT}/profile?mac=$(get_mac)" 2>/dev/null)
    log "DBG poll_approval: resp=[%s]" "${resp:0:120}"

    if echo "$resp" | grep -q '"status":"pending"'; then
        log "Waiting for master approval..."
        return 1
    fi
    if echo "$resp" | grep -q '"status":"unregistered"'; then
        logw "Master has no record, re-registering"
        rm -f "$MASTER_IP_FILE"
        do_register
        return 1
    fi
    if echo "$resp" | grep -q '"status":"approved"'; then
        apply_profile "$resp"
        _last_profile_sum=$(echo "$resp" | md5sum | cut -d' ' -f1)
        return 0
    fi
    return 1
}

########################################
# 9. PROFILE GENERATE & APPLY
########################################
generate_profile() {
    uci_load easymesh
    local ssid key mesh_id mesh_key routing_algo channel
    local ieee80211r ieee80211k ieee80211v ft_over_ds mobility_domain backhaul
    config_get ssid             global ssid              'OpenWrt'
    config_get key              global key               ''
    config_get mesh_id          global mesh_id           'OpenWrt-Mesh'
    config_get mesh_key         global mesh_key          ''
    config_get routing_algo     global routing_algo      'BATMAN_IV'
    config_get ieee80211r       global ieee80211r        '1'
    config_get ieee80211k       global ieee80211k        '1'
    config_get ieee80211v       global ieee80211v        '1'
    config_get ft_over_ds       global ft_over_ds        '1'
    config_get mobility_domain  global mobility_domain   'aabb'
    config_get backhaul         global backhaul          'wired'
    local radio_dev
    radio_dev=$(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{print $1}' | head -1)
    channel=$(uci get "${radio_dev}.channel" 2>/dev/null || echo 'auto')
    local new_profile
    new_profile=$(printf         '{"status":"approved","ssid":"%s","key":"%s","channel":"%s","mesh_id":"%s","mesh_key":"%s","routing_algo":"%s","ieee80211r":"%s","ieee80211k":"%s","ieee80211v":"%s","ft_over_ds":"%s","mobility_domain":"%s","backhaul":"%s"}'         "$ssid" "$key" "$channel" "$mesh_id" "$mesh_key" "$routing_algo"         "$ieee80211r" "$ieee80211k" "$ieee80211v" "$ft_over_ds" "$mobility_domain" "$backhaul")
    local old_profile; old_profile=$(cat "$PROFILE_FILE" 2>/dev/null | tr -d '
')
    if [ "$new_profile" != "$old_profile" ]; then
        printf '%s
' "$new_profile" > "$PROFILE_FILE"
        log "generate_profile: ssid=%s channel=%s backhaul=%s" "$ssid" "$channel" "$backhaul"
    fi
}

apply_profile() {
    local body="$1"
    local ssid key channel mesh_id mesh_key routing_algo
    local ieee80211r ieee80211k ieee80211v ft_over_ds mobility_domain backhaul
    local _pf="/tmp/em_profile_$$.json"
    printf '%s
' "$body" > "$_pf"
    ssid=$(           jsonfilter -i "$_pf" -e '@.ssid'            2>/dev/null)
    key=$(            jsonfilter -i "$_pf" -e '@.key'             2>/dev/null)
    channel=$(        jsonfilter -i "$_pf" -e '@.channel'         2>/dev/null)
    mesh_id=$(        jsonfilter -i "$_pf" -e '@.mesh_id'         2>/dev/null)
    mesh_key=$(       jsonfilter -i "$_pf" -e '@.mesh_key'        2>/dev/null)
    routing_algo=$(   jsonfilter -i "$_pf" -e '@.routing_algo'    2>/dev/null)
    ieee80211r=$(     jsonfilter -i "$_pf" -e '@.ieee80211r'      2>/dev/null)
    ieee80211k=$(     jsonfilter -i "$_pf" -e '@.ieee80211k'      2>/dev/null)
    ieee80211v=$(     jsonfilter -i "$_pf" -e '@.ieee80211v'      2>/dev/null)
    ft_over_ds=$(     jsonfilter -i "$_pf" -e '@.ft_over_ds'      2>/dev/null)
    mobility_domain=$(jsonfilter -i "$_pf" -e '@.mobility_domain' 2>/dev/null)
    backhaul=$(       jsonfilter -i "$_pf" -e '@.backhaul'        2>/dev/null)
    rm -f "$_pf"
    [ -z "$ssid" ] && { loge "apply_profile: missing ssid"; return 1; }
    log "Applying profile: ssid=%s channel=%s backhaul=%s" "$ssid" "$channel" "${backhaul:-wired}"
    # 写入 UCI easymesh —— agent 节点配置与 master 保持完全一致
    uci_set easymesh global enabled 1
    uci_set easymesh global role agent
    uci_set easymesh global mesh_id "${mesh_id:-OpenWrt-Mesh}"
    uci_set easymesh global mesh_key "${mesh_key}"
    uci_set easymesh global ssid "$ssid"
    uci_set easymesh global key "$key"
    uci_set easymesh global backhaul "${backhaul:-wired}"
    uci_set easymesh global routing_algo "${routing_algo:-BATMAN_IV}"
    [ -n "$ieee80211r" ]       && uci_set easymesh global ieee80211r       "$ieee80211r"
    [ -n "$ieee80211k" ]       && uci_set easymesh global ieee80211k       "$ieee80211k"
    [ -n "$ieee80211v" ]       && uci_set easymesh global ieee80211v       "$ieee80211v"
    [ -n "$ft_over_ds" ]       && uci_set easymesh global ft_over_ds       "$ft_over_ds"
    [ -n "$mobility_domain" ]  && uci_set easymesh global mobility_domain  "$mobility_domain"
    uci_commit easymesh
    # 更新 mesh0（802.11s 回程接口）—— 根据 backhaul 决定启用/禁用
    # backhaul=wired  → mesh0 禁用（disabled=1），节省 5G 空口
    # backhaul=wireless/auto → mesh0 启用，同步 mesh_id/mesh_key
    if uci show wireless.mesh0 >/dev/null 2>&1; then
        if [ "${backhaul:-wired}" = "wired" ]; then
            uci_set wireless mesh0 disabled 1
            log "apply_profile: mesh0 disabled (wired backhaul)"
        else
            uci_set wireless mesh0 disabled 0
            [ -n "$mesh_id" ]  && uci_set wireless mesh0 mesh_id  "$mesh_id"
            if [ -n "$mesh_key" ]; then
                uci_set wireless mesh0 encryption sae
                uci_set wireless mesh0 key "$mesh_key"
            else
                uci_set wireless mesh0 encryption none
                uci -q del wireless.mesh0.key
            fi
            log "apply_profile: mesh0 enabled, mesh_id=%s" "${mesh_id:-OpenWrt-Mesh}"
        fi
        uci_commit wireless
    fi
    # 更新无线 AP 接口配置
    # 更新所有 easymesh 管理的 AP（双频同名 AP，统一推送 ssid/key/roaming 参数）
    local _upd_ap
    for _upd_ap in easymesh_ap easymesh_ap_2g; do
        uci show wireless."${_upd_ap}" >/dev/null 2>&1 || continue
        uci_set wireless ${_upd_ap} ssid "$ssid"
        [ -n "$key" ] && {
            uci_set wireless ${_upd_ap} encryption 'psk2+ccmp'
            uci_set wireless ${_upd_ap} key "$key"
        }
        [ "${ieee80211k:-1}" = "1" ] && {
            uci_set wireless ${_upd_ap} ieee80211k 1
            uci_set wireless ${_upd_ap} rrm_neighbor_report 1
            uci_set wireless ${_upd_ap} rrm_beacon_report 1
        }
        [ "${ieee80211v:-1}" = "1" ] && {
            uci_set wireless ${_upd_ap} ieee80211v 1
            uci_set wireless ${_upd_ap} bss_transition 1
        }
        [ "${ieee80211r:-1}" = "1" ] && {
            uci_set wireless ${_upd_ap} ieee80211r 1
            uci_set wireless ${_upd_ap} ft_psk_generate_local 1
            [ -n "$mobility_domain" ] && uci_set wireless ${_upd_ap} mobility_domain "$mobility_domain"
            [ -n "$ft_over_ds" ]      && uci_set wireless ${_upd_ap} ft_over_ds "$ft_over_ds"
        }
    done
    [ -n "$channel" ] && [ "$channel" != "auto" ] && {
        local rd; rd=$(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{print $1}' | head -1)
        [ -n "$rd" ] && uci set "${rd}.channel=$channel"
    }
    uci_commit wireless
    setup_wired_backhaul
    wifi reload
    log "Profile applied. Agent now mirrors master config (dual-band AP)."
}

########################################
# 10. WATCHDOGS
########################################
gateway_watchdog() {
    local fail=0
    log "Gateway watchdog started"
    while true; do
        sleep "$GW_WATCHDOG_INTERVAL"
        local mip; mip=$(master_ip)
        [ -z "$mip" ] && continue
        if curl -s -m 4 -o /dev/null "http://${mip}:${MASTER_PORT}/ping" 2>/dev/null; then
            fail=0
        else
            fail=$(( fail + 1 ))
            logw "Gateway: master %s unreachable (fail=%s/3)" "$mip" "$fail"
            if [ "$fail" -ge 3 ]; then
                loge "Gateway declared dead - re-electing"
                rm -f "$MASTER_IP_FILE"
                elect_role; tune_batman; fail=0
            fi
        fi
    done
}

prev_gw=""
check_routing_paths() {
    local cur_gw
    cur_gw=$(batctl meshif "$MESH_IF" gwl 2>/dev/null | awk '/===>/{print $2}' | head -1)
    if [ -n "$cur_gw" ] && [ "$cur_gw" != "$prev_gw" ]; then
        log "Self-healing: gateway path changed -> %s (was: %s)" "$cur_gw" "${prev_gw:-none}"
        prev_gw="$cur_gw"
        sync_neighbor_list
    fi
}

########################################
# 11. SEAMLESS ROAMING
########################################
sync_neighbor_list() {
    local ap_iface ssid
    ap_iface=$(get_ap_iface)
    ssid=$(uci_get wireless easymesh_ap ssid || uci_get wireless @wifi-iface[0] ssid)
    [ -z "$ssid" ] && return
    local my_bssid; my_bssid=$(cat /sys/class/net/${ap_iface}/address 2>/dev/null)
    > "$NEIGHBOR_FILE"
    iw dev "$AP_IF" scan 2>/dev/null | awk -v ssid="$ssid" '
        /^BSS /  { bssid=$2 }
        /freq:/  { freq=$2 }
        /DS Parameter set/ { chan=$NF }
        /SSID: / {
            if ($2 == ssid && bssid != "") {
                op = (freq+0 > 4000) ? 115 : 81
                print bssid, op, chan
            }
        }' | while read -r bssid op chan; do
        [ "$bssid" = "$my_bssid" ] && continue
        hostapd_cli -i "$ap_iface" set_neighbor "$bssid" \
            ssid="\"$ssid\"" nr="$(echo "$bssid" | tr -d ':')${op}${chan}0000" 2>/dev/null && \
        echo "$bssid $op $chan" >> "$NEIGHBOR_FILE"
    done
    if [ "$(get_role)" = "master" ]; then
        local nb_json
        nb_json=$(awk '{printf "{\"bssid\":\"%s\",\"op\":%s,\"chan\":%s},", $1,$2,$3}' \
            "$NEIGHBOR_FILE" | sed 's/,$//')
        local payload="{\"ssid\":\"$ssid\",\"neighbors\":[$nb_json],\"my_bssid\":\"$my_bssid\"}"
        # 只在 payload 变化时才推送，避免每 10s 对离线 agent 产生大量 ERROR
        local _nb_hash; _nb_hash=$(printf '%s' "$payload" | md5sum | cut -c1-8)
        local _nb_last; _nb_last=$(cat /tmp/easymesh_nb_hash 2>/dev/null)
        if [ "$_nb_hash" != "$_nb_last" ]; then
            printf '%s' "$_nb_hash" > /tmp/easymesh_nb_hash
            for f in "$NODE_DB"/*.json; do
                [ -f "$f" ] || continue
                local peer_ip; peer_ip=$(jsonfilter -i "$f" -e '@.ip' 2>/dev/null)
                [ -z "$peer_ip" ] && continue
                # 静默推送：不经 do_http_post，不产生重试日志
                ( curl -s -m 5 -X POST -H "Content-Type: application/json"                     -d "$payload" "http://${peer_ip}:${MASTER_PORT}/roam/neighbors"                     >/dev/null 2>&1 ) &
            done
        fi
    fi
}

apply_neighbor_list() {
    local body="$1" ap_iface ssid
    ap_iface=$(get_ap_iface)
    ssid=$(echo "$body" | grep -o '"ssid":"[^"]*"' | cut -d'"' -f4)
    [ -z "$ssid" ] && return
    echo "$body" | grep -o '"bssid":"[^"]*"' | cut -d'"' -f4 | while read -r bssid; do
        [ -n "$bssid" ] && hostapd_cli -i "$ap_iface" \
            set_neighbor "$bssid" ssid="\"$ssid\"" >/dev/null 2>&1
    done
    local _nb_count; _nb_count=$(echo "$body" | grep -c '"bssid"')
    [ "$_nb_count" -gt 0 ] && logr "Neighbor list applied: %s APs" "$_nb_count"
}

roam_watchdog() {
    local ap_iface; ap_iface=$(get_ap_iface)
    log "Roam watchdog started on %s" "$ap_iface"
    while true; do
        sleep "$ROAM_PROBE_INTERVAL"
        [ -x "$(command -v hostapd_cli)" ] || continue
        iw dev "$ap_iface" station dump 2>/dev/null | \
        awk '/^Station/{mac=$2} /signal:/{print mac, $2}' | \
        while read -r sta_mac rssi; do
            [ -z "$sta_mac" ] || [ -z "$rssi" ] && continue
            local rssi_n="${rssi%.*}"
            local ck; ck=$(roam_cooldown_key "$sta_mac")
            local last_roam; last_roam=$(roam_cooldown_get "$ck")
            local now; now=$(date +%s)
            local time_since=$(( now - last_roam ))
            if [ "$time_since" -lt "$ROAM_COOLDOWN_TIME" ]; then
                logr "SKIP: %s in cooldown (%ss)" "$sta_mac" "$(( ROAM_COOLDOWN_TIME - time_since ))"
                continue
            fi
            local best_bssid
            if [ "${rssi_n}" -le "${ROAM_RSSI_HARD}" ] 2>/dev/null; then
                best_bssid=$(pick_best_candidate "$sta_mac" "$rssi_n")
                if [ -n "$best_bssid" ]; then
                    logr "HARD steer %s (%sdBm) -> %s" "$sta_mac" "$rssi_n" "$best_bssid"
                    hostapd_cli -i "$ap_iface" bss_tm_req "$sta_mac" \
                        pref=1 abridged=1 disassoc_imminent=1 \
                        neighbor="${best_bssid},0,0,0,0" >/dev/null 2>&1
                    roam_cooldown_set "$ck" "$now"
                fi
            elif [ "${rssi_n}" -le "${ROAM_RSSI_KICK}" ] 2>/dev/null; then
                best_bssid=$(pick_best_candidate "$sta_mac" "$rssi_n")
                if [ -n "$best_bssid" ]; then
                    logr "SOFT steer %s (%sdBm) -> %s" "$sta_mac" "$rssi_n" "$best_bssid"
                    hostapd_cli -i "$ap_iface" bss_tm_req "$sta_mac" \
                        pref=1 abridged=1 \
                        neighbor="${best_bssid},0,0,0,0" >/dev/null 2>&1
                    roam_cooldown_set "$ck" "$now"
                fi
            fi
        done
    done
}

pick_best_candidate() {
    local sta_mac="$1" cur_rssi="$2"
    local best_bssid="" best_rssi=-200
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue
        local peer_ip; peer_ip=$(jsonfilter -i "$f" -e '@.ip' 2>/dev/null)
        [ -z "$peer_ip" ] && continue
        local resp; resp=$(curl -s -m 2 \
        "http://${peer_ip}:${MASTER_PORT}/roam/signal?mac=${sta_mac}" 2>/dev/null)
        local peer_rssi; peer_rssi=$(echo "$resp"  | grep -o '"rssi":-\?[0-9]*' | cut -d: -f2)
        local peer_bssid; peer_bssid=$(echo "$resp" | grep -o '"bssid":"[^"]*"'  | cut -d'"' -f4)
        [ -z "$peer_rssi" ] || [ -z "$peer_bssid" ] && continue
        if [ "$peer_rssi" -gt "$best_rssi" ] 2>/dev/null; then
            best_rssi="$peer_rssi"; best_bssid="$peer_bssid"
        fi
    done
    if [ -n "$best_bssid" ] && [ "$best_rssi" -gt $(( cur_rssi + ROAM_HYSTERESIS )) ] 2>/dev/null; then
        echo "$best_bssid"
    fi
}

dfs_watchdog() {
    local ap_iface; ap_iface=$(get_ap_iface)
    log "DFS watchdog started on %s" "$ap_iface"
    cat > /tmp/easymesh_dfs_action.sh << 'SH'
#!/bin/sh
event="$2"
case "$event" in
    AP-CSA-FINISHED*|DFS-NOP-FINISHED*)
        new_chan=$(echo "$event" | grep -o 'chan=[0-9]*' | cut -d= -f2)
        printf '%s\n' "$new_chan" > /tmp/easymesh_dfs_chan_change
        ;;
esac
SH
    chmod +x /tmp/easymesh_dfs_action.sh
    hostapd_cli -i "$ap_iface" -a /tmp/easymesh_dfs_action.sh 2>/dev/null &
    while true; do
        if [ -f /tmp/easymesh_dfs_chan_change ]; then
            local new_chan; new_chan=$(cat /tmp/easymesh_dfs_chan_change)
            rm -f /tmp/easymesh_dfs_chan_change
            [ -n "$new_chan" ] && handle_dfs_channel_change "$new_chan"
        fi
        sleep 2
    done
}

handle_dfs_channel_change() {
    local new_chan="$1"
    log "DFS: mesh-wide channel change -> %s" "$new_chan"
    local rd; rd=$(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{print $1}' | head -1)
    uci set "${rd}.channel=${new_chan}"; uci_commit wireless
    if [ "$(get_role)" = "master" ]; then
        local payload="{\"channel\":\"$new_chan\",\"reason\":\"dfs\"}"
        for f in "$NODE_DB"/*.json; do
            [ -f "$f" ] || continue
            local peer_ip; peer_ip=$(jsonfilter -i "$f" -e '@.ip' 2>/dev/null)
            [ -z "$peer_ip" ] && continue
            do_http_post "http://${peer_ip}:${MASTER_PORT}/channel/apply" "$payload" >/dev/null 2>&1 &
            log "DFS: pushed channel %s to %s" "$new_chan" "$peer_ip"
        done
    fi
}

########################################
# 12. ACS / DEDICATED BACKHAUL / LB / TOPO
########################################
_last_ch=0
optimize_channel() {
    [ "$(get_role)" != "master" ] && return
    local now; now=$(date +%s)
    [ $(( now - _last_ch )) -lt "$CHANNEL_SCAN_INTERVAL" ] && return
    _last_ch=$now
    local dfs_enable; dfs_enable=$(uci_get easymesh global dfs_enable 1)
    local ch_24="1 6 11" ch_5_nodfs="36 40 44 48 149 153 157 161 165"
    local ch_5="${ch_5_nodfs}"
    [ "$dfs_enable" = "1" ] && ch_5="${ch_5_nodfs} 52 56 60 64 100 104 108 112 116 132 136 140"
    local rd; rd=$(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{print $1}' | head -1)
    local band; band=$(uci get "${rd}.band" 2>/dev/null || echo "5g")
    local candidates; case "$band" in 2g*|2.4*) candidates="$ch_24";; *) candidates="$ch_5";; esac
    local scan_out; scan_out=$(iw dev "$AP_IF" scan 2>/dev/null)
    local best_ch="" best_count=9999
    for ch in $candidates; do
        local count; count=$(echo "$scan_out" | grep -c "DS Parameter set: channel $ch")
        [ "$count" -lt "$best_count" ] && { best_count=$count; best_ch=$ch; }
    done
    [ -z "$best_ch" ] && return
    local cur; cur=$(uci get "${rd}.channel" 2>/dev/null)
    [ "$cur" = "$best_ch" ] && return
    log "ACS: channel %s -> %s (occupancy: %s APs)" "$cur" "$best_ch" "$best_count"
    uci set "${rd}.channel=$best_ch"; uci_commit wireless && wifi reload
    local payload="{\"channel\":\"$best_ch\",\"reason\":\"acs\"}"
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue
        local peer_ip; peer_ip=$(jsonfilter -i "$f" -e '@.ip' 2>/dev/null)
        [ -z "$peer_ip" ] && continue
        do_http_post "http://${peer_ip}:${MASTER_PORT}/channel/apply" "$payload" >/dev/null 2>&1 &
    done
}

setup_dedicated_backhaul() {
    local enabled; enabled=$(uci_get easymesh global dedicated_backhaul 0)
    [ "$enabled" != "1" ] && return
    local hw; hw=$(cat /tmp/easymesh_hw_type 2>/dev/null || echo "dual-band")
    [ "$hw" != "tri-band" ] && { log "Dedicated backhaul: skipped (hw=%s)" "$hw"; return 1; }
    local backhaul_radio="" seen5g=0
    for dev in $(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{gsub(/wireless\./,""); print $1}'); do
        local b; b=$(uci_get wireless "${dev}" band)
        case "$b" in 5g*|5GHz*) seen5g=$(( seen5g+1 ))
            [ "$seen5g" -ge 2 ] && { backhaul_radio="$dev"; break; };; esac
    done
    [ -z "$backhaul_radio" ] && { log "Dedicated backhaul: no second 5GHz radio"; return 1; }
    log "Dedicated backhaul: %s reserved for mesh" "$backhaul_radio"
    for iface in $(uci show wireless 2>/dev/null | awk -F= '/=wifi-iface/{gsub(/wireless\./,""); print $1}'); do
        local dev mode
        dev=$(uci_get wireless "${iface}" device)
        mode=$(uci get "wireless.${iface}.mode" 2>/dev/null)
        [ "$dev" = "$backhaul_radio" ] && [ "$mode" = "ap" ] && {
            uci del "wireless.${iface}"
            log "Dedicated backhaul: removed AP %s" "$iface"
        }
    done
    local bh_ch; bh_ch=$(uci_get easymesh global backhaul_channel 149)
    uci_set wireless "${backhaul_radio}" channel "${bh_ch}"
    uci_set wireless "${backhaul_radio}" htmode VHT80
    uci_add wireless easymesh_bh wifi-iface
    uci_set wireless easymesh_bh device "$backhaul_radio"
    uci_set wireless easymesh_bh mode mesh
    uci_set wireless easymesh_bh mesh_id $(uci_get easymesh global mesh_id)
    uci_set wireless easymesh_bh network mesh
    uci_set wireless easymesh_bh easymesh_managed 1
    local mesh_key; mesh_key=$(uci_get easymesh global mesh_key 2>/dev/null)
    if [ -n "$mesh_key" ]; then
        uci_set wireless easymesh_bh encryption sae
        uci_set wireless easymesh_bh key "$mesh_key"
    else
        uci_set wireless easymesh_bh encryption none
    fi
    uci_commit wireless
    log "Dedicated backhaul: %s configured (ch %s, VHT80)" "$backhaul_radio" "$bh_ch"
}

load_balance() {
    local ap_iface; ap_iface=$(get_ap_iface)
    local total; total=$(iw dev "$ap_iface" station dump 2>/dev/null | grep -c "^Station")
    [ "$total" -le "$LB_CLIENT_THRESHOLD" ] && return
    iw dev "$ap_iface" station dump 2>/dev/null | \
    awk '/^Station/{mac=$2} /signal:/{print $2+0, mac}' | \
    sort -n | head -$(( total / 5 )) | awk '{print $2}' | \
    while read -r mac; do
        hostapd_cli -i "$ap_iface" bss_tm_req "$mac" pref=1 abridged=1 >/dev/null 2>&1
    done
}

update_topology() {
    local my_mac my_ip my_role clients my_hostname
    my_mac=$(get_mac); my_ip=$(get_ip); my_role=$(get_role)
    clients=$(iw dev "$(get_ap_iface)" station dump 2>/dev/null | grep -c "^Station")
    my_hostname=$(uci_get system @system[0] hostname 'OpenWrt')
    local nodes="{\"mac\":\"$my_mac\",\"ip\":\"$my_ip\",\"role\":\"$my_role\",\"hostname\":\"$my_hostname\",\"clients\":$clients}"
    local links="" _orig_tmp="/tmp/em_orig_$$.txt"
    batctl meshif "$MESH_IF" orig 2>/dev/null | awk 'NR>2{print}' > "$_orig_tmp"
    while read -r peer_mac _ tq _rest; do
        [ -z "$peer_mac" ] && continue
        # 从 NODE_DB 查找该 peer 的完整信息
        local peer_norm; peer_norm=$(printf '%s' "$peer_mac" | tr 'A-F' 'a-f')
        local peer_safe; peer_safe=$(printf '%s' "$peer_norm" | tr ':' '_')
        local peer_f="${NODE_DB}/${peer_safe}.json"
        local peer_hostname="" peer_ip="" peer_role="agent" peer_clients=0
        if [ -f "$peer_f" ]; then
            peer_hostname=$(jsonfilter -i "$peer_f" -e '@.hostname' 2>/dev/null || echo "")
            peer_ip=$(      jsonfilter -i "$peer_f" -e '@.ip'       2>/dev/null || echo "")
        fi
        nodes="${nodes},{\"mac\":\"$peer_mac\",\"ip\":\"${peer_ip}\",\"role\":\"${peer_role}\",\"hostname\":\"${peer_hostname}\",\"tq\":$tq,\"clients\":$peer_clients}"
        links="${links:+$links,}{\"src\":\"$my_mac\",\"dst\":\"$peer_mac\",\"tq\":$tq}"
    done < "$_orig_tmp"
    rm -f "$_orig_tmp"
    # 追加 NODE_DB 中存在但 batctl orig 未出现的已批准节点（有线模式下 orig 可能为空）
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue
        local db_mac; db_mac=$(jsonfilter -i "$f" -e '@.mac' 2>/dev/null || echo "")
        [ -z "$db_mac" ] && continue
        case "$nodes" in *"\"$db_mac\""*) continue ;; esac
        local db_ip db_hostname db_source
        db_ip=$(      jsonfilter -i "$f" -e '@.ip'       2>/dev/null || echo "")
        db_hostname=$(jsonfilter -i "$f" -e '@.hostname' 2>/dev/null || echo "")
        db_source=$(  jsonfilter -i "$f" -e '@.source'   2>/dev/null || echo "wired")
        nodes="${nodes},{\"mac\":\"$db_mac\",\"ip\":\"$db_ip\",\"role\":\"agent\",\"hostname\":\"$db_hostname\",\"backhaul\":\"$db_source\",\"clients\":0}"
    done
    local bat0_up
    ip link show bat0 2>/dev/null | grep -q ',UP,\|<UP\|,UP>' \
        && bat0_up="true" || bat0_up="false"
    printf '{"ts":%d,"nodes":[%s],"links":[%s],"bat0_up":%s}\n' \
        "$(date +%s)" "$nodes" "${links:-}" "$bat0_up" > "$TOPO_FILE"
}

########################################
# 13. WIRELESS ONBOARDING AP
########################################
_stop_onboard_ap() {
    local _pid
    if [ -f /tmp/easymesh_pair_hostapd.pid ]; then
        _pid=$(cat /tmp/easymesh_pair_hostapd.pid)
        kill "$_pid" 2>/dev/null || true
        rm -f /tmp/easymesh_pair_hostapd.pid /tmp/easymesh_pair_hostapd.conf
    fi
    if [ -f /tmp/easymesh_pair_dnsmasq.pid ]; then
        _pid=$(cat /tmp/easymesh_pair_dnsmasq.pid)
        kill "$_pid" 2>/dev/null || true
        rm -f /tmp/easymesh_pair_dnsmasq.pid
    fi
    iw dev easymesh-pair0 del 2>/dev/null || true
    log "Wireless onboard AP stopped"
}

manage_wireless_onboard() {
    [ "$(get_role)" != "master" ] && return
    local en; en=$(uci get easymesh.global.wireless_onboard 2>/dev/null || echo 0)

    # onboard 功能关闭时：确保 AP 已停止
    if [ "$en" != "1" ]; then
        [ -f /tmp/easymesh_pair_hostapd.pid ] && _stop_onboard_ap
        return
    fi

    # 如果没有 pending 节点 且 至少有一个 approved 节点 → 自动关闭 onboard AP
    # （所有节点都已经加入，不需要继续广播临时 SSID）
    local pending_count approved_count
    pending_count=$(ls "$PENDING_DB"/*.json 2>/dev/null | wc -l)
    approved_count=$(ls "$NODE_DB"/*.json   2>/dev/null | wc -l)
    if [ "$pending_count" -eq 0 ] && [ "$approved_count" -gt 0 ]; then
        if [ -f /tmp/easymesh_pair_hostapd.pid ] && \
                kill -0 "$(cat /tmp/easymesh_pair_hostapd.pid)" 2>/dev/null; then
            log "All nodes approved, stopping wireless onboard AP"
            _stop_onboard_ap
        fi
        return
    fi

    # AP 已在运行
    [ -f /tmp/easymesh_pair_hostapd.pid ] && \
        kill -0 "$(cat /tmp/easymesh_pair_hostapd.pid)" 2>/dev/null && return
    local ssid mac prefix
    mac=$(get_mac); prefix=$(echo "$mac" | tr -d ':' | cut -c1-6 | tr 'a-f' 'A-F')
    ssid="EasyMesh-Setup-${prefix}"
    local phy; phy=$(iw phy 2>/dev/null | awk '/^phy/{print $1}' | head -1)
    [ -z "$phy" ] && return
    iw phy "$phy" interface add easymesh-pair0 type __ap 2>/dev/null || true
    ip link set easymesh-pair0 up
    cat > /tmp/easymesh_pair_hostapd.conf << HAPD
interface=easymesh-pair0
driver=nl80211
ssid=$ssid
hw_mode=g
channel=6
auth_algs=1
wpa=0
HAPD
    hostapd -B /tmp/easymesh_pair_hostapd.conf -P /tmp/easymesh_pair_hostapd.pid 2>/dev/null
    local my_ip; my_ip=$(get_ip)
    ip addr add "${my_ip%.*}.250/24" dev easymesh-pair0 2>/dev/null || true
    dnsmasq --interface=easymesh-pair0 --bind-interfaces \
        --dhcp-range="${my_ip%.*}.200,${my_ip%.*}.249,10m" \
        --dhcp-option=3,"${my_ip%.*}.250" \
        --no-resolv --no-hosts \
        --pid-file=/tmp/easymesh_pair_dnsmasq.pid 2>/dev/null
    log "Wireless onboard AP: %s" "$ssid"
}
########################################
# MAIN
########################################
_handle_approval_signal() {
    log "USR1: node approved — pushing profile to all approved agents"
    # 主动推送 profile 给所有已批准节点，不等 agent 的 10 秒轮询
    local profile; profile=$(cat "$PROFILE_FILE" 2>/dev/null)
    [ -z "$profile" ] && { log "WARN USR1: no profile file, agent will get it on next poll"; return; }
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue
        local peer_ip; peer_ip=$(jsonfilter -i "$f" -e '@.ip' 2>/dev/null)
        [ -z "$peer_ip" ] && continue
        ( curl -s -m 5 -X POST             -H "Content-Type: application/json"             -d "$profile"             "http://${peer_ip}:${MASTER_PORT}/profile/push" >/dev/null 2>&1 ) &
        log "USR1: pushed profile to agent %s" "$peer_ip"
    done
}

main_loop() {
    _dbg_init   # 预翻译 _dbg 字符串，export 给 socat 子进程
    _stop_jobs
    mkdir -p "$NODE_DB" "$PENDING_DB" "$ROAM_COOLDOWN_DIR" "$EM_PID_DIR"
    echo $$ > "${EM_PID_DIR}/easymesh_$(get_role).pid"

    { printf "\n" >> "$LOGFILE" 2>/dev/null
      log "================================================"
      log "EasyMesh daemon starting (pid=%s)" "$$"
      log "================================================"; }

    local hw_type="dual-band"
    local count5g; count5g=$(uci show wireless 2>/dev/null \
        | awk -F= '/=wifi-device/{dev=$1} dev && /\.band=/{gsub(/.*=/,""); if(/^5g|^5GHz/) n++} END{print n+0}')
    [ "$count5g" -ge 2 ] && hw_type="tri-band"
    echo "$hw_type" > /tmp/easymesh_hw_type
    log "Hardware: %s" "$hw_type"

    elect_role
    tune_batman
    setup_wired_backhaul

    log "Starting as: %s" "$(get_role)"

    _bg roam_watchdog  roam_watchdog
    _bg dfs_watchdog   dfs_watchdog
    _bg http_server    run_node_server

    if [ "$(get_role)" = "master" ]; then
        _bg disc_server discovery_server
        manage_wireless_onboard
        generate_profile
        log "DBG main: master ready, disc_server started, profile written"
        trap '_handle_approval_signal' USR1
    else
        _bg gw_watchdog gateway_watchdog
        log "DBG main: agent starting find_master+register"
        find_master && do_register || true
    fi

    setup_dedicated_backhaul
    # 只启动一个轻量诊断（不重复，不阻塞）
    _diagnose_network_improved &
    local _registered=0 _iter=0
    while true; do
        if [ $(( _iter % (ELECTION_INTERVAL / 10) )) -eq 0 ]; then
            local _prev_role; _prev_role=$(get_role)
            elect_role; tune_batman
            if [ "$(get_role)" != "$_prev_role" ]; then
                _registered=0
                log "Role switch: %s -> %s" "$_prev_role" "$(get_role)"
                if [ "$(get_role)" = "master" ]; then
                    _bg disc_server discovery_server
                    generate_profile
                fi
            fi
        fi

        if [ "$(get_role)" = "master" ]; then
            generate_profile
            optimize_channel
            manage_wireless_onboard
        else
            if [ "$_registered" = "0" ]; then
                if find_master; then
                    do_register && _registered=1
                elif [ -f "$MASTER_IP_FILE" ]; then
                    # 后台扫描已写入，直接注册
                    do_register && _registered=1
                else
                    log "DBG main_loop iter=%s: master not found yet, will retry" "$_iter"
                fi
            else
                poll_for_approval
            fi
        fi

        sync_neighbor_list
        load_balance
        update_topology
        check_routing_paths

        _iter=$(( _iter + 1 ))
        sleep 10
    done
}

case "${1:-}" in
    stop)           teardown_batman; _stop_jobs ;;
    __socat_http)   __socat_http ;;
    __handle_hello) __handle_hello ;;
    *)              main_loop ;;
esac
