#!/bin/sh

. /lib/functions.sh

# ── Files ─────────────────────────────────────────────────────────────────────
ROLE_FILE="/tmp/easymesh_role"
MASTER_IP_FILE="/tmp/easymesh_master_ip"
PROFILE_FILE="/tmp/easymesh_profile.json"
TOPO_FILE="/tmp/easymesh_topo.json"
NODE_DB="/tmp/easymesh_nodes"
NEIGHBOR_FILE="/tmp/easymesh_neighbors.conf"
ROAM_COOLDOWN_DIR="/tmp/em_cooldown"
EM_PID_DIR="/tmp/easymesh_pids"

# ── Constants ──────────────────────────────────────────────────────────────────
MASTER_PORT=4304
DISC_PORT=4305          # UDP 广播发现端口
ETH_IF="eth0"
BRIDGE_IF="br-lan"
AP_IF="wlan0"
MESH_IF="bat0"
LOGFILE="/tmp/easymesh.log"
LOG_MAX_LINES=500
_log_seq=0

# ── Tuning ────────────────────────────────────────────────────────────────────
BATMAN_OGM_INTERVAL=500
BATMAN_HOP_PENALTY=30
BATMAN_GW_MODE="client"
ROAM_RSSI_KICK=-72
ROAM_RSSI_HARD=-78
ROAM_HYSTERESIS=5
ROAM_PROBE_INTERVAL=5
ROAM_COOLDOWN_TIME=30
LB_CLIENT_THRESHOLD=15
CHANNEL_SCAN_INTERVAL=120
ELECTION_INTERVAL=30
GW_WATCHDOG_INTERVAL=10
HTTP_MAX_RETRIES=3
HTTP_TIMEOUT=5

# ── i18n ──────────────────────────────────────────────────────────────────────
lang=$(uci get luci.main.lang 2>/dev/null || echo "en")
translate() {
    local tpl="$1"; shift
    local lua_script translated
    lua_script="require \"luci.i18n\".setlanguage(\"${lang}\"); print(require \"luci.i18n\".translate([==[${tpl}]==]))"
    translated=$(lua -e "$lua_script" 2>/dev/null)
    [ -z "$translated" ] && translated="$tpl"
    if [ $# -gt 0 ]; then
        # shellcheck disable=SC2059
        printf "$translated" "$@"
    else
        printf '%s' "$translated"
    fi
}

# ── Logging ───────────────────────────────────────────────────────────────────
# _emlog <level> <tag> <message>
_emlog() {
    local level="$1" tag="$2"; shift 2
    local ts; ts=$(date "+%Y-%m-%d %H:%M:%S")
    _log_seq=$(( _log_seq + 1 ))
    printf "%s [%-5s] [%-8s] %s\n" "$ts" "$level" "$tag" "$*" >> "$LOGFILE"
    if [ $(( _log_seq % 50 )) -eq 0 ]; then
        local lc; lc=$(wc -l < "$LOGFILE" 2>/dev/null || echo 0)
        if [ "$lc" -gt "$LOG_MAX_LINES" ]; then
            local keep=$(( LOG_MAX_LINES * 4 / 5 ))
            tail -n "$keep" "$LOGFILE" > "${LOGFILE}.tmp" && mv "${LOGFILE}.tmp" "$LOGFILE"
        fi
    fi
}

# log <template> [args...]   — translate 模板，printf 插入参数
log()  { _emlog "INFO"  "core"  "$(translate "$@")"; }
logr() { _emlog "INFO"  "roam"  "$(translate "$@")"; }
logd() { _emlog "INFO"  "dfs"   "$(translate "$@")"; }
logh() { _emlog "INFO"  "heal"  "$(translate "$@")"; }
logw() { _emlog "WARN"  "core"  "$(translate "$@")"; }
loge() { _emlog "ERROR" "core"  "$(translate "$@")"; }

# ── Basic helpers ──────────────────────────────────────────────────────────────
get_mac()  { cat /sys/class/net/${BRIDGE_IF}/address 2>/dev/null || cat /sys/class/net/${ETH_IF}/address 2>/dev/null; }
get_ip()   { ip -4 addr show dev "$BRIDGE_IF" 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1 | head -1; }
get_role() { cat "$ROLE_FILE" 2>/dev/null || echo "agent"; }
master_ip(){ cat "$MASTER_IP_FILE" 2>/dev/null; }
wan_up()   { ubus call network.interface.wan status 2>/dev/null | grep -q '"up": true'; }
get_ap_iface() {
    uci get wireless.easymesh_ap.ifname 2>/dev/null ||
    uci get wireless.@wifi-iface[0].ifname 2>/dev/null ||
    echo "$AP_IF"
}

roam_cooldown_key() { echo "$1" | tr ':' '_'; }
roam_cooldown_get() { cat "${ROAM_COOLDOWN_DIR}/${1}" 2>/dev/null || echo 0; }
roam_cooldown_set() { mkdir -p "$ROAM_COOLDOWN_DIR"; printf '%s\n' "$2" > "${ROAM_COOLDOWN_DIR}/${1}"; }

# ── HTTP helpers ───────────────────────────────────────────────────────────────
do_http_post() {
    local url="$1" data="$2"
    local retry=0 wait_time resp tmp
    tmp="/tmp/em_http_$$.json"
    while [ "$retry" -lt "$HTTP_MAX_RETRIES" ]; do
        resp=$(wget -q -T "$HTTP_TIMEOUT" \
            --post-data="$data" \
            --header='Content-Type: application/json' \
            -O "$tmp" "$url" 2>/dev/null && cat "$tmp" 2>/dev/null)
        rm -f "$tmp"
        if [ -n "$resp" ]; then echo "$resp"; return 0; fi
        retry=$(( retry + 1 ))
        [ "$retry" -ge "$HTTP_MAX_RETRIES" ] && break
        case "$retry" in 1) wait_time=2;; 2) wait_time=4;; *) wait_time=8;; esac
        logw "HTTP POST retry %s/%s in %ss: %s" "$retry" "$HTTP_MAX_RETRIES" "$wait_time" "$url"
        sleep "$wait_time"
    done
    loge "HTTP POST failed after %s retries: %s" "$HTTP_MAX_RETRIES" "$url"
    return 1
}

########################################
# 1. PROCESS MANAGEMENT
########################################
_stop_jobs() {
    [ -d "$EM_PID_DIR" ] || return 0
    local _f _pid
    for _f in "$EM_PID_DIR"/*.pid; do
        [ -f "$_f" ] || continue
        _pid=$(cat "$_f" 2>/dev/null)
        [ -n "$_pid" ] && kill "$_pid" 2>/dev/null || true
        rm -f "$_f"
    done
}

_bg() {
    local _name="$1"; shift
    mkdir -p "$EM_PID_DIR"
    "$@" &
    echo $! > "${EM_PID_DIR}/${_name}.pid"
}

########################################
# 2. ROLE ELECTION
########################################
elect_role() {
    local mymac myip
    mymac=$(get_mac); myip=$(get_ip)

    if wan_up; then
        echo "master" > "$ROLE_FILE"
        echo "$myip"  > "$MASTER_IP_FILE"
        log "Election: WAN up -> master (%s)" "$mymac"
        return 0
    fi

    local best_mac="$mymac" best_ip="$myip"
    mkdir -p "$NODE_DB"
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue
        local peer_ip peer_mac
        peer_ip=$(jsonfilter  -i "$f" -e '@.ip'  2>/dev/null)
        peer_mac=$(jsonfilter -i "$f" -e '@.mac' 2>/dev/null)
        [ -z "$peer_ip" ] && continue
        local resp
        resp=$(wget -q -T 3 -O- "http://${peer_ip}:${MASTER_PORT}/wan" 2>/dev/null)
        if echo "$resp" | grep -q '"wan":true'; then
            echo "agent"    > "$ROLE_FILE"
            echo "$peer_ip" > "$MASTER_IP_FILE"
            log "Election: peer %s has WAN -> agent" "$peer_ip"
            return 0
        fi
        [ -n "$peer_mac" ] && [ "$peer_mac" \< "$best_mac" ] && {
            best_mac="$peer_mac"; best_ip="$peer_ip"
        }
    done

    if [ "$best_mac" = "$mymac" ]; then
        echo "master" > "$ROLE_FILE"
        echo "$myip"  > "$MASTER_IP_FILE"
        log "Election: lowest MAC -> master (%s)" "$mymac"
    else
        echo "agent"    > "$ROLE_FILE"
        echo "$best_ip" > "$MASTER_IP_FILE"
        log "Election: %s wins -> agent (master=%s)" "$best_mac" "$best_ip"
    fi
}

########################################
# 3. BATMAN-ADV TUNING
########################################
tune_batman() {
    batctl meshif "$MESH_IF" orig_interval "$BATMAN_OGM_INTERVAL" 2>/dev/null
    batctl meshif "$MESH_IF" hop_penalty   "$BATMAN_HOP_PENALTY"  2>/dev/null
    if [ "$(get_role)" = "master" ]; then
        batctl meshif "$MESH_IF" gw_mode server 2>/dev/null
        log "batman-adv: GW mode=server, OGM=%sms" "$BATMAN_OGM_INTERVAL"
    else
        batctl meshif "$MESH_IF" gw_mode "$BATMAN_GW_MODE" 2>/dev/null
        log "batman-adv: GW mode=%s, OGM=%sms" "$BATMAN_GW_MODE" "$BATMAN_OGM_INTERVAL"
    fi
}

########################################
# 4. WIRED BACKHAUL
########################################
setup_wired_backhaul() {
    if ! ip link show "$MESH_IF" >/dev/null 2>&1; then
        loge "bat0 missing - is batman-adv module loaded?"
        return 1
    fi
    ip link set "$MESH_IF" up 2>/dev/null
    if ! brctl show "$BRIDGE_IF" 2>/dev/null | grep -q "$MESH_IF"; then
        brctl addif "$BRIDGE_IF" "$MESH_IF" 2>/dev/null && \
            log "Wired backhaul: bat0 joined %s" "$BRIDGE_IF"
    fi
    local backhaul
    backhaul=$(uci get easymesh.global.backhaul 2>/dev/null || echo 'wired')
    if [ "$backhaul" = "wired" ] || [ "$backhaul" = "auto" ]; then
        if ! batctl meshif "$MESH_IF" if 2>/dev/null | grep -q "$ETH_IF"; then
            batctl meshif "$MESH_IF" interface add "$ETH_IF" 2>/dev/null && \
                log "Wired backhaul: %s added as batman-adv hardif" "$ETH_IF"
        fi
    fi
    # 注意：在 elect_role 之后调用，此时 role 已确定
    log "Wired backhaul ready (role=%s)" "$(get_role)"
}

########################################
# 5. UDP BROADCAST DISCOVERY
########################################
# 商业 Mesh 风格：新节点开机广播，master 自动发现并审批
# 无需手动操作，插线即加入
#
# 协议（纯文本 UDP）:
#   Agent  → 广播: "EASYMESH_HELLO <mac> <ip> <hostname>"
#   Master → 单播回: "EASYMESH_WELCOME <master_ip> <mesh_key>"
#   Agent  收到后: 写入 MASTER_IP_FILE，调 do_register()
#
# 实现：用 nc -u（busybox 有）或 /dev/udp（busybox ash 不支持）
# OpenWrt busybox nc: nc -u -l -p PORT（监听UDP）; nc -u IP PORT（发送UDP）

DISC_HELLO_INTERVAL=5     # 秒：agent 广播间隔
DISC_TIMEOUT=60           # 秒：持续广播超时后放弃（等手动或已注册）

# Master 侧：监听 UDP 广播，自动审批新节点
discovery_server() {
    log "Discovery server listening on UDP %s" "$DISC_PORT"
    while true; do
        # nc -u -l -p: 每次接受一个 UDP 包（busybox nc 不做持久循环）
        # 用 while true 重新启动监听
        local msg
        msg=$(nc -u -l -p "$DISC_PORT" 2>/dev/null)
        [ -z "$msg" ] && { sleep 1; continue; }

        local type mac ip hostname
        type=$(echo "$msg" | awk '{print $1}')
        mac=$(echo "$msg"  | awk '{print $2}')
        ip=$(echo "$msg"   | awk '{print $3}')
        hostname=$(echo "$msg" | awk '{print $4}')

        [ "$type" != "EASYMESH_HELLO" ] && continue
        [ -z "$mac" ] || [ -z "$ip" ] && continue

        log "Discovery: new node %s (%s) at %s" "$mac" "$hostname" "$ip"

        # 自动写入 NODE_DB（跳过 PENDING，直接审批）
        local safe; safe=$(echo "$mac" | tr ':' '_')
        mkdir -p "$NODE_DB"
        if [ ! -f "${NODE_DB}/${safe}.json" ]; then
            printf '{"mac":"%s","ip":"%s","hostname":"%s","source":"wired","status":"approved","ts":%s}\n' \
                "$mac" "$ip" "${hostname:-unknown}" "$(date +%s)" \
                > "${NODE_DB}/${safe}.json"
            log "Node auto-approved: %s (%s)" "$mac" "${hostname:-unknown}"
            # 立即推送配置
            generate_profile
            local mkey; mkey=$(uci get easymesh.global.mesh_key 2>/dev/null || echo "")
            # 回复 WELCOME（单播到 agent）
            printf 'EASYMESH_WELCOME %s %s\n' "$(get_ip)" "$mkey" | \
                nc -u "$ip" "$DISC_PORT" 2>/dev/null &
        fi
    done
}

# Agent 侧：开机广播，找到 master 后停止
discovery_client() {
    local mac ip hostname mymac myip
    mymac=$(get_mac); myip=$(get_ip)
    hostname=$(uci get system.@system[0].hostname 2>/dev/null || echo "node")
    local elapsed=0

    log "Discovery: broadcasting HELLO every %ss" "$DISC_HELLO_INTERVAL"
    while [ "$elapsed" -lt "$DISC_TIMEOUT" ]; do
        # 广播 HELLO
        printf 'EASYMESH_HELLO %s %s %s\n' "$mymac" "$myip" "$hostname" | \
            nc -u 255.255.255.255 "$DISC_PORT" 2>/dev/null

        # 等待 WELCOME（短暂监听，非阻塞方式：timeout 3s）
        local reply
        reply=$(nc -u -l -p "$DISC_PORT" -w 3 2>/dev/null)
        if echo "$reply" | grep -q "^EASYMESH_WELCOME"; then
            local master_ip_got
            master_ip_got=$(echo "$reply" | awk '{print $2}')
            echo "$master_ip_got" > "$MASTER_IP_FILE"
            log "Discovery: master found at %s" "$master_ip_got"
            return 0
        fi

        sleep "$DISC_HELLO_INTERVAL"
        elapsed=$(( elapsed + DISC_HELLO_INTERVAL + 3 ))
    done

    # 超时：fallback 到网关扫描
    log "Discovery timeout, falling back to LAN scan"
    return 1
}

########################################
# 6. INTER-NODE HTTP SERVER
########################################
# 用 socat（推荐）或 busybox nc while 循环（正确实现）
# 关键：nc fifo 模式在 busybox 上死锁，必须用下面这种方式

_http_ok()  { printf 'HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nConnection: close\r\n\r\n%s' "$1"; }
_http_403() { printf 'HTTP/1.1 403 Forbidden\r\nContent-Type: application/json\r\nConnection: close\r\n\r\n{"status":"pending"}\n'; }
_http_404() { printf 'HTTP/1.1 404 Not Found\r\nConnection: close\r\n\r\n{"error":"not found"}\n'; }

_handle_one_request() {
    local req_line method rawpath
    IFS= read -r req_line
    req_line="${req_line%$(printf '\r')}"
    method="${req_line%% *}"
    rawpath="${req_line#* }"; rawpath="${rawpath%% *}"
    [ "$method" = "OPTIONS" ] && { _http_ok "{}"; return; }

    local content_length=0 hline
    while IFS= read -r hline; do
        hline="${hline%$(printf '\r')}"
        [ -z "$hline" ] && break
        case "$hline" in Content-Length:*|content-length:*)
            content_length="${hline##*: }" ;; esac
    done

    local body=""
    [ "$content_length" -gt 0 ] 2>/dev/null && body=$(dd bs=1 count="$content_length" 2>/dev/null)

    local path query
    query="${rawpath#*\?}"; path="${rawpath%%\?*}"
    [ "$path" = "$rawpath" ] && query=""

    case "$path" in
    /ping)
        _http_ok "{\"role\":\"$(get_role)\",\"mac\":\"$(get_mac)\",\"ip\":\"$(get_ip)\"}"
        ;;
    /wan)
        wan_up && _http_ok '{"wan":true}' || _http_ok '{"wan":false}'
        ;;
    /register)
        local src; src=$(echo "$body" | grep -o '"source":"[^"]*"' | cut -d'"' -f4)
        register_node "$body" "${src:-wired}"
        _http_ok '{"status":"ok","msg":"registered"}'
        ;;
    /profile/checksum)
        local req_mac safe
        req_mac=$(echo "$query" | grep -o 'mac=[^&]*' | cut -d= -f2)
        safe=$(echo "$req_mac" | tr ':' '_')
        if [ -f "${NODE_DB}/${safe}.json" ] && [ -f "$PROFILE_FILE" ]; then
            local sum; sum=$(md5sum "$PROFILE_FILE" | cut -d' ' -f1)
            _http_ok "{\"sum\":\"$sum\"}"
        else
            _http_ok '{"status":"unregistered"}'
        fi
        ;;
    /profile)
        local req_mac safe
        req_mac=$(echo "$query" | grep -o 'mac=[^&]*' | cut -d= -f2)
        safe=$(echo "$req_mac" | tr ':' '_')
        if [ -f "${NODE_DB}/${safe}.json" ] && [ -f "$PROFILE_FILE" ]; then
            _http_ok "$(cat "$PROFILE_FILE")"
        else
            _http_ok '{"status":"unregistered"}'
        fi
        ;;
    /channel/apply)
        local new_chan reason
        new_chan=$(echo "$body" | grep -o '"channel":"[^"]*"' | cut -d'"' -f4)
        reason=$(echo "$body"  | grep -o '"reason":"[^"]*"'  | cut -d'"' -f4)
        [ -z "$new_chan" ] && { _http_ok '{"status":"ignored"}'; return; }
        log "Channel sync from master: ch=%s reason=%s" "$new_chan" "${reason:-unknown}"
        local rd; rd=$(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{print $1}' | head -1)
        uci set "${rd}.channel=${new_chan}"; uci commit wireless
        wifi reload &
        _http_ok "{\"status\":\"ok\",\"channel\":\"$new_chan\"}"
        ;;
    /roam/signal)
        local sta_mac; sta_mac=$(echo "$query" | grep -o 'mac=[^&]*' | cut -d= -f2)
        local ap_iface; ap_iface=$(get_ap_iface)
        local bssid; bssid=$(cat /sys/class/net/${ap_iface}/address 2>/dev/null)
        local sig; sig=$(iw dev "$ap_iface" station get "$sta_mac" 2>/dev/null | awk '/signal:/{print $2}' | head -1)
        if [ -n "$sig" ]; then _http_ok "{\"rssi\":$sig,\"bssid\":\"$bssid\"}"
        else _http_ok '{"rssi":null}'; fi
        ;;
    /roam/neighbors)
        apply_neighbor_list "$body"
        _http_ok '{"status":"ok"}'
        ;;
    *)
        _http_404
        ;;
    esac
}

run_node_server() {
    log "HTTP server starting on port %s" "$MASTER_PORT"

    # socat：最佳选择，并发，每连接 fork
    if command -v socat >/dev/null 2>&1; then
        log "HTTP server: socat mode (concurrent)"
        # socat 前台运行（_bg 已把整个 run_node_server 放后台）
        exec socat TCP-LISTEN:${MASTER_PORT},reuseaddr,fork,crnl \
            EXEC:"$0 __http_handler"
        return
    fi

    # busybox nc 正确实现：
    # nc -l -p PORT 每次接受一个连接，stdin/stdout 即 TCP stream
    # 用 sh -c 在子进程里运行 handler，避免变量污染
    # 注意：busybox nc 没有 -k（keepalive），必须 while 循环
    log "HTTP server: nc serial mode"
    while true; do
        # 关键：nc 的 stdin 来自 handler 的 stdout，nc 的 stdout 进 handler 的 stdin
        # busybox nc 语法：nc -l -p PORT（监听，接受一个连接后退出）
        # 用命名管道正确双向：req_pipe 从 nc 收数据，resp_pipe 发数据给 nc
        local rp="/tmp/em_req_$$" sp="/tmp/em_sp_$$"
        mkfifo "$rp" 2>/dev/null || { sleep 1; continue; }
        # 后台开 handler，从 rp 读请求，直接输出到 nc（通过替换 stdout）
        sh -c ". $0 __http_handler < $rp" > "$rp.out" 2>/dev/null &
        local hpid=$!
        # nc 把收到的数据写入 rp，并把 rp.out 发回给客户端
        nc -l -p "$MASTER_PORT" > "$rp" < "$rp.out" 2>/dev/null
        wait "$hpid" 2>/dev/null
        rm -f "$rp" "$rp.out"
    done
}

########################################
# 7. NODE REGISTRATION
########################################
# 简化：收到注册直接写 NODE_DB（自动审批）
# 管理员可在 LuCI 节点页查看所有已接入节点
register_node() {
    local body="$1" source="$2"
    local mac ip hostname
    mac=$(echo "$body"      | grep -o '"mac":"[^"]*"'      | cut -d'"' -f4)
    ip=$(echo "$body"       | grep -o '"ip":"[^"]*"'       | cut -d'"' -f4)
    hostname=$(echo "$body" | grep -o '"hostname":"[^"]*"' | cut -d'"' -f4)
    [ -z "$mac" ] && return 1
    local safe; safe=$(echo "$mac" | tr ':' '_')
    mkdir -p "$NODE_DB"
    # 更新节点信息（IP 可能变化）
    printf '{"mac":"%s","ip":"%s","hostname":"%s","source":"%s","status":"approved","ts":%s}\n' \
        "$mac" "${ip:-?}" "${hostname:-?}" "${source:-wired}" "$(date +%s)" \
        > "${NODE_DB}/${safe}.json"
    log "Node registered: %s (%s) via %s" "$mac" "${hostname:-?}" "$source"
}

########################################
# 8. AGENT: FIND MASTER & JOIN
########################################
find_master() {
    # 方法1：读缓存
    local cached; cached=$(master_ip)
    if [ -n "$cached" ]; then
        if wget -q -T 3 -O- "http://${cached}:${MASTER_PORT}/ping" 2>/dev/null | grep -q '"role":"master"'; then
            return 0
        fi
    fi
    rm -f "$MASTER_IP_FILE"

    # 方法2：检查默认网关（最常见情况：master 是网关）
    local gw; gw=$(ip route 2>/dev/null | awk '/default/{print $3}' | head -1)
    if [ -n "$gw" ]; then
        if wget -q -T 3 -O- "http://${gw}:${MASTER_PORT}/ping" 2>/dev/null | grep -q '"role":"master"'; then
            echo "$gw" > "$MASTER_IP_FILE"
            log "Master found at gateway: %s" "$gw"
            return 0
        fi
    fi

    # 方法3：UDP 广播发现
    log "Searching master via UDP broadcast..."
    local myip; myip=$(get_ip)
    local mymac; mymac=$(get_mac)
    local hostname; hostname=$(uci get system.@system[0].hostname 2>/dev/null || echo "node")
    local i=0
    while [ "$i" -lt 6 ]; do
        printf 'EASYMESH_HELLO %s %s %s\n' "$mymac" "$myip" "$hostname" | \
            nc -u 255.255.255.255 "$DISC_PORT" 2>/dev/null
        # 等待 WELCOME（3s 超时）
        local reply; reply=$(nc -u -l -p "$DISC_PORT" -w 3 2>/dev/null)
        if echo "$reply" | grep -q "^EASYMESH_WELCOME"; then
            local mip; mip=$(echo "$reply" | awk '{print $2}')
            echo "$mip" > "$MASTER_IP_FILE"
            log "Master found via broadcast: %s" "$mip"
            return 0
        fi
        i=$(( i + 1 ))
        sleep 2
    done

    # 方法4：同子网扫描（最慢，最后用）
    local prefix; prefix=$(echo "$myip" | cut -d. -f1-3)
    log "Scanning subnet %s.0/24 for master..." "$prefix"
    for j in $(seq 1 254); do
        local c="${prefix}.${j}"
        [ "$c" = "$myip" ] && continue
        if wget -q -T 1 -O- "http://${c}:${MASTER_PORT}/ping" 2>/dev/null | grep -q '"role":"master"'; then
            echo "$c" > "$MASTER_IP_FILE"
            log "Master found via scan: %s" "$c"
            return 0
        fi
    done

    return 1
}

do_register() {
    local mip; mip=$(master_ip)
    [ -z "$mip" ] && { find_master || return 1; mip=$(master_ip); }
    local mac ip hostname
    mac=$(get_mac); ip=$(get_ip)
    hostname=$(uci get system.@system[0].hostname 2>/dev/null || echo "node")
    do_http_post \
        "http://${mip}:${MASTER_PORT}/register" \
        "{\"mac\":\"$mac\",\"ip\":\"$ip\",\"hostname\":\"$hostname\",\"source\":\"wired\"}" || {
        loge "Failed to register with master %s" "$mip"
        return 1
    }
    log "Registered with master: %s" "$mip"
}

_last_profile_sum=""
poll_for_approval() {
    local mip; mip=$(master_ip)
    [ -z "$mip" ] && return 1

    local sum_resp remote_sum
    sum_resp=$(wget -q -T 3 -O- \
        "http://${mip}:${MASTER_PORT}/profile/checksum?mac=$(get_mac)" 2>/dev/null)
    remote_sum=$(echo "$sum_resp" | grep -o '"sum":"[^"]*"' | cut -d'"' -f4)

    if [ -n "$remote_sum" ] && [ "$remote_sum" = "$_last_profile_sum" ]; then
        return 0
    fi

    local resp
    resp=$(wget -q -T 5 -O- "http://${mip}:${MASTER_PORT}/profile?mac=$(get_mac)" 2>/dev/null)

    if echo "$resp" | grep -q '"status":"unregistered"'; then
        logw "Master lost our record, re-registering"
        rm -f "$MASTER_IP_FILE"
        do_register
        return 1
    fi
    if echo "$resp" | grep -q '"status":"approved"'; then
        apply_profile "$resp"
        _last_profile_sum=$(echo "$resp" | md5sum | cut -d' ' -f1)
        return 0
    fi
    return 1
}

########################################
# 9. PROFILE GENERATE & APPLY
########################################
generate_profile() {
    config_load easymesh
    local ssid key mesh_id mesh_key routing_algo channel
    config_get ssid         global ssid          'OpenWrt'
    config_get key          global key           ''
    config_get mesh_id      global mesh_id       'OpenWrt-Mesh'
    config_get mesh_key     global mesh_key      ''
    config_get routing_algo global routing_algo  'BATMAN_IV'
    local radio_dev
    radio_dev=$(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{print $1}' | head -1)
    channel=$(uci get "${radio_dev}.channel" 2>/dev/null || echo 'auto')
    printf '{"status":"approved","ssid":"%s","key":"%s","channel":"%s","mesh_id":"%s","mesh_key":"%s","routing_algo":"%s","ieee80211k":"1","ieee80211v":"1","backhaul":"wired"}\n' \
        "$ssid" "$key" "$channel" "$mesh_id" "$mesh_key" "$routing_algo" > "$PROFILE_FILE"
}

apply_profile() {
    local body="$1"
    echo "$body" > /tmp/em_profile_tmp.json
    local ssid key channel mesh_id mesh_key routing_algo
    ssid=$(jsonfilter         -i /tmp/em_profile_tmp.json -e '@.ssid'         2>/dev/null)
    key=$(jsonfilter          -i /tmp/em_profile_tmp.json -e '@.key'          2>/dev/null)
    channel=$(jsonfilter      -i /tmp/em_profile_tmp.json -e '@.channel'      2>/dev/null)
    mesh_id=$(jsonfilter      -i /tmp/em_profile_tmp.json -e '@.mesh_id'      2>/dev/null)
    mesh_key=$(jsonfilter     -i /tmp/em_profile_tmp.json -e '@.mesh_key'     2>/dev/null)
    routing_algo=$(jsonfilter -i /tmp/em_profile_tmp.json -e '@.routing_algo' 2>/dev/null)
    rm -f /tmp/em_profile_tmp.json
    [ -z "$ssid" ] && { loge "apply_profile: missing ssid"; return 1; }
    log "Applying profile: ssid=%s" "$ssid"
    uci set easymesh.global.enabled=1
    uci set easymesh.global.role=agent
    uci set easymesh.global.mesh_id="${mesh_id:-OpenWrt-Mesh}"
    uci set easymesh.global.mesh_key="${mesh_key}"
    uci set easymesh.global.ssid="$ssid"
    uci set easymesh.global.key="$key"
    uci set easymesh.global.backhaul=wired
    uci set easymesh.global.routing_algo="${routing_algo:-BATMAN_IV}"
    uci commit easymesh
    local _ap_sect
    _ap_sect=$(uci show wireless 2>/dev/null | \
        awk -F= '/=wifi-iface/{gsub(/wireless\./,""); s=$1} /\.mode=.ap/{print s; exit}')
    [ -z "$_ap_sect" ] && _ap_sect="@wifi-iface[0]"
    uci set "wireless.${_ap_sect}.ssid=$ssid"
    uci set "wireless.${_ap_sect}.key=$key"
    uci set "wireless.${_ap_sect}.ieee80211k=1"
    uci set "wireless.${_ap_sect}.ieee80211v=1"
    uci set "wireless.${_ap_sect}.bss_transition=1"
    uci set "wireless.${_ap_sect}.rrm_neighbor_report=1"
    [ -n "$channel" ] && [ "$channel" != "auto" ] && {
        local rd; rd=$(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{print $1}' | head -1)
        [ -n "$rd" ] && uci set "${rd}.channel=$channel"
    }
    uci commit wireless
    setup_wired_backhaul
    wifi reload
    log "Profile applied. Joined mesh."
}

########################################
# 10. WATCHDOGS
########################################
gateway_watchdog() {
    local fail=0
    log "Gateway watchdog started"
    while true; do
        sleep "$GW_WATCHDOG_INTERVAL"
        local mip; mip=$(master_ip)
        [ -z "$mip" ] && continue
        if wget -q -T 4 -O/dev/null "http://${mip}:${MASTER_PORT}/ping" 2>/dev/null; then
            fail=0
        else
            fail=$(( fail + 1 ))
            logw "Gateway: master %s unreachable (fail=%s/3)" "$mip" "$fail"
            if [ "$fail" -ge 3 ]; then
                loge "Gateway declared dead - re-electing"
                rm -f "$MASTER_IP_FILE"
                elect_role; tune_batman; fail=0
            fi
        fi
    done
}

prev_gw=""
check_routing_paths() {
    local cur_gw
    cur_gw=$(batctl meshif "$MESH_IF" gwl 2>/dev/null | awk '/===>{ print $2 }' | head -1)
    if [ -n "$cur_gw" ] && [ "$cur_gw" != "$prev_gw" ]; then
        log "Self-healing: gateway path changed -> %s (was: %s)" "$cur_gw" "${prev_gw:-none}"
        prev_gw="$cur_gw"
        sync_neighbor_list
    fi
}

########################################
# 11. SEAMLESS ROAMING
########################################
sync_neighbor_list() {
    local ap_iface ssid
    ap_iface=$(get_ap_iface)
    ssid=$(uci get wireless.easymesh_ap.ssid 2>/dev/null || uci get wireless.@wifi-iface[0].ssid 2>/dev/null)
    [ -z "$ssid" ] && return
    local my_bssid; my_bssid=$(cat /sys/class/net/${ap_iface}/address 2>/dev/null)
    > "$NEIGHBOR_FILE"
    iw dev "$AP_IF" scan 2>/dev/null | awk -v ssid="$ssid" '
        /^BSS /  { bssid=$2 }
        /freq:/  { freq=$2 }
        /DS Parameter set/ { chan=$NF }
        /SSID: / {
            if ($2 == ssid && bssid != "") {
                op = (freq+0 > 4000) ? 115 : 81
                print bssid, op, chan
            }
        }' | while read -r bssid op chan; do
        [ "$bssid" = "$my_bssid" ] && continue
        hostapd_cli -i "$ap_iface" set_neighbor "$bssid" \
            ssid="\"$ssid\"" nr="${bssid//:/}${op}${chan}0000" 2>/dev/null && \
        echo "$bssid $op $chan" >> "$NEIGHBOR_FILE"
    done
    if [ "$(get_role)" = "master" ]; then
        local nb_json
        nb_json=$(awk '{printf "{\"bssid\":\"%s\",\"op\":%s,\"chan\":%s},", $1,$2,$3}' \
            "$NEIGHBOR_FILE" | sed 's/,$//')
        local payload="{\"ssid\":\"$ssid\",\"neighbors\":[$nb_json],\"my_bssid\":\"$my_bssid\"}"
        for f in "$NODE_DB"/*.json; do
            [ -f "$f" ] || continue
            local peer_ip; peer_ip=$(jsonfilter -i "$f" -e '@.ip' 2>/dev/null)
            [ -z "$peer_ip" ] && continue
            do_http_post "http://${peer_ip}:${MASTER_PORT}/roam/neighbors" "$payload" >/dev/null 2>&1 &
        done
    fi
}

apply_neighbor_list() {
    local body="$1" ap_iface ssid
    ap_iface=$(get_ap_iface)
    ssid=$(echo "$body" | grep -o '"ssid":"[^"]*"' | cut -d'"' -f4)
    [ -z "$ssid" ] && return
    echo "$body" | grep -o '"bssid":"[^"]*"' | cut -d'"' -f4 | while read -r bssid; do
        [ -n "$bssid" ] && hostapd_cli -i "$ap_iface" \
            set_neighbor "$bssid" ssid="\"$ssid\"" >/dev/null 2>&1
    done
    logr "Neighbor list applied: %s APs" "$(echo "$body" | grep -c '"bssid"')"
}

roam_watchdog() {
    local ap_iface; ap_iface=$(get_ap_iface)
    log "Roam watchdog started on %s" "$ap_iface"
    while true; do
        sleep "$ROAM_PROBE_INTERVAL"
        [ -x "$(command -v hostapd_cli)" ] || continue
        iw dev "$ap_iface" station dump 2>/dev/null | \
        awk '/^Station/{mac=$2} /signal:/{print mac, $2}' | \
        while read -r sta_mac rssi; do
            [ -z "$sta_mac" ] || [ -z "$rssi" ] && continue
            local rssi_n="${rssi%.*}"
            local ck; ck=$(roam_cooldown_key "$sta_mac")
            local last_roam; last_roam=$(roam_cooldown_get "$ck")
            local now; now=$(date +%s)
            local time_since=$(( now - last_roam ))
            if [ "$time_since" -lt "$ROAM_COOLDOWN_TIME" ]; then
                logr "SKIP: %s in cooldown (%ss)" "$sta_mac" "$(( ROAM_COOLDOWN_TIME - time_since ))"
                continue
            fi
            local best_bssid
            if [ "${rssi_n}" -le "${ROAM_RSSI_HARD}" ] 2>/dev/null; then
                best_bssid=$(pick_best_candidate "$sta_mac" "$rssi_n")
                if [ -n "$best_bssid" ]; then
                    logr "HARD steer %s (%sdBm) -> %s" "$sta_mac" "$rssi_n" "$best_bssid"
                    hostapd_cli -i "$ap_iface" bss_tm_req "$sta_mac" \
                        pref=1 abridged=1 disassoc_imminent=1 \
                        neighbor="${best_bssid},0,0,0,0" >/dev/null 2>&1
                    roam_cooldown_set "$ck" "$now"
                fi
            elif [ "${rssi_n}" -le "${ROAM_RSSI_KICK}" ] 2>/dev/null; then
                best_bssid=$(pick_best_candidate "$sta_mac" "$rssi_n")
                if [ -n "$best_bssid" ]; then
                    logr "SOFT steer %s (%sdBm) -> %s" "$sta_mac" "$rssi_n" "$best_bssid"
                    hostapd_cli -i "$ap_iface" bss_tm_req "$sta_mac" \
                        pref=1 abridged=1 \
                        neighbor="${best_bssid},0,0,0,0" >/dev/null 2>&1
                    roam_cooldown_set "$ck" "$now"
                fi
            fi
        done
    done
}

pick_best_candidate() {
    local sta_mac="$1" cur_rssi="$2"
    local best_bssid="" best_rssi=-200
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue
        local peer_ip; peer_ip=$(jsonfilter -i "$f" -e '@.ip' 2>/dev/null)
        [ -z "$peer_ip" ] && continue
        local resp; resp=$(wget -q -T 2 -O- "http://${peer_ip}:${MASTER_PORT}/roam/signal?mac=${sta_mac}" 2>/dev/null)
        local peer_rssi; peer_rssi=$(echo "$resp"  | grep -o '"rssi":-\?[0-9]*' | cut -d: -f2)
        local peer_bssid; peer_bssid=$(echo "$resp" | grep -o '"bssid":"[^"]*"'  | cut -d'"' -f4)
        [ -z "$peer_rssi" ] || [ -z "$peer_bssid" ] && continue
        if [ "$peer_rssi" -gt "$best_rssi" ] 2>/dev/null; then
            best_rssi="$peer_rssi"; best_bssid="$peer_bssid"
        fi
    done
    local threshold=$(( cur_rssi + ROAM_HYSTERESIS ))
    if [ -n "$best_bssid" ] && [ "$best_rssi" -gt "$threshold" ] 2>/dev/null; then
        echo "$best_bssid"
    fi
}

dfs_watchdog() {
    local ap_iface; ap_iface=$(get_ap_iface)
    log "DFS watchdog started on %s" "$ap_iface"
    cat > /tmp/easymesh_dfs_action.sh << 'SH'
#!/bin/sh
event="$2"
case "$event" in
    AP-CSA-FINISHED*|DFS-NOP-FINISHED*)
        new_chan=$(echo "$event" | grep -o 'chan=[0-9]*' | cut -d= -f2)
        printf '%s\n' "$new_chan" > /tmp/easymesh_dfs_chan_change
        ;;
esac
SH
    chmod +x /tmp/easymesh_dfs_action.sh
    hostapd_cli -i "$ap_iface" -a /tmp/easymesh_dfs_action.sh 2>/dev/null &
    while true; do
        if [ -f /tmp/easymesh_dfs_chan_change ]; then
            local new_chan; new_chan=$(cat /tmp/easymesh_dfs_chan_change)
            rm -f /tmp/easymesh_dfs_chan_change
            [ -n "$new_chan" ] && handle_dfs_channel_change "$new_chan"
        fi
        sleep 2
    done
}

handle_dfs_channel_change() {
    local new_chan="$1"
    log "DFS: mesh-wide channel change -> %s" "$new_chan"
    local rd; rd=$(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{print $1}' | head -1)
    uci set "${rd}.channel=${new_chan}"; uci commit wireless
    if [ "$(get_role)" = "master" ]; then
        local payload="{\"channel\":\"$new_chan\",\"reason\":\"dfs\"}"
        for f in "$NODE_DB"/*.json; do
            [ -f "$f" ] || continue
            local peer_ip; peer_ip=$(jsonfilter -i "$f" -e '@.ip' 2>/dev/null)
            [ -z "$peer_ip" ] && continue
            do_http_post "http://${peer_ip}:${MASTER_PORT}/channel/apply" "$payload" >/dev/null 2>&1 &
            log "DFS: pushed channel %s to %s" "$new_chan" "$peer_ip"
        done
    fi
}

########################################
# 12. ACS / DEDICATED BACKHAUL / LB / TOPO
########################################
_last_ch=0
optimize_channel() {
    [ "$(get_role)" != "master" ] && return
    local now; now=$(date +%s)
    [ $(( now - _last_ch )) -lt "$CHANNEL_SCAN_INTERVAL" ] && return
    _last_ch=$now
    local dfs_enable; dfs_enable=$(uci get easymesh.global.dfs_enable 2>/dev/null || echo 1)
    local ch_24="1 6 11" ch_5_nodfs="36 40 44 48 149 153 157 161 165"
    local ch_5="${ch_5_nodfs}"
    [ "$dfs_enable" = "1" ] && ch_5="${ch_5_nodfs} 52 56 60 64 100 104 108 112 116 132 136 140"
    local rd; rd=$(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{print $1}' | head -1)
    local band; band=$(uci get "${rd}.band" 2>/dev/null || echo "5g")
    local candidates; case "$band" in 2g*|2.4*) candidates="$ch_24";; *) candidates="$ch_5";; esac
    local scan_out; scan_out=$(iw dev "$AP_IF" scan 2>/dev/null)
    local best_ch="" best_count=9999
    for ch in $candidates; do
        local count; count=$(echo "$scan_out" | grep -c "DS Parameter set: channel $ch")
        [ "$count" -lt "$best_count" ] && { best_count=$count; best_ch=$ch; }
    done
    [ -z "$best_ch" ] && return
    local cur; cur=$(uci get "${rd}.channel" 2>/dev/null)
    [ "$cur" = "$best_ch" ] && return
    log "ACS: channel %s -> %s (occupancy: %s APs)" "$cur" "$best_ch" "$best_count"
    uci set "${rd}.channel=$best_ch"; uci commit wireless && wifi reload
    local payload="{\"channel\":\"$best_ch\",\"reason\":\"acs\"}"
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue
        local peer_ip; peer_ip=$(jsonfilter -i "$f" -e '@.ip' 2>/dev/null)
        [ -z "$peer_ip" ] && continue
        do_http_post "http://${peer_ip}:${MASTER_PORT}/channel/apply" "$payload" >/dev/null 2>&1 &
    done
}

setup_dedicated_backhaul() {
    local enabled; enabled=$(uci get easymesh.global.dedicated_backhaul 2>/dev/null || echo 0)
    [ "$enabled" != "1" ] && return
    local hw; hw=$(cat /tmp/easymesh_hw_type 2>/dev/null || echo "dual-band")
    [ "$hw" != "tri-band" ] && { log "Dedicated backhaul: skipped (hw=%s)" "$hw"; return 1; }
    local backhaul_radio="" seen5g=0
    for dev in $(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{gsub(/wireless\./,""); print $1}'); do
        local b; b=$(uci get "wireless.${dev}.band" 2>/dev/null)
        case "$b" in 5g*|5GHz*) seen5g=$(( seen5g+1 )); [ "$seen5g" -ge 2 ] && { backhaul_radio="$dev"; break; };; esac
    done
    [ -z "$backhaul_radio" ] && { log "Dedicated backhaul: no second 5GHz radio"; return 1; }
    log "Dedicated backhaul: %s reserved for mesh" "$backhaul_radio"
    for iface in $(uci show wireless 2>/dev/null | awk -F= '/=wifi-iface/{gsub(/wireless\./,""); print $1}'); do
        local dev; dev=$(uci get "wireless.${iface}.device" 2>/dev/null)
        local mode; mode=$(uci get "wireless.${iface}.mode" 2>/dev/null)
        [ "$dev" = "$backhaul_radio" ] && [ "$mode" = "ap" ] && {
            uci del "wireless.${iface}"
            log "Dedicated backhaul: removed AP %s" "$iface"
        }
    done
    local bh_ch; bh_ch=$(uci get easymesh.global.backhaul_channel 2>/dev/null || echo 149)
    uci set "wireless.${backhaul_radio}.channel=${bh_ch}"
    uci set "wireless.${backhaul_radio}.htmode=VHT80"
    uci set wireless.easymesh_bh=wifi-iface
    uci set wireless.easymesh_bh.device="$backhaul_radio"
    uci set wireless.easymesh_bh.mode=mesh
    uci set wireless.easymesh_bh.mesh_id=$(uci get easymesh.global.mesh_id 2>/dev/null)
    uci set wireless.easymesh_bh.network=mesh
    uci set wireless.easymesh_bh.easymesh_managed=1
    local mesh_key; mesh_key=$(uci get easymesh.global.mesh_key 2>/dev/null)
    if [ -n "$mesh_key" ]; then uci set wireless.easymesh_bh.encryption=sae; uci set wireless.easymesh_bh.key="$mesh_key"
    else uci set wireless.easymesh_bh.encryption=none; fi
    uci commit wireless
    log "Dedicated backhaul: %s configured (ch %s, VHT80)" "$backhaul_radio" "$bh_ch"
}

load_balance() {
    local ap_iface; ap_iface=$(get_ap_iface)
    local total; total=$(iw dev "$ap_iface" station dump 2>/dev/null | grep -c "^Station")
    [ "$total" -le "$LB_CLIENT_THRESHOLD" ] && return
    iw dev "$ap_iface" station dump 2>/dev/null | \
    awk '/^Station/{mac=$2} /signal:/{print $2+0, mac}' | \
    sort -n | head -$(( total / 5 )) | awk '{print $2}' | \
    while read -r mac; do
        hostapd_cli -i "$ap_iface" bss_tm_req "$mac" pref=1 abridged=1 >/dev/null 2>&1
    done
}

update_topology() {
    local my_mac my_ip my_role clients
    my_mac=$(get_mac); my_ip=$(get_ip); my_role=$(get_role)
    clients=$(iw dev "$(get_ap_iface)" station dump 2>/dev/null | grep -c "^Station")
    local nodes="{\"mac\":\"$my_mac\",\"ip\":\"$my_ip\",\"role\":\"$my_role\",\"clients\":$clients}"
    local links=""
    while read -r peer_mac _ tq _rest; do
        [ -z "$peer_mac" ] && continue
        nodes="${nodes},{\"mac\":\"$peer_mac\",\"tq\":$tq}"
        links="${links:+$links,}{\"src\":\"$my_mac\",\"dst\":\"$peer_mac\",\"tq\":$tq}"
    done < <(awk 'NR>2{print}' /sys/kernel/debug/batman_adv/bat0/originators 2>/dev/null)
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue; nodes="${nodes},$(cat "$f")"
    done
    printf '{"ts":%d,"nodes":[%s],"links":[%s]}\n' "$(date +%s)" "$nodes" "${links:-}" > "$TOPO_FILE"
}

########################################
# 13. WIRELESS ONBOARDING AP
########################################
manage_wireless_onboard() {
    [ "$(get_role)" != "master" ] && return
    local en; en=$(uci get easymesh.global.wireless_onboard 2>/dev/null || echo 0)
    [ "$en" != "1" ] && return
    [ -f /tmp/easymesh_pair_hostapd.pid ] && \
        kill -0 "$(cat /tmp/easymesh_pair_hostapd.pid)" 2>/dev/null && return
    local ssid mac prefix
    mac=$(get_mac); prefix=$(echo "$mac" | tr -d ':' | cut -c1-6 | tr 'a-f' 'A-F')
    ssid="EasyMesh-Setup-${prefix}"
    local phy; phy=$(iw phy 2>/dev/null | awk '/^phy/{print $1}' | head -1)
    [ -z "$phy" ] && return
    iw phy "$phy" interface add easymesh-pair0 type __ap 2>/dev/null || true
    ip link set easymesh-pair0 up
    cat > /tmp/easymesh_pair_hostapd.conf << HAPD
interface=easymesh-pair0
driver=nl80211
ssid=$ssid
hw_mode=g
channel=6
auth_algs=1
wpa=0
HAPD
    hostapd -B /tmp/easymesh_pair_hostapd.conf -P /tmp/easymesh_pair_hostapd.pid 2>/dev/null
    local my_ip; my_ip=$(get_ip)
    ip addr add "${my_ip%.*}.250/24" dev easymesh-pair0 2>/dev/null || true
    dnsmasq --interface=easymesh-pair0 --bind-interfaces \
        --dhcp-range="${my_ip%.*}.200,${my_ip%.*}.249,10m" \
        --dhcp-option=3,"${my_ip%.*}.250" \
        --no-resolv --no-hosts \
        --pid-file=/tmp/easymesh_pair_dnsmasq.pid 2>/dev/null
    log "Wireless onboard AP: %s" "$ssid"
}

########################################
# MAIN
########################################
main_loop() {
    _stop_jobs
    mkdir -p "$NODE_DB" "$ROAM_COOLDOWN_DIR" "$EM_PID_DIR"
    echo $$ > /tmp/easymesh_master.pid

    { printf "\n" >> "$LOGFILE" 2>/dev/null
      _emlog "INFO" "core" "================================================"
      _emlog "INFO" "core" "EasyMesh daemon starting (pid=$$)"
      _emlog "INFO" "core" "================================================"; }

    # 硬件检测
    local hw_type="dual-band" count5g=0 _dev
    for _dev in $(uci show wireless 2>/dev/null | awk -F= '/=wifi-device/{gsub(/wireless\./,""); print $1}'); do
        local _b; _b=$(uci get "wireless.${_dev}.band" 2>/dev/null || echo "")
        case "$_b" in 5g*|5GHz*) count5g=$(( count5g+1 ));; esac
    done
    [ "$count5g" -ge 2 ] && hw_type="tri-band"
    echo "$hw_type" > /tmp/easymesh_hw_type
    log "Hardware: %s" "$hw_type"

    # 先选举角色，再配置回程（确保 role 已知）
    elect_role
    tune_batman
    setup_wired_backhaul   # 此时 role 已确定，日志正确

    log "Starting as: %s" "$(get_role)"

    # 启动后台服务
    _bg roam_watchdog  roam_watchdog
    _bg dfs_watchdog   dfs_watchdog
    _bg node_server    run_node_server

    if [ "$(get_role)" = "master" ]; then
        _bg disc_server discovery_server
        manage_wireless_onboard
        generate_profile
    else
        _bg gw_watchdog gateway_watchdog
        # Agent：自动发现并注册（无需人工操作）
        find_master && do_register || true
    fi

    setup_dedicated_backhaul

    local _registered=0 _iter=0
    while true; do
        # 定期重选举
        if [ $(( _iter % (ELECTION_INTERVAL / 10) )) -eq 0 ]; then
            local _prev_role; _prev_role=$(get_role)
            elect_role; tune_batman
            if [ "$(get_role)" != "$_prev_role" ]; then
                _registered=0
                log "Role switch: %s -> %s" "$_prev_role" "$(get_role)"
                # 角色变为 master 时启动发现服务
                if [ "$(get_role)" = "master" ]; then
                    _bg disc_server discovery_server
                    generate_profile
                fi
            fi
        fi

        if [ "$(get_role)" = "master" ]; then
            generate_profile
            optimize_channel
            manage_wireless_onboard
        else
            if [ "$_registered" = "0" ]; then
                find_master && do_register && _registered=1
            else
                poll_for_approval
            fi
        fi

        sync_neighbor_list
        load_balance
        update_topology
        check_routing_paths

        _iter=$(( _iter + 1 ))
        sleep 10
    done
}

case "$1" in
    stop)
        _stop_jobs
        pkill -f easymesh-master 2>/dev/null || true
        rm -rf "$EM_PID_DIR" /tmp/easymesh_master.pid /tmp/em_req_* /tmp/em_resp_*
        ;;
    __http_handler)
        _handle_one_request
        ;;
    *) main_loop ;;
esac
