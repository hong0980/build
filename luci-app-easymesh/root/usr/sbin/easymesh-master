#!/bin/sh
. /lib/functions.sh

PROFILE_FILE="/tmp/easymesh_profile.json"
TOPO_FILE="/tmp/easymesh_topo.json"
NEIGHBOR_FILE="/tmp/easymesh_neighbors.conf"
ROAM_COOLDOWN_DIR="/tmp/em_cooldown"
export ROLE_FILE="/tmp/easymesh_master_role"
export NODE_DB="/tmp/easymesh_nodes"
export PENDING_DB="/tmp/easymesh_pending"
export EM_PID_DIR="/tmp/easymesh_pids"

EM_STATE_DIR="/etc/easymesh"
export MASTER_IP_FILE="${EM_STATE_DIR}/master_ip"
export PERSISTENT_NODE_DB="/etc/easymesh/easymesh_nodes"
_LAST_SUM_FILE="${EM_STATE_DIR}/last_sum"

_is_dsa() { ip link show 2>/dev/null | grep -qE 'lan[0-9]+@eth'; }

_get_eth_if() {
    if _is_dsa; then
        local p; p=$(ip link show 2>/dev/null | awk -F'[@: ]+' '/lan[0-9]+@eth/{print $3; exit}')
        echo "${p:-eth0}"
    else
        local raw i=0 name
        while true; do
            name=$(uci -q get "network.@device[${i}].name") || break
            if [ "$name" = "br-lan" ]; then
                raw=$(uci -q get "network.@device[${i}].ports" | awk '{print $1}')
                break
            fi
            i=$(( i + 1 ))
        done
        [ -z "$raw" ] && raw=$(uci -q get network.lan.ifname | awk '{print $1}')
        echo "${raw%.*}"
    fi
}

ETH_IF=$(_get_eth_if)
[ -z "$ETH_IF" ] && ETH_IF="eth0"
export ETH_IF
BRIDGE_IF="br-lan"
export BRIDGE_IF
MESH_IF="bat0"
export MESH_IF

LOG_MAX_LINES=300
_LOG_SEQ_FILE="/tmp/em_logseq"
export MASTER_PORT=4304
export DISC_PORT=4305
export DISC_REPLY_PORT=4306
export LOGFILE="/tmp/easymesh.log"

BATMAN_OGM_INTERVAL=500
BATMAN_HOP_PENALTY=30
BATMAN_GW_MODE="client"
ROAM_RSSI_KICK=-72
ROAM_RSSI_HARD=-78
ROAM_HYSTERESIS=5
ROAM_PROBE_INTERVAL=5
ROAM_COOLDOWN_TIME=30
LB_CLIENT_THRESHOLD=15
CHANNEL_SCAN_INTERVAL=120
ELECTION_INTERVAL=30
GW_WATCHDOG_INTERVAL=10
HTTP_MAX_RETRIES=3
HTTP_TIMEOUT=5

[ -z "$lang" ] && lang=$(uci_get luci main lang en)
translate() {
    local tpl="$1"; shift
    local translated
    translated=$(lua -e "require \"luci.i18n\".setlanguage(\"${lang}\"); print(require \"luci.i18n\".translate([==[${tpl}]==]))" 2>/dev/null)
    [ -z "$translated" ] && translated="$tpl"
    [ $# -gt 0 ] && printf "$translated" "$@" || printf '%s' "$translated"
}

_emlog() {
    local level="$1" tag="$2"; shift 2
    local ts; ts=$(date "+%Y-%m-%d %H:%M:%S")
    (
        flock 200
        printf "%s [%-5s] [%-8s] %s\n" "$ts" "$level" "$tag" "$*" >> "$LOGFILE"
        local seq
        seq=$(( $(cat "$_LOG_SEQ_FILE" 2>/dev/null || echo 0) + 1 ))
        echo "$seq" > "$_LOG_SEQ_FILE"
        if [ $(( seq % 50 )) -eq 0 ]; then
            local lc; lc=$(wc -l < "$LOGFILE" 2>/dev/null || echo 0)
            if [ "$lc" -gt "$LOG_MAX_LINES" ]; then
                local keep=$(( LOG_MAX_LINES * 4 / 5 ))
                tail -n "$keep" "$LOGFILE" > "${LOGFILE}.tmp" && mv "${LOGFILE}.tmp" "$LOGFILE"
            fi
        fi
    ) 200>>"${LOGFILE}.lock"
}
log()  { _emlog "INFO"  "core"  "$(translate "$@")"; }
logr() { _emlog "INFO"  "roam"  "$(translate "$@")"; }
logd() { _emlog "INFO"  "dfs"   "$(translate "$@")"; }
logh() { _emlog "INFO"  "heal"  "$(translate "$@")"; }
logw() { _emlog "WARN"  "core"  "$(translate "$@")"; }
loge() { _emlog "ERROR" "core"  "$(translate "$@")"; }

########################################
# BASIC HELPERS
########################################
MAC_CACHE=""
get_mac() {
    [ -n "$MAC_CACHE" ] && { echo "$MAC_CACHE"; return; }
    MAC_CACHE=$(cat /sys/class/net/${BRIDGE_IF}/address 2>/dev/null ||
                 cat /sys/class/net/${ETH_IF}/address 2>/dev/null)
    echo "$MAC_CACHE"
}
get_ip()    { ip -4 addr show dev "$BRIDGE_IF" 2>/dev/null |
              awk '/inet /{print $2}' | cut -d/ -f1 | head -1; }
master_ip() { cat "$MASTER_IP_FILE" 2>/dev/null; }
wan_up()    { ubus call network.interface.wan status 2>/dev/null | grep -q '"up": true'; }

_mesh_iface_cache=''
get_mesh_iface() {
    [ -n "$_mesh_iface_cache" ] && { echo "$_mesh_iface_cache"; return; }
    _mesh_iface_cache=$(ubus call network.interface.mesh status 2>/dev/null | jsonfilter -e '@.device' ||
                        iw dev 2>/dev/null | awk '$1=="Interface" && $2~/mesh0/ {print $2}' ||
                        iwinfo 2>/dev/null | awk '/mesh0/ && /ESSID/ {print $1}')
    echo "$_mesh_iface_cache"
}

get_role() {
    [ -n "${_ROLE_CACHE:-}" ] && { echo "$_ROLE_CACHE"; return; }
    cat "$ROLE_FILE" 2>/dev/null || echo "agent"
}
_set_role() { _ROLE_CACHE="$1"; echo "$1" > "$ROLE_FILE"; }

AP_IFACE_CACHE=""
get_ap_iface() {
    [ -n "$AP_IFACE_CACHE" ] && { echo "$AP_IFACE_CACHE"; return; }
    local iface; iface=$(iw dev 2>/dev/null | awk '/Interface/{i=$2} /type AP/{print i; exit}')
    AP_IFACE_CACHE="${iface:-wlan0}"
    echo "$AP_IFACE_CACHE"
}

_WIFI_DEVS_CACHE=""
_wifi_devs() {
    [ -n "$_WIFI_DEVS_CACHE" ] && { echo "$_WIFI_DEVS_CACHE"; return; }
    _WIFI_DEVS_CACHE=$(uci -q show wireless | awk -F= '/=wifi-device$/{sub(/wireless\./,""); print $1}')
    echo "$_WIFI_DEVS_CACHE"
}

_profile_sum() { md5sum < "$PROFILE_FILE" | cut -d' ' -f1; }
roam_cooldown_get() { cat "${ROAM_COOLDOWN_DIR}/${1}" 2>/dev/null || echo 0; }
roam_cooldown_set() { printf '%s\n' "$2" > "${ROAM_COOLDOWN_DIR}/${1}"; }

do_http_post() {
    local url="$1" data="$2" retry=0 resp
    while [ "$retry" -lt "$HTTP_MAX_RETRIES" ]; do
        resp=$(curl -s -m "$HTTP_TIMEOUT" \
            -H "Content-Type: application/json" -d "$data" "$url" 2>/dev/null)
        [ -n "$resp" ] && { echo "$resp"; return 0; }
        retry=$(( retry + 1 ))
        [ "$retry" -ge "$HTTP_MAX_RETRIES" ] && break
        logw "HTTP POST retry %s/%s: %s" "$retry" "$HTTP_MAX_RETRIES" "$url"
        sleep $(( retry * 2 ))
    done
    loge "HTTP POST failed after %s retries: %s" "$HTTP_MAX_RETRIES" "$url"
    return 1
}

_ping_master() {
    curl -s -m 3 "http://${1}:${MASTER_PORT}/ping" 2>/dev/null | grep -q '"role":"master"'
}

_node_update() {
    local f="$1" ip="$2" ts; ts=$(date +%s)
    sed -i "s/\"ip\":\"[^\"]*\"/\"ip\":\"${ip}\"/" "$f"
    sed -i "s/\"ts\":[0-9]*/\"ts\":${ts}/" "$f"
    local _bn; _bn="${f##*/}"
    [ -f "${PERSISTENT_NODE_DB}/${_bn}" ] && cp "$f" "${PERSISTENT_NODE_DB}/${_bn}" 2>/dev/null
}

_iter_nodes() {
    local cb="$1" f ip mac
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue
        ip=$(jsonfilter -i "$f" -e '@.ip' 2>/dev/null)
        [ -z "$ip" ] && continue
        mac=$(jsonfilter -i "$f" -e '@.mac' 2>/dev/null)
        "$cb" "$ip" "$mac" "$f"
    done
}

_save_sum() { printf '%s' "$1" > "$_LAST_SUM_FILE"; }
_load_sum() { cat "$_LAST_SUM_FILE" 2>/dev/null; }

########################################
# 1. PROCESS MANAGEMENT
########################################
_pkill() {
    local pat="$1" p pid cmd
    for p in /proc/[0-9]*/cmdline; do
        [ -f "$p" ] || continue
        pid="${p%/cmdline}"; pid="${pid##*/}"
        [ "$pid" = "$$" ] && continue
        cmd=$(tr '\0' ' ' < "$p" 2>/dev/null)
        case "$cmd" in *${pat}*) kill "$pid" 2>/dev/null || true ;; esac
    done
}

_stop_jobs() {
    [ -d "$EM_PID_DIR" ] || return 0
    local f pid
    for f in "$EM_PID_DIR"/*.pid; do
        [ -f "$f" ] || continue
        pid=$(cat "$f" 2>/dev/null)
        [ -z "$pid" ] && continue
        kill "$pid" 2>/dev/null || true
        local i=0
        while [ $i -lt 3 ] && kill -0 "$pid" 2>/dev/null; do
            sleep 1; i=$(( i + 1 ))
        done
        kill -9 "$pid" 2>/dev/null || true
    done
    _pkill "socat.*:${MASTER_PORT}"
    _pkill "socat.*:${DISC_PORT}"
}

_bg() { local name="$1"; shift; "$@" & echo $! > "${EM_PID_DIR}/${name}.pid"; }

########################################
# 2. ROLE ELECTION
########################################
elect_role() {
    local cfg_role; cfg_role=$(uci_get easymesh global role)
    if [ -n "$cfg_role" ]; then
        _set_role "$cfg_role"
        [ "$cfg_role" = "master" ] && { local ip; ip=$(get_ip); [ -n "$ip" ] && echo "$ip" > "$MASTER_IP_FILE"; }
        return 0
    fi
    local mymac myip; mymac=$(get_mac); myip=$(get_ip)
    if wan_up; then
        _set_role "master"; echo "$myip" > "$MASTER_IP_FILE"
        log "Election: WAN up -> master (%s)" "$mymac"; return 0
    fi
    local best_mac="$mymac" best_ip="$myip"
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue
        local peer_ip peer_mac
        peer_ip=$(jsonfilter  -i "$f" -e '@.ip'  2>/dev/null)
        peer_mac=$(jsonfilter -i "$f" -e '@.mac' 2>/dev/null)
        [ -z "$peer_ip" ] && continue
        if curl -s -m 3 "http://${peer_ip}:${MASTER_PORT}/wan" 2>/dev/null | grep -q '"wan":true'; then
            _set_role "agent"; echo "$peer_ip" > "$MASTER_IP_FILE"
            log "Election: peer %s has WAN -> agent" "$peer_ip"; return 0
        fi
        if [ -n "$peer_mac" ]; then
            local pmh bmh
            pmh=$(echo "$peer_mac" | tr -d ':'); bmh=$(echo "$best_mac" | tr -d ':')
            [ "$pmh" \< "$bmh" ] && { best_mac="$peer_mac"; best_ip="$peer_ip"; }
        fi
    done
    if [ "$best_mac" = "$mymac" ]; then
        _set_role "master"; echo "$myip" > "$MASTER_IP_FILE"
        log "Election: lowest MAC -> master (%s)" "$mymac"
    else
        _set_role "agent"; echo "$best_ip" > "$MASTER_IP_FILE"
        log "Election: %s wins -> agent (master=%s)" "$best_mac" "$best_ip"
    fi
}

########################################
# 3. BATMAN-ADV TUNING
########################################
tune_batman() {
    batctl meshif "$MESH_IF" orig_interval "$BATMAN_OGM_INTERVAL" 2>/dev/null
    batctl meshif "$MESH_IF" hop_penalty   "$BATMAN_HOP_PENALTY"  2>/dev/null
    local bmode; bmode=$(uci_get easymesh global backhaul 'wired')
    local role;  role=$(get_role)
    local algo;  algo=$(uci_get easymesh global routing_algo 'BATMAN_V')
    local state="${bmode}:${role}:${algo}"
    local last;  last=$(cat /tmp/easymesh_batman_state 2>/dev/null)
    if [ "$state" != "$last" ]; then
        if [ -f /sys/module/batman_adv/parameters/routing_algo ]; then
            echo "$algo" > /sys/module/batman_adv/parameters/routing_algo 2>/dev/null \
                && log "batman-adv: routing_algo=%s" "$algo" \
                || logw "batman-adv: routing_algo=%s rejected" "$algo"
        fi
        if [ "$bmode" = "wired" ]; then
            batctl meshif "$MESH_IF" bl 0 2>/dev/null
            batctl meshif "$MESH_IF" dat 0 2>/dev/null
            log "batman-adv: BLA=off DAT=off (wired)"
        fi
        printf '%s' "$state" > /tmp/easymesh_batman_state
    fi
    if [ "$role" = "master" ]; then
        batctl meshif "$MESH_IF" gw_mode server 2>/dev/null
        log "batman-adv: role=master gw=server OGM=%sms" "$BATMAN_OGM_INTERVAL"
    else
        batctl meshif "$MESH_IF" gw_mode "$BATMAN_GW_MODE" 2>/dev/null
        log "batman-adv: role=agent gw=%s OGM=%sms" "$BATMAN_GW_MODE" "$BATMAN_OGM_INTERVAL"
    fi
}

########################################
# 4. BACKHAUL SETUP / TEARDOWN
########################################
setup_wired_backhaul() {
    if ! ip link show "$MESH_IF" >/dev/null 2>&1; then
        modprobe batman-adv 2>/dev/null || true
        sleep 1
        ip link add name "$MESH_IF" type batadv 2>/dev/null || {
            loge "Failed to create bat0"; return 1
        }
        local w=0
        while ! ip link show "$MESH_IF" >/dev/null 2>&1; do
            w=$(( w+1 )); [ $w -ge 15 ] && { loge "bat0 missing after 15s - kmod-batman-adv?"; return 1; }
            sleep 1
        done
    fi
    ip link set "$MESH_IF" up 2>/dev/null
    local sw=0
    while [ ! -d "/sys/class/net/$MESH_IF/mesh" ] && [ $sw -lt 2 ]; do sleep 1; sw=$(( sw+1 )); done

    local backhaul; backhaul=$(uci_get easymesh global backhaul 'wired')

    if [ "$backhaul" = "wired" ] || [ "$backhaul" = "auto" ]; then
        if ! _is_dsa; then
            local bport; bport=$(uci_get easymesh global backhaul_port '')
            if [ -n "$bport" ] && ip link show "$bport" >/dev/null 2>&1; then
                if ! batctl meshif "$MESH_IF" if 2>/dev/null | grep -qw "$bport"; then
                    ip link set "$bport" nomaster 2>/dev/null || \
                        brctl delif "$BRIDGE_IF" "$bport" 2>/dev/null || true
                    ip link set "$bport" up 2>/dev/null
                    batctl meshif "$MESH_IF" interface add "$bport" 2>/dev/null \
                        && log "Wired backhaul: %s -> bat0" "$bport" \
                        || loge "Backhaul: failed to add %s to bat0" "$bport"
                    ETH_IF="$bport"; export ETH_IF
                fi
            fi
        fi
    fi

    if [ "$backhaul" != "wired" ]; then
        local mesh_iface; mesh_iface=$(get_mesh_iface)
        if ip link show "$mesh_iface" >/dev/null 2>&1; then
            if ! batctl meshif "$MESH_IF" if 2>/dev/null | grep -qw "$mesh_iface"; then
                ip link set "$mesh_iface" up 2>/dev/null
                batctl meshif "$MESH_IF" interface add "$mesh_iface" 2>/dev/null \
                    && log "Wireless backhaul: $mesh_iface -> $MESH_IF"
            fi
        else
            [ "$backhaul" = "wireless" ] && logw "mesh0 not found, wireless backhaul failed"
        fi
    fi

    if [ "$backhaul" = "wired" ]; then
        ip link show "$MESH_IF" 2>/dev/null | grep -q "master br-lan" && {
            ip link set "$MESH_IF" nomaster 2>/dev/null || \
                brctl delif "$BRIDGE_IF" "$MESH_IF" 2>/dev/null || true
            log "Backhaul: bat0 removed from br-lan"
        }
        batctl meshif "$MESH_IF" bl 0 2>/dev/null
        batctl meshif "$MESH_IF" dat 0 2>/dev/null
    else
        ip link show "$MESH_IF" 2>/dev/null | grep -q "master br-lan" || {
            ip link set "$MESH_IF" master br-lan 2>/dev/null || \
                brctl addif "$BRIDGE_IF" "$MESH_IF" 2>/dev/null
            ip link show "$MESH_IF" 2>/dev/null | grep -q "master br-lan" \
                && log "Backhaul: bat0 joined br-lan" \
                || loge "Backhaul: FAILED to add bat0 to br-lan"
        }
    fi
    log "Backhaul ready (mode=%s role=%s)" "$backhaul" "$(get_role)"
}

teardown_batman() {
    ip link set "$MESH_IF" nomaster 2>/dev/null || \
        brctl delif "$BRIDGE_IF" "$MESH_IF" 2>/dev/null || true
    if _is_dsa; then
        batctl meshif "$MESH_IF" interface del "$ETH_IF" 2>/dev/null || true
    else
        local bport; bport=$(uci_get easymesh global backhaul_port '')
        if [ -n "$bport" ]; then
            batctl meshif "$MESH_IF" interface del "$bport" 2>/dev/null || true
            ip link set "$bport" up 2>/dev/null
            ip link set "$bport" master br-lan 2>/dev/null || \
                brctl addif "$BRIDGE_IF" "$bport" 2>/dev/null || true
        fi
    fi
    local backhaul; backhaul=$(uci_get easymesh global backhaul 'wired')
    [ "$backhaul" != "wired" ] && {
        local mesh_iface; mesh_iface=$(get_mesh_iface)
        [ -n "$mesh_iface" ] && \
            batctl meshif "$MESH_IF" interface del "$mesh_iface" 2>/dev/null || true
    }
    ip link set "$MESH_IF" down 2>/dev/null || true
    log "batman-adv torn down"
}

########################################
# 5. UDP DISCOVERY SERVER
########################################
discovery_server() {
    log "Discovery server listening on UDP %s" "$DISC_PORT"
    socat UDP4-RECVFROM:${DISC_PORT},fork,reuseaddr \
        EXEC:"/usr/sbin/easymesh-master __handle_hello" 2>/dev/null &
    echo $! > "${EM_PID_DIR}/disc_server.pid"
}

__handle_hello() {
    local msg; IFS= read -r -t 5 msg 2>/dev/null
    [ -z "$msg" ] && return 0

    local cmd mac agent_ip host
    read -r cmd mac agent_ip host <<EOF
$msg
EOF

    [ "$cmd" != "EASYMESH_HELLO" ] && return 0
    { [ -z "$mac" ] || [ -z "$agent_ip" ]; } && return 0
    echo "$mac" | grep -qiE '^([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}$' || return 0
    mac=$(echo "$mac" | tr 'A-F' 'a-f')

    local safe; safe=$(echo "$mac" | tr ':' '_')
    local approved="${NODE_DB}/${safe}.json"
    local pending="${PENDING_DB}/${safe}.json"
    local persistent="${PERSISTENT_NODE_DB}/${safe}.json"
    mkdir -p "$NODE_DB" "$PENDING_DB"

    if [ -f "$approved" ]; then
        _node_update "$approved" "$agent_ip"
    elif [ -f "$persistent" ]; then
        sed "s/\"ip\":\"[^\"]*\"/\"ip\":\"${agent_ip}\"/" "$persistent" | \
        sed "s/\"ts\":[0-9]*/\"ts\":$(date +%s)/" > "$approved"
        log "HELLO: Node recovered from persistent storage: %s"  "$mac"
    elif [ -f "$pending" ]; then
        _node_update "$pending" "$agent_ip"
    else
        printf '{"mac":"%s","ip":"%s","hostname":"%s","source":"wired","status":"pending","ts":%s}\n' \
            "$mac" "$agent_ip" "${host:-}" "$(date +%s)" > "$pending"
        printf "%s [INFO ] [core    ] Pending node: %s (%s) via wired\n" \
            "$(date '+%Y-%m-%d %H:%M:%S')" "$mac" "${host:-unknown}" >> "$LOGFILE"
    fi

    local myip
    myip=$(ip -4 addr show dev "${BRIDGE_IF}" 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1 | head -1)
    [ -z "$myip" ] && myip=$(ip -4 route get "$agent_ip" 2>/dev/null \
        | awk '/src/{for(i=1;i<=NF;i++) if($i=="src") print $(i+1); exit}')
    [ -z "$myip" ] && return 0

    printf 'EASYMESH_WELCOME %s\n' "$myip" | \
        socat - "UDP-DATAGRAM:${agent_ip}:${DISC_REPLY_PORT}" 2>/dev/null
}

########################################
# 6. EMBEDDED HTTP SERVER
########################################
_http_ok()   { printf "HTTP/1.0 200 OK\r\nContent-Type: application/json\r\nAccess-Control-Allow-Origin: *\r\nConnection: close\r\n\r\n%s" "$1"; }
_http_html() { printf "HTTP/1.0 200 OK\r\nContent-Type: text/html; charset=utf-8\r\nAccess-Control-Allow-Origin: *\r\nConnection: close\r\n\r\n"; cat "$1"; }
_http_404()  { printf 'HTTP/1.0 404 Not Found\r\nContent-Type: application/json\r\nConnection: close\r\n\r\n{"error":"not found"}\n'; }

_serve_profile() {
    local query="$1" mode="$2"
    local req_mac safe
    req_mac=$(echo "$query" | grep -o 'mac=[^&]*' | cut -d= -f2)
    safe=$(echo "$req_mac" | tr ':' '_' | tr 'A-F' 'a-f')
    if [ -f "${PENDING_DB}/${safe}.json" ]; then
        _http_ok '{"status":"pending"}'
    elif [ -f "${NODE_DB}/${safe}.json" ] && [ -f "$PROFILE_FILE" ]; then
        if [ "$mode" = "sum" ]; then
            _http_ok "{\"sum\":\"$(_profile_sum)\"}"
        else
            _http_ok "$(cat "$PROFILE_FILE")"
        fi
    else
        _http_ok '{"status":"unregistered"}'
    fi
}

__http_handler() {
    local method="${REQUEST_METHOD:-GET}"
    local path="${PATH_INFO:-/}"
    local query="${QUERY_STRING:-}"
    local clen="${CONTENT_LENGTH:-0}"
    local body=""
    [ "$clen" -gt 0 ] 2>/dev/null && body=$(dd bs=1 count="$clen" 2>/dev/null)
    [ "$method" = "OPTIONS" ] && { _http_ok "{}"; return; }

    case "$path" in
        /|/index.html)
            local html="/www/easymesh-pair/index.html"
            if [ -f "$html" ]; then _http_html "$html"
            else _http_ok '{"error":"index.html not found"}'; fi
            ;;
        /favicon.ico) _http_404 ;;
        /ping)
            _http_ok "$(printf '{"role":"%s","mac":"%s","ip":"%s"}' \
                "$(get_role)" "$(get_mac)" "$(get_ip)")"
            ;;
        /wan)
            wan_up && _http_ok '{"wan":true}' || _http_ok '{"wan":false}'
            ;;
        /register)
            local src; src=$(echo "$body" | grep -o '"source":"[^"]*"' | cut -d'"' -f4)
            register_node "$body" "${src:-wired}"
            _http_ok '{"status":"ok","msg":"registered"}'
            ;;
        /profile/checksum) _serve_profile "$query" "sum" ;;
        /profile)          _serve_profile "$query" "profile" ;;
        /profile/push)
            [ "$method" != "POST" ] && { _http_ok '{"status":"ignored"}'; return; }
            local push_ssid; push_ssid=$(echo "$body" | grep -o '"ssid":"[^"]*"' | cut -d'"' -f4)
            if [ -n "$push_ssid" ]; then
                apply_profile "$body"
                _save_sum "$(_profile_sum)"
                _http_ok '{"status":"ok","msg":"profile applied"}'
                log "Profile received via push from master"
            else
                _http_ok '{"status":"error","msg":"invalid profile"}'
            fi
            ;;
        /nodes/approve)
            local req_mac; req_mac=$(echo "$query" | grep -o 'mac=[^&]*' | cut -d= -f2)
            [ -z "$req_mac" ] && req_mac=$(echo "$body" | grep -o '"mac":"[^"]*"' | cut -d'"' -f4)
            req_mac=$(echo "$req_mac" | tr 'A-F' 'a-f')
            local safe; safe=$(echo "$req_mac" | tr ':' '_')
            local pf="${PENDING_DB}/${safe}.json"
            local af="${NODE_DB}/${safe}.json"
            local persistent="${PERSISTENT_NODE_DB}/${safe}.json"

            if [ -f "$pf" ]; then
                sed 's/"status":"pending"/"status":"approved"/' "$pf" > "$af" && rm -f "$pf"
                mkdir -p "$PERSISTENT_NODE_DB"
                cp "$af" "$persistent" 2>/dev/null || loge "Failed to persist node: $req_mac"
                _http_ok '{"status":"ok","msg":"approved"}'
                log "Node approved: %s (persisted to %s)" "$req_mac" "$persistent"
            elif [ -f "$af" ]; then
                _http_ok '{"status":"ok","msg":"already approved"}'
            else
                _http_ok '{"status":"error","msg":"node not found"}'
            fi
            ;;
        /nodes/list)
            local out="[" first=1
            for f in "$PENDING_DB"/*.json "$NODE_DB"/*.json; do
                [ -f "$f" ] || continue
                [ "$first" = "1" ] && first=0 || out="${out},"
                out="${out}$(cat "$f")"
            done
            _http_ok "${out}]"
            ;;
        /channel/apply)
            local new_chan reason
            new_chan=$(echo "$body" | grep -o '"channel":"[^"]*"' | cut -d'"' -f4)
            reason=$(echo "$body"  | grep -o '"reason":"[^"]*"'  | cut -d'"' -f4)
            [ -z "$new_chan" ] && { _http_ok '{"status":"ignored"}'; return; }
            log "Channel sync: ch=%s reason=%s" "$new_chan" "${reason:-?}"
            local rd
            for rd in $(_wifi_devs); do uci -q set "wireless.${rd}.channel=${new_chan}"; done
            uci_commit wireless; wifi reload &
            _http_ok "{\"status\":\"ok\",\"channel\":\"$new_chan\"}"
            ;;
        /roam/signal)
            local sta_mac; sta_mac=$(echo "$query" | grep -o 'mac=[^&]*' | cut -d= -f2)
            local ap; ap=$(get_ap_iface)
            local bssid; bssid=$(cat /sys/class/net/${ap}/address 2>/dev/null)
            local sig; sig=$(iw dev "$ap" station get "$sta_mac" 2>/dev/null \
                | awk '/signal:/{print $2}' | head -1)
            if [ -n "$sig" ]; then _http_ok "{\"rssi\":$sig,\"bssid\":\"$bssid\"}"
            else _http_ok '{"rssi":null}'; fi
            ;;
        /roam/neighbors)
            apply_neighbor_list "$body"; _http_ok '{"status":"ok"}'
            ;;
        *) _http_404 ;;
    esac
}

__socat_http() {
    local req_line; IFS= read -r req_line
    req_line="${req_line%$'\r'}"
    [ -z "$req_line" ] && return
    local method full_url
    method=$(  echo "$req_line" | awk '{print $1}')
    full_url=$(echo "$req_line" | awk '{print $2}')
    local path="${full_url%\?*}"
    local query="${full_url#*\?}"
    [ "$query" = "$full_url" ] && query=""
    local clen=0
    while IFS= read -r header; do
        header="${header%$'\r'}"; [ -z "$header" ] && break
        case "$(echo "$header" | tr 'A-Z' 'a-z')" in
            content-length:*)
                clen=$(echo "$header" | awk -F': ' '{print $2}' | tr -d '\r\n ') ;;
        esac
    done
    export REQUEST_METHOD="$method" PATH_INFO="$path" \
           QUERY_STRING="$query" CONTENT_LENGTH="$clen"
    __http_handler
}

run_node_server() {
    log "HTTP server starting on :%s" "$MASTER_PORT"
    _pkill "socat.*TCP.*${MASTER_PORT}"
    sleep 1
    socat TCP4-LISTEN:${MASTER_PORT},fork,reuseaddr \
        EXEC:"/usr/sbin/easymesh-master __socat_http" 2>>"$LOGFILE" &
    sleep 1
    local ok=0
    command -v ss     >/dev/null 2>&1 && ss     -tlnp 2>/dev/null | grep -q ":${MASTER_PORT}" && ok=1
    command -v netstat>/dev/null 2>&1 && [ "$ok" = "0" ] && \
        netstat -tlnp 2>/dev/null | grep -q ":${MASTER_PORT}" && ok=1
    [ "$ok" = "1" ] \
        && log "HTTP server listening on :%s" "$MASTER_PORT" \
        || loge "HTTP server failed to start on :%s" "$MASTER_PORT"
}

########################################
# 7. NODE REGISTRATION
########################################
register_node() {
    local body="$1" source="$2"
    local mac ip hostname
    mac=$(      echo "$body" | grep -o '"mac":"[^"]*"'      | cut -d'"' -f4)
    ip=$(       echo "$body" | grep -o '"ip":"[^"]*"'       | cut -d'"' -f4)
    hostname=$( echo "$body" | grep -o '"hostname":"[^"]*"' | cut -d'"' -f4)
    [ -z "$mac" ] && { loge "register_node: missing mac"; return 1; }
    [ -z "$ip"  ] && { loge "register_node: missing ip";  return 1; }
    mac=$(echo "$mac" | tr 'A-F' 'a-f')
    local safe; safe=$(echo "$mac" | tr ':' '_')
    mkdir -p "$NODE_DB" "$PENDING_DB" "$PERSISTENT_NODE_DB"
    local approved="${NODE_DB}/${safe}.json"
    local pending="${PENDING_DB}/${safe}.json"
    local persistent="${PERSISTENT_NODE_DB}/${safe}.json"

    if [ -f "$approved" ]; then
        _node_update "$approved" "${ip:-?}"
        log "Node re-registered (approved): %s (%s) ip=%s" "$mac" "${hostname:-?}" "$ip"
    elif [ -f "$persistent" ]; then
        sed "s/\"ip\":\"[^\"]*\"/\"ip\":\"${ip}\"/" "$persistent" | \
        sed "s/\"ts\":[0-9]*/\"ts\":$(date +%s)/" > "$approved"
        log "Node recovered from persistent storage: %s (%s) ip=%s" "$mac" "${hostname:-?}" "$ip"
    else
        printf '{"mac":"%s","ip":"%s","hostname":"%s","source":"%s","status":"pending","ts":%s}\n' \
            "$mac" "${ip:-?}" "${hostname:-?}" "${source:-wired}" "$(date +%s)" > "$pending"
        log "Pending node: %s (%s) ip=%s via %s" "$mac" "${hostname:-?}" "$ip" "$source"
    fi
}

########################################
# 8. AGENT: FIND MASTER & REGISTER
########################################
find_master() {
    local my_ip; my_ip=$(get_ip)
    local prefix; prefix="${my_ip%.*}"
    local backhaul; backhaul=$(uci_get easymesh global backhaul 'wired')

    if [ "$backhaul" != "wired" ]; then
        local w=0
        while [ $w -lt 40 ]; do
            local nb; nb=$(batctl meshif bat0 neighbors 2>/dev/null \
                | grep -vcE "^B\.A\.T|^No |^$" || echo 0)
            [ "$nb" -gt 0 ] && { log "batman neighbour after %ss" "$w"; break; }
            sleep 2; w=$(( w + 2 ))
        done
        [ $w -ge 40 ] && logw "No batman neighbour in 40s, continuing"
    fi

    local cached; cached=$(master_ip)
    if [ -n "$cached" ] && [ "$cached" != "$my_ip" ]; then
        if _ping_master "$cached"; then return 0; fi
        rm -f "$MASTER_IP_FILE"
    fi

    local cand="${prefix}.1"
    if [ "$cand" != "$my_ip" ]; then
        local t=0
        while [ $t -lt 3 ]; do
            if _ping_master "$cand"; then
                echo "$cand" > "$MASTER_IP_FILE"
                log "Master found at %s (wired direct)" "$cand"; return 0
            fi
            t=$(( t+1 )); sleep 3
        done
        log "Master not at %s" "$cand"
    fi

    local s
    for s in 2 254 250 100 101; do
        local c="${prefix}.${s}"
        [ "$c" = "$my_ip" ] && continue
        if _ping_master "$c"; then
            echo "$c" > "$MASTER_IP_FILE"
            log "Master found at %s (quick scan)" "$c"; return 0
        fi
    done

    (
        local j c
        for j in $(seq 3 253); do
            c="${prefix}.${j}"
            [ "$c" = "$my_ip" ] && continue
            [ -f "$MASTER_IP_FILE" ] && break
            if _ping_master "$c"; then
                echo "$c" > "$MASTER_IP_FILE"
                printf "%s [INFO ] [core    ] Master found at %s (bg scan)\n" \
                    "$(date '+%Y-%m-%d %H:%M:%S')" "$c" >> "$LOGFILE"
                break
            fi
        done
    ) &
    return 1
}

do_register() {
    local mip; mip=$(master_ip)
    [ -z "$mip" ] && { find_master || return 1; mip=$(master_ip); }
    [ -z "$mip" ] && return 1
    local mac; mac=$(get_mac)
    local hostname; hostname=$(uci_get system @system[0] hostname OpenWrt)
    local reg_source="wired" ip
    echo "$mip" | grep -qE '\.250$' && reg_source="wireless"
    if [ "$reg_source" = "wireless" ]; then
        local wlan_ip mprefix
        wlan_ip=$(ip -4 addr show 2>/dev/null | awk '/inet /{ip=$2} /wlan/{print ip; exit}' | cut -d/ -f1)
        mprefix="${mip%.*}"
        echo "$wlan_ip" | grep -q "^${mprefix}\." && ip="$wlan_ip" || ip=$(get_ip)
    else
        ip=$(get_ip)
    fi
    local resp
    resp=$(do_http_post \
        "http://${mip}:${MASTER_PORT}/register" \
        "{\"mac\":\"$mac\",\"ip\":\"$ip\",\"hostname\":\"$hostname\",\"source\":\"$reg_source\"}") || {
        loge "Failed to register with master %s" "$mip"; return 1
    }
    log "Registered with master %s via %s" "$mip" "$reg_source"
}

poll_for_approval() {
    local mip; mip=$(master_ip)
    [ -z "$mip" ] && return 1
    local sum_resp remote_sum
    sum_resp=$(curl -s -m 3 \
        "http://${mip}:${MASTER_PORT}/profile/checksum?mac=$(get_mac)" 2>/dev/null)
    remote_sum=$(echo "$sum_resp" | grep -o '"sum":"[^"]*"' | cut -d'"' -f4)
    [ -n "$remote_sum" ] && [ "$remote_sum" = "$(_load_sum)" ] && return 0
    local resp
    resp=$(curl -s -m 5 "http://${mip}:${MASTER_PORT}/profile?mac=$(get_mac)" 2>/dev/null)
    case "$resp" in
        *'"status":"pending"'*)
            log "Waiting for master approval..."; return 1 ;;
        *'"status":"unregistered"'*)
            logw "Not registered, re-registering"
            do_register || true; return 2 ;;
        *'"status":"approved"'*)
            apply_profile "$resp"
            _save_sum "$(_profile_sum)"
            return 0 ;;
    esac
    return 1
}

########################################
# 9. PROFILE GENERATE & APPLY
########################################
generate_profile() {
    config_load easymesh
    local ssid key mesh_id mesh_key routing_algo channel band_merge
    local ssid_5g ssid_2g key_5g key_2g
    local ieee80211r ieee80211k ieee80211v ft_over_ds mobility_domain backhaul
    config_get ssid            global ssid             'OpenWrt'
    config_get key             global key              ''
    config_get band_merge      global band_merge       '1'
    config_get ssid_5g         global ssid_5g          ''
    config_get ssid_2g         global ssid_2g          ''
    config_get key_5g          global key_5g           ''
    config_get key_2g          global key_2g           ''
    config_get mesh_id         global mesh_id          'OpenWrt-Mesh'
    config_get mesh_key        global mesh_key         ''
    config_get routing_algo    global routing_algo     'BATMAN_V'
    config_get ieee80211r      global ieee80211r       '1'
    config_get ieee80211k      global ieee80211k       '1'
    config_get ieee80211v      global ieee80211v       '1'
    config_get ft_over_ds      global ft_over_ds       '1'
    config_get mobility_domain global mobility_domain  'aabb'
    config_get backhaul        global backhaul         'wired'
    local rd
    for rd in $(_wifi_devs); do
        local b; b=$(uci -q get "wireless.${rd}.band")
        case "$b" in 5g*|5GHz*) break ;; esac
    done
    [ -z "$rd" ] && rd=$(_wifi_devs | head -1)
    channel=$(uci -q get "wireless.${rd}.channel" 2>/dev/null || echo 'auto')
    local new_prof
    new_prof=$(printf \
        '{"status":"approved","ssid":"%s","key":"%s","channel":"%s","mesh_id":"%s","mesh_key":"%s","routing_algo":"%s","ieee80211r":"%s","ieee80211k":"%s","ieee80211v":"%s","ft_over_ds":"%s","mobility_domain":"%s","backhaul":"%s","band_merge":"%s","ssid_5g":"%s","ssid_2g":"%s","key_5g":"%s","key_2g":"%s"}' \
        "$ssid" "$key" "$channel" "$mesh_id" "$mesh_key" "$routing_algo" \
        "$ieee80211r" "$ieee80211k" "$ieee80211v" "$ft_over_ds" "$mobility_domain" \
        "$backhaul" "$band_merge" "$ssid_5g" "$ssid_2g" "$key_5g" "$key_2g")
    local old_prof; old_prof=$(cat "$PROFILE_FILE" 2>/dev/null)
    if [ "$new_prof" != "$old_prof" ]; then
        printf '%s' "$new_prof" > "$PROFILE_FILE"
        log "Profile updated: ssid=%s channel=%s backhaul=%s" "$ssid" "$channel" "$backhaul"
    fi
}

apply_profile() {
    local body="$1" _pf="/tmp/em_profile_$$.json"
    printf '%s' "$body" > "$_pf"
    local ssid key channel mesh_id mesh_key routing_algo
    local ieee80211r ieee80211k ieee80211v ft_over_ds mobility_domain backhaul
    local band_merge ssid_5g ssid_2g key_5g key_2g
    eval "$(jsonfilter -i "$_pf" \
        -e 'ssid=@.ssid'                        -e 'key=@.key'                   \
        -e 'channel=@.channel'                  -e 'mesh_id=@.mesh_id'           \
        -e 'mesh_key=@.mesh_key'                -e 'routing_algo=@.routing_algo' \
        -e 'ieee80211r=@.ieee80211r'            -e 'ieee80211k=@.ieee80211k'     \
        -e 'ieee80211v=@.ieee80211v'            -e 'ft_over_ds=@.ft_over_ds'     \
        -e 'mobility_domain=@.mobility_domain'  -e 'backhaul=@.backhaul'         \
        -e 'band_merge=@.band_merge'            -e 'ssid_5g=@.ssid_5g'           \
        -e 'ssid_2g=@.ssid_2g'                  -e 'key_5g=@.key_5g'             \
        -e 'key_2g=@.key_2g'                    2>/dev/null)"
    rm -f "$_pf"
    [ -z "$ssid" ] && { loge "apply_profile: missing ssid"; return 1; }
    log "Applying profile: ssid=%s channel=%s backhaul=%s" "$ssid" "$channel" "${backhaul:-wired}"

    uci -q set easymesh.global.enabled=1
    uci -q set easymesh.global.role=agent
    uci -q set easymesh.global.ssid="$ssid"
    uci -q set easymesh.global.key="$key"
    uci -q set easymesh.global.mesh_id="${mesh_id:-OpenWrt-Mesh}"
    uci -q set easymesh.global.mesh_key="$mesh_key"
    uci -q set easymesh.global.backhaul="${backhaul:-wired}"
    uci -q set easymesh.global.routing_algo="${routing_algo:-BATMAN_V}"
    [ -n "$band_merge"      ] && uci -q set easymesh.global.band_merge="$band_merge"
    [ -n "$ssid_5g"         ] && uci -q set easymesh.global.ssid_5g="$ssid_5g"
    [ -n "$ssid_2g"         ] && uci -q set easymesh.global.ssid_2g="$ssid_2g"
    [ -n "$key_5g"          ] && uci -q set easymesh.global.key_5g="$key_5g"
    [ -n "$key_2g"          ] && uci -q set easymesh.global.key_2g="$key_2g"
    [ -n "$ieee80211r"      ] && uci -q set easymesh.global.ieee80211r="$ieee80211r"
    [ -n "$ieee80211k"      ] && uci -q set easymesh.global.ieee80211k="$ieee80211k"
    [ -n "$ieee80211v"      ] && uci -q set easymesh.global.ieee80211v="$ieee80211v"
    [ -n "$ft_over_ds"      ] && uci -q set easymesh.global.ft_over_ds="$ft_over_ds"
    [ -n "$mobility_domain" ] && uci -q set easymesh.global.mobility_domain="$mobility_domain"
    uci -q commit easymesh

    if uci show wireless.mesh0 >/dev/null 2>&1; then
        if [ "${backhaul:-wired}" = "wired" ]; then
            uci_set wireless mesh0 disabled 1
        else
            uci_set wireless mesh0 disabled 0
            [ -n "$mesh_id" ] && uci_set wireless mesh0 mesh_id "$mesh_id"
            if [ -n "$mesh_key" ]; then
                uci_set wireless mesh0 encryption sae
                uci_set wireless mesh0 key "$mesh_key"
            else
                uci_set wireless mesh0 encryption none
                uci -q del wireless.mesh0.key
            fi
        fi
    fi

    local ap_s5g ap_k5g ap_s2g ap_k2g
    if [ "${band_merge:-1}" = "1" ]; then
        ap_s5g="$ssid"; ap_k5g="$key"; ap_s2g="$ssid"; ap_k2g="$key"
    else
        ap_s5g="${ssid_5g:-$ssid}"; ap_k5g="${key_5g:-$key}"
        ap_s2g="${ssid_2g:-$ssid}"; ap_k2g="${key_2g:-$key}"
    fi

    local iface
    for iface in $(uci -q show wireless | \
            awk -F= '/\.easymesh_managed=.1/{sub(/wireless\./,""); sub(/\.easymesh_managed/,""); print $1}'); do
        [ "$iface" = "mesh0" ] && continue
        uci show "wireless.${iface}" >/dev/null 2>&1 || continue
        local dev band ap_s ap_k
        dev=$(uci -q get "wireless.${iface}.device")
        band=$(uci -q get "wireless.${dev}.band" | tr '[:upper:]' '[:lower:]')
        case "$band" in
            2g*|2.4*) ap_s="$ap_s2g"; ap_k="$ap_k2g" ;;
            *)        ap_s="$ap_s5g"; ap_k="$ap_k5g" ;;
        esac
        uci_set wireless "$iface" disabled 0
        uci_set wireless "$iface" ssid "$ap_s"
        if [ -n "$ap_k" ]; then
            uci_set wireless "$iface" encryption 'psk2+ccmp'
            uci_set wireless "$iface" key "$ap_k"
        else
            uci_set wireless "$iface" encryption 'none'
            uci -q del "wireless.${iface}.key"
        fi
        [ "${ieee80211k:-1}" = "1" ] && {
            uci_set wireless "$iface" ieee80211k 1
            uci_set wireless "$iface" rrm_neighbor_report 1
            uci_set wireless "$iface" rrm_beacon_report 1
        }
        [ "${ieee80211v:-1}" = "1" ] && {
            uci_set wireless "$iface" ieee80211v 1
            uci_set wireless "$iface" bss_transition 1
        }
        [ "${ieee80211r:-1}" = "1" ] && {
            uci_set wireless "$iface" ieee80211r 1
            uci_set wireless "$iface" ft_psk_generate_local 1
            [ -n "$mobility_domain" ] && uci_set wireless "$iface" mobility_domain "$mobility_domain"
            [ -n "$ft_over_ds"      ] && uci_set wireless "$iface" ft_over_ds      "$ft_over_ds"
        }
    done

    [ -n "$channel" ] && [ "$channel" != "auto" ] && {
        local rd
        for rd in $(_wifi_devs); do uci -q set "wireless.${rd}.channel=$channel"; done
    }

    local wchanges; wchanges=$(uci changes wireless 2>/dev/null)
    uci_commit wireless
    setup_wired_backhaul
    printf '%s' "$body" > "$PROFILE_FILE"
    if [ -n "$wchanges" ]; then
        wifi reload
        log "Profile applied (config changed, ssid=%s)" "$ssid"
    else
        log "Profile applied (no wireless change)"
    fi
}

########################################
# 10. WATCHDOGS
########################################
gateway_watchdog() {
    local fail=0
    log "Gateway watchdog started"
    while true; do
        sleep "$GW_WATCHDOG_INTERVAL"
        local mip; mip=$(master_ip)
        [ -z "$mip" ] && continue
        if curl -s -m 4 -o /dev/null "http://${mip}:${MASTER_PORT}/ping" 2>/dev/null; then
            fail=0
        else
            fail=$(( fail + 1 ))
            logw "Gateway: master %s unreachable (%s/3)" "$mip" "$fail"
            if [ "$fail" -ge 3 ]; then
                loge "Gateway dead - re-electing"
                rm -f "$MASTER_IP_FILE"; elect_role; tune_batman; fail=0
            fi
        fi
    done
}

prev_gw=""
check_routing_paths() {
    local cur_gw
    cur_gw=$(batctl meshif "$MESH_IF" gwl 2>/dev/null | awk '/===>/{print $2}' | head -1)
    if [ -n "$cur_gw" ] && [ "$cur_gw" != "$prev_gw" ]; then
        logh "Self-healing: gateway path %s -> %s" "${prev_gw:-none}" "$cur_gw"
        prev_gw="$cur_gw"; sync_neighbor_list
    fi
}

########################################
# 11. SEAMLESS ROAMING
########################################
sync_neighbor_list() {
    local ap; ap=$(get_ap_iface)
    local ssid; ssid=$(uci -q show wireless | awk -F= '/\.easymesh_managed=.1/{sub(/wireless\./,""); sub(/\.easymesh_managed.*/,""); iface=$1} iface && /\.ssid=/{sub(/.*=/,""); print; exit}')
    [ -z "$ssid" ] && return
    local my_bssid; my_bssid=$(cat /sys/class/net/${ap}/address 2>/dev/null)
    > "$NEIGHBOR_FILE"
    iw dev "$ap" scan 2>/dev/null | awk -v ssid="$ssid" '
        /^BSS /  { bssid=$2 }
        /freq:/  { freq=$2 }
        /DS Parameter set/ { chan=$NF }
        /SSID: / { if ($2==ssid && bssid!="") { op=(freq+0>4000)?115:81; print bssid,op,chan } }
    ' | while read -r bssid op chan; do
        [ "$bssid" = "$my_bssid" ] && continue
        ubus call "hostapd.${ap}" rrm_nr_set \
            "{\"list\":[{\"bssid\":\"$bssid\",\"ssid\":\"$ssid\",\"info\":\"$(echo "$bssid" | tr -d ':')${op}${chan}0000\"}]}" \
            2>/dev/null && echo "$bssid $op $chan" >> "$NEIGHBOR_FILE"
    done
    [ "$(get_role)" != "master" ] && return
    local nb_json
    nb_json=$(awk '{printf "{\"bssid\":\"%s\",\"op\":%s,\"chan\":%s},", $1,$2,$3}' \
        "$NEIGHBOR_FILE" | sed 's/,$//')
    local payload="{\"ssid\":\"$ssid\",\"neighbors\":[$nb_json],\"my_bssid\":\"$my_bssid\"}"
    local hash; hash=$(printf '%s' "$payload" | md5sum | cut -c1-8)
    local last; last=$(cat /tmp/easymesh_nb_hash 2>/dev/null)
    [ "$hash" = "$last" ] && return
    printf '%s' "$hash" > /tmp/easymesh_nb_hash
    _push_nb() {
        ( curl -s -m 5 -X POST -H "Content-Type: application/json" \
            -d "$payload" "http://${1}:${MASTER_PORT}/roam/neighbors" >/dev/null 2>&1 ) &
    }
    _iter_nodes _push_nb
}

apply_neighbor_list() {
    local body="$1" ap; ap=$(get_ap_iface)
    local ssid; ssid=$(echo "$body" | grep -o '"ssid":"[^"]*"' | cut -d'"' -f4)
    [ -z "$ssid" ] && return
    echo "$body" | grep -o '"bssid":"[^"]*"' | cut -d'"' -f4 | while read -r bssid; do
        [ -z "$bssid" ] && continue
        ubus call "hostapd.${ap}" rrm_nr_set \
            "{\"list\":[{\"bssid\":\"$bssid\",\"ssid\":\"$ssid\",\"info\":\"$(echo "$bssid" | tr -d ':')0000000000\"}]}" \
            >/dev/null 2>&1
    done
    local cnt; cnt=$(echo "$body" | grep -c '"bssid"')
    [ "$cnt" -gt 0 ] && logr "Neighbor list applied: %s APs" "$cnt"
}

roam_watchdog() {
    local ap; ap=$(get_ap_iface)
    local ap2g; ap2g=$(uci_get wireless easymesh_ap_2g ifname "")
    log "Roam watchdog started on %s%s" "$ap" "${ap2g:+ and $ap2g}"
    while true; do
        sleep "$ROAM_PROBE_INTERVAL"
        ubus list "hostapd.${ap}" >/dev/null 2>&1 || continue
        local ifaces="$ap"
        [ -n "$ap2g" ] && [ "$ap2g" != "$ap" ] && \
            ip link show "$ap2g" >/dev/null 2>&1 && ifaces="$ap $ap2g"
        {
            for _if in $ifaces; do
                iw dev "$_if" station dump 2>/dev/null | \
                    awk -v iface="$_if" '/^Station/{mac=$2} /signal:/{print mac, $2, iface}'
            done
        } | sort -u -k1,1 | while read -r sta rssi iface; do
            [ -z "$sta" ] || [ -z "$rssi" ] && continue
            local ck; ck=$(echo "$sta" | tr ':' '_')
            local last_roam; last_roam=$(roam_cooldown_get "$ck")
            local now; now=$(date +%s)
            local since=$(( now - last_roam ))
            if [ "$since" -lt "$ROAM_COOLDOWN_TIME" ]; then
                logr "SKIP: %s cooldown (%ss)" "$sta" "$(( ROAM_COOLDOWN_TIME - since ))"
                continue
            fi
            local rssi_n="${rssi%.*}" mode=""
            [ "${rssi_n}" -le "${ROAM_RSSI_HARD}" ] 2>/dev/null && mode="HARD"
            [ -z "$mode" ] && [ "${rssi_n}" -le "${ROAM_RSSI_KICK}" ] 2>/dev/null && mode="SOFT"
            [ -z "$mode" ] && continue
            local best; best=$(pick_best_candidate "$sta" "$rssi_n")
            [ -z "$best" ] && continue
            local hex; hex=$(echo "$best" | tr -d ':')
            local extra=""; [ "$mode" = "HARD" ] && extra=",\"disassociation_imminent\":1"
            logr "%s steer %s (%sdBm) -> %s" "$mode" "$sta" "$rssi_n" "$best"
            ubus call "hostapd.${iface:-$ap}" bss_transition_request \
                "{\"addr\":\"$sta\",\"abridged\":1${extra},\"neighbors\":[\"${hex},0,0,0,0\"]}" \
                >/dev/null 2>&1
            roam_cooldown_set "$ck" "$now"
        done
    done
}

pick_best_candidate() {
    local sta_mac="$1" cur_rssi="$2"
    local best_bssid="" best_rssi=-200
    _check_peer() {
        local resp; resp=$(curl -s -m 2 \
            "http://${1}:${MASTER_PORT}/roam/signal?mac=${sta_mac}" 2>/dev/null)
        local pr; pr=$(echo "$resp" | grep -o '"rssi":-\?[0-9]*' | cut -d: -f2)
        local pb; pb=$(echo "$resp" | grep -o '"bssid":"[^"]*"'   | cut -d'"' -f4)
        [ -z "$pr" ] || [ -z "$pb" ] && return
        [ "$pr" -gt "$best_rssi" ] 2>/dev/null && { best_rssi="$pr"; best_bssid="$pb"; }
    }
    _iter_nodes _check_peer
    [ -n "$best_bssid" ] && \
        [ "$best_rssi" -gt $(( cur_rssi + ROAM_HYSTERESIS )) ] 2>/dev/null && \
        echo "$best_bssid"
}

########################################
# 12. DFS
########################################
dfs_watchdog() {
    local ap; ap=$(get_ap_iface)
    logd "DFS watchdog started on %s" "$ap"
    iw event 2>/dev/null | while read -r line; do
        case "$line" in
            *"channel switch started"*|*"radar detected"*)
                sleep 2
                local new_chan; new_chan=$(iw dev "$ap" info 2>/dev/null | awk '/channel/{print $2; exit}')
                [ -n "$new_chan" ] && printf '%s\n' "$new_chan" > /tmp/easymesh_dfs_chan_change
                ;;
        esac
    done &
    while true; do
        if [ -f /tmp/easymesh_dfs_chan_change ]; then
            local new_chan; new_chan=$(cat /tmp/easymesh_dfs_chan_change)
            rm -f /tmp/easymesh_dfs_chan_change
            [ -n "$new_chan" ] && handle_dfs_channel_change "$new_chan"
        fi
        sleep 2
    done
}

handle_dfs_channel_change() {
    local new_chan="$1"
    logd "DFS: mesh-wide channel -> %s" "$new_chan"
    local rd
    for rd in $(_wifi_devs); do uci -q set "wireless.${rd}.channel=${new_chan}"; done
    uci_commit wireless
    [ "$(get_role)" != "master" ] && return
    local payload="{\"channel\":\"$new_chan\",\"reason\":\"dfs\"}"
    _push_dfs() {
        do_http_post "http://${1}:${MASTER_PORT}/channel/apply" "$payload" >/dev/null 2>&1 &
        logd "DFS: pushed ch %s to %s" "$new_chan" "$1"
    }
    _iter_nodes _push_dfs
}

########################################
# 13. ACS / LB / TOPO / DEDICATED BH
########################################
_last_ch=0
optimize_channel() {
    [ "$(get_role)" != "master" ] && return
    local now; now=$(date +%s)
    [ $(( now - _last_ch )) -lt "$CHANNEL_SCAN_INTERVAL" ] && return
    _last_ch=$now
    local dfs; dfs=$(uci_get easymesh global dfs_enable 1)
    local ch24="1 6 11" ch5="36 40 44 48 149 153 157 161 165"
    [ "$dfs" = "1" ] && ch5="$ch5 52 56 60 64 100 104 108 112 116 132 136 140"
    local rd; rd=$(_wifi_devs | head -1)
    local band; band=$(uci -q get "wireless.${rd}.band" 2>/dev/null || echo "5g")
    local cands; case "$band" in 2g*|2.4*) cands="$ch24";; *) cands="$ch5";; esac
    local ap; ap=$(get_ap_iface)
    local scan; scan=$(iw dev "$ap" scan 2>/dev/null)
    local best="" best_cnt=9999
    for ch in $cands; do
        local cnt; cnt=$(echo "$scan" | grep -c "DS Parameter set: channel $ch")
        [ "$cnt" -lt "$best_cnt" ] && { best_cnt=$cnt; best=$ch; }
    done
    [ -z "$best" ] && return
    local cur; cur=$(uci -q get "wireless.${rd}.channel" 2>/dev/null)
    [ "$cur" = "$best" ] && return
    logd "ACS: ch %s -> %s (occupancy %s)" "$cur" "$best" "$best_cnt"
    uci -q set "wireless.${rd}.channel=$best"; uci_commit wireless && wifi reload
    local payload="{\"channel\":\"$best\",\"reason\":\"acs\"}"
    _push_acs() { do_http_post "http://${1}:${MASTER_PORT}/channel/apply" "$payload" >/dev/null 2>&1 & }
    _iter_nodes _push_acs
}

setup_dedicated_backhaul() {
    local enabled; enabled=$(uci_get easymesh global dedicated_backhaul 0)
    [ "$enabled" != "1" ] && return
    local hw; hw=$(cat /tmp/easymesh_hw_type 2>/dev/null || echo "dual-band")
    [ "$hw" != "tri-band" ] && { log "Dedicated backhaul: skipped (hw=%s)" "$hw"; return 1; }
    local bh_band; bh_band=$(uci_get easymesh global backhaul_band "5g_2")
    local target=2; [ "$bh_band" = "5g_1" ] && target=1
    local bh_radio="" seen5g=0 dev
    for dev in $(_wifi_devs); do
        local b; b=$(uci -q get "wireless.${dev}.band")
        case "$b" in 5g*|5GHz*)
            seen5g=$(( seen5g+1 ))
            [ "$seen5g" -ge "$target" ] && { bh_radio="$dev"; break; } ;;
        esac
    done
    [ -z "$bh_radio" ] && { log "Dedicated backhaul: no second 5GHz radio"; return 1; }
    log "Dedicated backhaul: %s reserved for mesh" "$bh_radio"
    local iface
    for iface in $(uci -q show wireless | awk -F= '/=wifi-iface$/{sub(/wireless\./,""); print $1}'); do
        local d; d=$(uci_get wireless "$iface" device)
        local m; m=$(uci -q get "wireless.${iface}.mode")
        [ "$d" = "$bh_radio" ] && [ "$m" = "ap" ] && {
            uci del "wireless.${iface}"
            log "Dedicated backhaul: removed AP %s" "$iface"
        }
    done
    local bh_ch; bh_ch=$(uci_get easymesh global backhaul_channel 149)
    uci_set wireless "$bh_radio" channel "$bh_ch"
    uci_set wireless "$bh_radio" htmode VHT80
    uci_add wireless wifi-iface easymesh_bh
    uci_set wireless easymesh_bh device "$bh_radio"
    uci_set wireless easymesh_bh mode mesh
    uci_set wireless easymesh_bh mesh_id "$(uci_get easymesh global mesh_id)"
    uci_set wireless easymesh_bh network mesh
    uci_set wireless easymesh_bh easymesh_managed 1
    local mesh_key; mesh_key=$(uci_get easymesh global mesh_key)
    if [ -n "$mesh_key" ]; then
        uci_set wireless easymesh_bh encryption sae
        uci_set wireless easymesh_bh key "$mesh_key"
    else
        uci_set wireless easymesh_bh encryption none
    fi
    uci_commit wireless
    log "Dedicated backhaul: %s configured (ch=%s VHT80)" "$bh_radio" "$bh_ch"
}

load_balance() {
    local ap; ap=$(get_ap_iface)
    local ap2g; ap2g=$(uci_get wireless easymesh_ap_2g ifname "")
    local total; total=$(iw dev "$ap" station dump 2>/dev/null | grep -c "^Station")
    [ -n "$ap2g" ] && [ "$ap2g" != "$ap" ] && {
        local cnt2; cnt2=$(iw dev "$ap2g" station dump 2>/dev/null | grep -c "^Station")
        total=$(( total + cnt2 ))
    }
    [ "$total" -le "$LB_CLIENT_THRESHOLD" ] && return
    {
        for _if in $ap ${ap2g:+$ap2g}; do
            iw dev "$_if" station dump 2>/dev/null | \
                awk -v iface="$_if" '/^Station/{mac=$2} /signal:/{print $2+0, mac, iface}'
        done
    } | sort -n | head -$(( total / 5 )) | awk '{print $2, $3}' | \
    while read -r mac lbif; do
        local rssi; rssi=$(iw dev "$lbif" station get "$mac" 2>/dev/null | awk '/signal:/{print $2+0}')
        local best; best=$(pick_best_candidate "$mac" "${rssi:--60}")
        [ -n "$best" ] && ubus call "hostapd.${lbif}" bss_transition_request \
            "{\"addr\":\"$mac\",\"abridged\":1,\"neighbors\":[\"$(echo "$best" | tr -d ':'),0,0,0,0\"]}" \
            >/dev/null 2>&1
    done
}

update_topology() {
    local my_mac my_ip my_role my_hostname clients
    my_mac=$(get_mac); my_ip=$(get_ip); my_role=$(get_role)
    my_hostname=$(uci_get system @system[0] hostname 'OpenWrt')
    clients=$(iw dev "$(get_ap_iface)" station dump 2>/dev/null | grep -c "^Station")
    local nodes="{\"mac\":\"$my_mac\",\"ip\":\"$my_ip\",\"role\":\"$my_role\",\"hostname\":\"$my_hostname\",\"clients\":$clients}"
    local links="" tmp="/tmp/em_topo_$$.txt"
    batctl meshif "$MESH_IF" orig 2>/dev/null | awk 'NR>2{print}' > "$tmp"
    while read -r peer_mac _ tq _rest; do
        [ -z "$peer_mac" ] && continue
        local pnorm; pnorm=$(printf '%s' "$peer_mac" | tr 'A-F' 'a-f')
        local psafe; psafe=$(printf '%s' "$pnorm" | tr ':' '_')
        local pf="${NODE_DB}/${psafe}.json"
        local ph="" pip=""
        [ -f "$pf" ] && {
            ph=$(jsonfilter  -i "$pf" -e '@.hostname' 2>/dev/null)
            pip=$(jsonfilter -i "$pf" -e '@.ip'       2>/dev/null)
        }
        nodes="${nodes},{\"mac\":\"$peer_mac\",\"ip\":\"${pip}\",\"role\":\"agent\",\"hostname\":\"${ph}\",\"tq\":$tq,\"clients\":0}"
        links="${links:+$links,}{\"src\":\"$my_mac\",\"dst\":\"$peer_mac\",\"tq\":$tq}"
    done < "$tmp"
    rm -f "$tmp"
    for f in "$NODE_DB"/*.json; do
        [ -f "$f" ] || continue
        local dm; dm=$(jsonfilter -i "$f" -e '@.mac' 2>/dev/null)
        [ -z "$dm" ] && continue
        case "$nodes" in *"\"$dm\""*) continue ;; esac
        local dip dh ds
        dip=$(jsonfilter -i "$f" -e '@.ip'       2>/dev/null)
        dh=$(jsonfilter  -i "$f" -e '@.hostname' 2>/dev/null)
        ds=$(jsonfilter  -i "$f" -e '@.source'   2>/dev/null || echo "wired")
        nodes="${nodes},{\"mac\":\"$dm\",\"ip\":\"$dip\",\"role\":\"agent\",\"hostname\":\"$dh\",\"backhaul\":\"$ds\",\"clients\":0}"
    done
    local bat0_up
    ip link show bat0 2>/dev/null | grep -qE ',UP,|<UP|,UP>' && bat0_up="true" || bat0_up="false"
    printf '{"ts":%d,"nodes":[%s],"links":[%s],"bat0_up":%s}\n' \
        "$(date +%s)" "$nodes" "${links:-}" "$bat0_up" > "$TOPO_FILE"
}

########################################
# 14. WIRELESS ONBOARDING AP
########################################
_stop_onboard_ap() {
    local f pid
    for f in /tmp/easymesh_pair_hostapd.pid /tmp/easymesh_pair_dnsmasq.pid; do
        [ -f "$f" ] || continue
        pid=$(cat "$f"); kill "$pid" 2>/dev/null || true; rm -f "$f"
    done
    rm -f /tmp/easymesh_pair_hostapd.conf
    iw dev easymesh-pair0 del 2>/dev/null || true
    log "Wireless onboard AP stopped"
}

manage_wireless_onboard() {
    [ "$(get_role)" != "master" ] && return
    local en; en=$(uci -q get easymesh.global.wireless_onboard || echo 0)
    if [ "$en" != "1" ]; then
        [ -f /tmp/easymesh_pair_hostapd.pid ] && _stop_onboard_ap; return
    fi
    local pending; pending=$(ls "$PENDING_DB"/*.json 2>/dev/null | wc -l)
    local approved; approved=$(ls "$NODE_DB"/*.json   2>/dev/null | wc -l)
    if [ "$pending" -eq 0 ] && [ "$approved" -gt 0 ]; then
        [ -f /tmp/easymesh_pair_hostapd.pid ] && \
            kill -0 "$(cat /tmp/easymesh_pair_hostapd.pid)" 2>/dev/null && {
                log "All nodes approved - stopping onboard AP"; _stop_onboard_ap
            }
        return
    fi
    [ -f /tmp/easymesh_pair_hostapd.pid ] && \
        kill -0 "$(cat /tmp/easymesh_pair_hostapd.pid)" 2>/dev/null && return

    local mac; mac=$(get_mac)
    local hex; hex=$(echo "$mac" | tr -d ':' | tr 'a-f' 'A-F')
    local oui="${hex%??????}"
    local ssid="EasyMesh-Setup-${oui}"
    local phy; phy=$(iw phy 2>/dev/null | awk '/^phy/{print $1}' | head -1)
    [ -z "$phy" ] && return
    iw phy "$phy" interface add easymesh-pair0 type __ap 2>/dev/null || true
    ip link set easymesh-pair0 up
    cat > /tmp/easymesh_pair_hostapd.conf << HAPD
interface=easymesh-pair0
driver=nl80211
ssid=$ssid
hw_mode=g
channel=6
auth_algs=1
wpa=0
HAPD
    hostapd -B /tmp/easymesh_pair_hostapd.conf -P /tmp/easymesh_pair_hostapd.pid 2>/dev/null
    local my_ip; my_ip=$(get_ip)
    ip addr add "${my_ip%.*}.250/24" dev easymesh-pair0 2>/dev/null || true
    dnsmasq --interface=easymesh-pair0 --bind-interfaces \
        --dhcp-range="${my_ip%.*}.200,${my_ip%.*}.249,10m" \
        --dhcp-option=3,"${my_ip%.*}.250" \
        --no-resolv --no-hosts \
        --pid-file=/tmp/easymesh_pair_dnsmasq.pid 2>/dev/null
    log "Wireless onboard AP: %s" "$ssid"
}

########################################
# MAIN
########################################
_handle_approval_signal() {
    log "USR1: pushing profile to all approved agents"
    local profile; profile=$(cat "$PROFILE_FILE" 2>/dev/null)
    [ -z "$profile" ] && { logw "USR1: no profile, agents will poll"; return; }
    _push_prof() {
        ( curl -s -m 5 -X POST -H "Content-Type: application/json" \
            -d "$profile" "http://${1}:${MASTER_PORT}/profile/push" >/dev/null 2>&1 ) &
        log "USR1: pushed profile to %s" "$1"
    }
    _iter_nodes _push_prof
}

main_loop() {
    _stop_jobs
    mkdir -p "$NODE_DB" "$PENDING_DB" "$ROAM_COOLDOWN_DIR" "$EM_PID_DIR" "$EM_STATE_DIR" "$PERSISTENT_NODE_DB" 2>/dev/null
    ls "$PERSISTENT_NODE_DB"/*.json >/dev/null 2>&1 && {
        log "Recovering approved nodes from persistent storage..."
        for _pf in "$PERSISTENT_NODE_DB"/*.json; do
            [ -f "$_pf" ] || continue
            local _bn; _bn="${_pf##*/}"
            local _rt="${NODE_DB}/${_bn}"
            if [ ! -f "$_rt" ]; then
                sed "s/\"ts\":[0-9]*/\"ts\":$(date +%s)/" "$_pf" > "$_rt"
                local _mac; _mac=$(jsonfilter -i "$_rt" -e '@.mac' 2>/dev/null)
                log "Recovered node: %s" "${_mac:-unknown}"
            fi
        done
    }
    { printf "\n" >> "$LOGFILE" 2>/dev/null
      log "================================================"
      log "EasyMesh daemon starting (pid=%s)" "$$"
      log "================================================"; }

    local count5g hw_type="dual-band"
    count5g=$(uci -q show wireless | \
        awk -F= '/=wifi-device/{d=$1} d && /\.band=/{b=$2; sub(/.*=/,"",b); if(b~/^5g|^5GHz/) n++} END{print n+0}')
    [ "$count5g" -ge 2 ] && hw_type="tri-band"
    echo "$hw_type" > /tmp/easymesh_hw_type
    log "Hardware: %s" "$hw_type"

    elect_role
    local role; role=$(get_role)
    echo $$ > "${EM_PID_DIR}/easymesh_${role}.pid"
    tune_batman
    setup_wired_backhaul
    log "Starting as: %s" "$role"

    _bg roam_watchdog roam_watchdog
    _bg dfs_watchdog  dfs_watchdog
    _bg http_server   run_node_server

    if [ "$role" = "master" ]; then
        _bg disc_server discovery_server
        manage_wireless_onboard
        generate_profile
        trap '_handle_approval_signal' USR1
    else
        _bg gw_watchdog gateway_watchdog
        find_master && do_register || true
    fi
    setup_dedicated_backhaul

    local _registered=0 _iter=0

    while true; do
        if [ $(( _iter % (ELECTION_INTERVAL / 10) )) -eq 0 ]; then
            local prev_role; prev_role="$role"
            elect_role
            role=$(get_role)

            if [ "$role" != "$prev_role" ]; then
                tune_batman
                _registered=0
                log "Role switch: %s -> %s" "$prev_role" "$role"
                rm -f "${EM_PID_DIR}/easymesh_${prev_role}.pid"
                echo $$ > "${EM_PID_DIR}/easymesh_${role}.pid"
                [ "$role" = "master" ] && { _bg disc_server discovery_server; generate_profile; }
            fi
        else
            role=$(get_role)
        fi

        if [ "$role" = "master" ]; then
            if [ $(( _iter % 6 )) -eq 0 ]; then
                optimize_channel
                manage_wireless_onboard
            fi
        else
            if [ "$_registered" = "0" ]; then
                if find_master; then
                    do_register && _registered=1
                elif [ -f "$MASTER_IP_FILE" ]; then
                    do_register && _registered=1
                fi
            else
                poll_for_approval
                [ $? -eq 2 ] && _registered=0
            fi
        fi

        sync_neighbor_list
        load_balance
        update_topology
        check_routing_paths
        _iter=$(( _iter + 1 ))
        sleep 10
    done
}

case "${1:-}" in
    stop)           teardown_batman; _stop_jobs ;;
    __socat_http)   __socat_http ;;
    __handle_hello) __handle_hello ;;
    *)              main_loop ;;
esac
