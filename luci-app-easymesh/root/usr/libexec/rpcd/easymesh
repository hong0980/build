#!/bin/sh
. /usr/share/libubox/jshn.sh

MESH_IF="bat0"
LOGFILE="/tmp/easymesh.log"
EM_RUN_DIR="/tmp/easymesh"
EM_PID_DIR="${EM_RUN_DIR}/pids"
NODE_DB="${EM_RUN_DIR}/nodes"
PENDING_DB="${EM_RUN_DIR}/pending"
TOPO_FILE="${EM_RUN_DIR}/topo.json"
NEIGHBOR_FILE="${EM_RUN_DIR}/neighbors.conf"
PERSISTENT_NODE_DB="/etc/easymesh/easymesh_nodes"

list() {
    cat << EOF
{
  "pending":   {},
  "approved":  {},
  "topology":  {},
  "neighbors": {},
  "status":    {},
  "log":       { "lines": "number" },
  "approve":   { "mac": "" },
  "reject":    { "mac": "" }
}
EOF
}

call() {
    local method="$1" args
    IFS= read -r -t 2 args 2>/dev/null
    [ -z "$args" ] && args='{}'
    case "$method" in
        pending)   _pending ;;
        approved)  _approved ;;
        topology)  _topology ;;
        log)
            local lines; lines=$(jsonfilter -s "$args" -e '@.lines' 2>/dev/null)
            _log "${lines:-100}"
            ;;
        approve)
            local mac; mac=$(jsonfilter -s "$args" -e '@.mac' 2>/dev/null)
            _approve "$mac"
            ;;
        reject)
            local mac; mac=$(jsonfilter -s "$args" -e '@.mac' 2>/dev/null)
            _reject "$mac"
            ;;
        neighbors) _neighbors ;;
        status)    _status ;;
        *) printf '{"error":"unknown method: %s"}\n' "$method"; return 1 ;;
    esac
}

_nodes_from_dir() {
    local dir="$1" status="$2" f
    json_init
    json_add_array "nodes"
    for f in "$dir"/*.json; do
        [ -f "$f" ] || continue
        local mac ip hostname source ts
        mac=$(     jsonfilter -i "$f" -e '@.mac'      2>/dev/null) || continue
        ip=$(      jsonfilter -i "$f" -e '@.ip'       2>/dev/null)
        hostname=$(jsonfilter -i "$f" -e '@.hostname' 2>/dev/null)
        source=$(  jsonfilter -i "$f" -e '@.source'   2>/dev/null)
        ts=$(      jsonfilter -i "$f" -e '@.ts'       2>/dev/null)

        json_add_object
        json_add_string "mac"      "$mac"
        json_add_string "ip"       "${ip:-}"
        json_add_string "hostname" "${hostname:-}"
        json_add_string "source"   "${source:-wired}"
        json_add_string "status"   "$status"
        json_add_int    "ts"       "${ts:-0}"
        json_close_object
    done
    json_close_array
    json_dump
}

_pending()  { _nodes_from_dir "$PENDING_DB" "pending";  }
_approved() { _nodes_from_dir "$NODE_DB"    "approved"; }

_neighbors() {
    local json; json=$(batctl meshif "$MESH_IF" originators_json 2>/dev/null)
    if [ -n "$json" ] && [ "$json" != "null" ]; then
        echo "$json"
    else
        echo '{"neighbors":[]}'
    fi
}

_status() {
    local daemon_running="false" role="unknown" bat0_up="false" pid
    ip link show "$MESH_IF" 2>/dev/null | grep -q 'UP,LOWER_UP' && bat0_up="true"

    for r in master agent; do
        pid=$(cat "${EM_PID_DIR}/easymesh_${r}.pid" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            daemon_running="true"
            role="$r"
            break
        fi
    done
    printf '{"daemon_running":%s,"role":"%s","bat0_up":%s}\n' "$daemon_running" "$role" "$bat0_up"
}

_topology() {
    if [ -f "$TOPO_FILE" ]; then
        local now mtime age
        now=$(date +%s)
        mtime=$(date -r "$TOPO_FILE" +%s 2>/dev/null || echo 0)
        age=$(( now - mtime ))
        [ "$age" -lt 15 ] && { cat "$TOPO_FILE"; return; }
    fi
    local bat0_up="false"
    ip link show "$MESH_IF" 2>/dev/null | grep -q 'UP,LOWER_UP' && bat0_up="true"
    printf '{"ts":%d,"nodes":[],"links":[],"bat0_up":%s}\n' "$(date +%s)" "$bat0_up"
}

_log() {
    local n="${1:-100}"
    json_init
    json_add_array "lines"
    tail -n "$n" "$LOGFILE" 2>/dev/null | while IFS= read -r line; do
        [ -n "$line" ] && json_add_string "" "$line"
    done
    json_close_array
    json_dump
}

_approve() {
    local mac="$1"
    [ -z "$mac" ] && { printf '{"error":"mac required"}\n'; return 1; }
    local safe; safe=$(printf '%s' "$mac" | tr 'A-F' 'a-f' | tr ':' '_')
    local dst="${NODE_DB}/${safe}.json"
    local src="${PENDING_DB}/${safe}.json"
    local persistent="${PERSISTENT_NODE_DB}/${safe}.json"

    if [ -f "$src" ]; then
        sed 's/"status":"pending"/"status":"approved"/' "$src" > "$dst" && rm -f "$src"
        cp "$dst" "$persistent" 2>/dev/null
        _signal_master
        printf '{"status":"ok","mac":"%s"}\n' "$mac"
    elif [ -f "$dst" ]; then
        _signal_master
        cp "$dst" "$persistent" 2>/dev/null
        printf '{"status":"ok","msg":"already approved","mac":"%s"}\n' "$mac"
    else
        printf '{"error":"node not found","mac":"%s"}\n' "$mac"
        return 1
    fi
}

_reject() {
    local mac="$1"
    [ -z "$mac" ] && { printf '{"error":"mac required"}\n'; return 1; }
    local safe=$(echo "$mac" | tr 'A-F' 'a-f' | tr ':' '_')
    rm -f "${PENDING_DB}/${safe}.json" 2>/dev/null
    printf '{"status":"ok","mac":"%s"}\n' "$mac"
}

_signal_master() {
    local pid; pid=$(cat "${EM_PID_DIR}/easymesh_master.pid" 2>/dev/null)
    [ -n "$pid" ] && kill -USR1 "$pid" 2>/dev/null || true
}

case "$1" in
    list) list ;;
    call) call "$2" ;;
esac
