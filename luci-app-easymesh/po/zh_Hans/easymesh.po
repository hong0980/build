msgid "Overview & Config"
msgstr "概览与配置"

msgid "Nodes"
msgstr "节点状态"

msgid "Log"
msgstr "运行日志"

# ══════════════════════════════════════════════════════════════════════════════
# overview.js — 页面标题与描述
# ══════════════════════════════════════════════════════════════════════════════

msgid "EasyMesh Configuration"
msgstr "EasyMesh 配置"

msgid "Multi-node mesh via batman-adv over wired Ethernet or 802.11s wireless backhaul."
msgstr "多节点 Mesh 网络，通过有线以太网或 802.11s 无线回程运行 batman-adv 路由。"

# ══════════════════════════════════════════════════════════════════════════════
# overview.js — 角色引导块
# ══════════════════════════════════════════════════════════════════════════════

msgid "Add New Node (Master Mode)"
msgstr "添加新节点（主节点模式）"

msgid "Flash OpenWrt + install luci-app-easymesh on the new node"
msgstr "在新节点上刷入 OpenWrt，并安装 luci-app-easymesh"

msgid "Set role to Agent in its EasyMesh config, then enable EasyMesh"
msgstr "在新节点的 EasyMesh 配置中将角色设为 Agent，然后启用 EasyMesh"

msgid "Connect a LAN cable: this master LAN port ↔ new node LAN port"
msgstr "用网线连接：本主节点 LAN 口 ↔ 新节点 LAN 口"

msgid "Wait ~30 s — agent auto-discovers master via UDP broadcast"
msgstr "等待约 30 秒，新节点通过 UDP 广播自动发现主节点"

msgid "Go to Nodes tab on this master and click Allow to join"
msgstr "在主节点的「节点状态」页面点击「允许加入」"

msgid "Quick join: on the new node hold WPS button 2–10 s."
msgstr "快速加入：在新节点上按住 WPS 按钮 2～10 秒，自动切换为 Agent 并发现主节点"

msgid "Agent Mode — Joining Mesh"
msgstr "从节点模式 — 加入 Mesh"

msgid "Connect a LAN cable from this node to the master router"
msgstr "用网线将本节点的 LAN 口连接到主节点路由器"

msgid "Enable EasyMesh and set role to Agent, then Save & Apply"
msgstr "请在下方启用 EasyMesh 并将角色设为 Agent，然后保存并应用"

msgid "This node broadcasts discovery packets to find the master"
msgstr "本节点将通过 UDP 广播自动发现主节点"

msgid "Master shows this node in Nodes tab — approve it there"
msgstr "主节点的「节点状态」页面会显示本节点，在那里点击批准"

msgid "Once approved, master pushes WiFi config automatically"
msgstr "批准后主节点将自动推送 WiFi 配置"

# ══════════════════════════════════════════════════════════════════════════════
# overview.js — 标签页
# ══════════════════════════════════════════════════════════════════════════════

msgid "Basic"
msgstr "基本设置"

msgid "Mesh Backhaul"
msgstr "Mesh 回程网络"

msgid "Roaming"
msgstr "漫游设置（802.11r/k/v）"

msgid "Advanced"
msgstr "高级"

# ══════════════════════════════════════════════════════════════════════════════
# overview.js — 基本设置 tab
# ══════════════════════════════════════════════════════════════════════════════

msgid "Enable EasyMesh"
msgstr "启用 EasyMesh"

msgid "Node Role"
msgstr "节点角色"

msgid "Master: gateway router with DHCP and uplink. Agent: extends coverage."
msgstr "主节点负责 DHCP 和上行；Agent 从节点负责覆盖延伸。"

msgid "Master (connected to modem/ISP)"
msgstr "主节点（连接光猫/ISP）"

msgid "Agent (Slave, extends coverage)"
msgstr "从节点 Agent（扩展覆盖范围）"

msgid "Master"
msgstr "主节点"

msgid "Agent"
msgstr "从节点"

msgid "Wi-Fi settings are automatically pushed by the master once approved. No manual Wi-Fi config needed on agents."
msgstr "所有 Wi-Fi 设置在 Agent 被批准后由主节点自动推送，无需手动配置。"

msgid "WAN Port Mode"
msgstr "WAN 口模式"

msgid "Router: WAN port connects to modem/ISP. Switch: all ports become LAN (uplink via another router)."
msgstr "路由模式：WAN 口连接光猫/ISP。交换机模式：所有网口作为 LAN（适合上级路由已有 DHCP 的场景）。"

msgid "Router (WAN port separate)"
msgstr "路由模式（WAN 口独立）"

msgid "Switch (all ports as LAN — no WAN)"
msgstr "交换机模式（所有网口作为 LAN）"

msgid "WAN Protocol"
msgstr "WAN 协议"

msgid "PPPoE: dial-up with username/password (ISP fiber). AP/DHCP: automatic address from upstream router."
msgstr "PPPoE：使用账号密码拨号（运营商宽带）。DHCP：从上级路由自动获取地址。"

msgid "DHCP (automatic — upstream router)"
msgstr "DHCP（自动获取 — 上级路由）"

msgid "PPPoE (dial-up — ISP fiber/DSL)"
msgstr "PPPoE（拨号 — 运营商宽带/DSL）"

msgid "PPPoE Username"
msgstr "PPPoE 用户名"

msgid "PPPoE Password"
msgstr "PPPoE 密码"

msgid "Dual-band Merge (same SSID/password)"
msgstr "双频合并（使用相同 SSID 和密码）"

msgid "Enabled: one SSID/password applied to both 2.4 GHz and 5 GHz radios.Disabled: set different SSID and password for each band."
msgstr "开启：2.4G 和 5G 使用同一 SSID 和密码。关闭：为每个频段单独设置。"

msgid "WiFi Name (SSID)"
msgstr "WiFi 名称（SSID）"

msgid "Applied to both 2.4 GHz and 5 GHz radios. Pushed to all agent nodes."
msgstr "应用于 2.4 GHz 和 5 GHz 频段，并自动推送到所有 Agent 节点。"

msgid "WiFi Password"
msgstr "WiFi 密码"

msgid "WPA2/WPA3. Min 8 chars. Leave empty for open network."
msgstr "WPA2/WPA3 加密。最少 8 位。留空为开放网络。"

msgid "5 GHz WiFi Name (SSID)"
msgstr "5 GHz 无线名称（SSID）"

msgid "5 GHz WiFi Password"
msgstr "5 GHz 无线密码"

msgid "2.4 GHz WiFi Name (SSID)"
msgstr "2.4 GHz 无线名称（SSID）"

msgid "2.4 GHz WiFi Password"
msgstr "2.4 GHz 无线密码"

msgid "Wireless Node Onboarding"
msgstr "无线添加新节点"

msgid "Broadcast a temporary open SSID so new nodes can join without a cable."
msgstr "广播临时开放 SSID，让新节点无需网线即可加入。仍需在「节点」页面手动确认。"

# ══════════════════════════════════════════════════════════════════════════════
# overview.js — Mesh 回程 tab
# ══════════════════════════════════════════════════════════════════════════════

msgid "Backhaul Type"
msgstr "回程方式"

msgid "Wired: batman-adv over LAN cable (recommended). Wireless: dedicated 802.11s link."
msgstr "有线模式通过 LAN 网线连接节点（推荐）；无线模式使用专用 802.11s 链路。"

msgid "Wired (recommended)"
msgstr "有线回程（推荐）"

msgid "Wireless (802.11s)"
msgstr "无线（802.11s）"

msgid "Auto (wired preferred)"
msgstr "自动选择（有线优先）"

msgid "802.11s Mesh ID"
msgstr "802.11s Mesh 网络标识"

msgid "Internal mesh network name. Must be identical on all nodes."
msgstr "无线 Mesh 回程网络标识，所有节点必须相同。与客户端 WiFi 名称不同。"

msgid "802.11s Mesh Password (SAE)"
msgstr "802.11s Mesh 密码（SAE）"

msgid "Encryption key for wireless backhaul. Must match on all nodes."
msgstr "无线 Mesh 回程加密密钥，所有节点必须相同。留空则禁用 Mesh 加密。"

msgid "Min 8 characters"
msgstr "至少 8 位字符"

msgid "802.11s Backhaul Band"
msgstr "802.11s 回程频段"
msgid "Wired Backhaul Port"
msgstr "有线回程专用网口"

msgid "2.4 GHz (better range, slower)"
msgstr "2.4GHz（穿墙好，速度慢）"

msgid "5 GHz (faster, recommended)"
msgstr "5GHz（速度快，推荐）"

# ══════════════════════════════════════════════════════════════════════════════
# overview.js — 漫游 tab
# ══════════════════════════════════════════════════════════════════════════════

msgid "802.11r Fast BSS Transition"
msgstr "802.11r 快速 BSS 切换"

msgid "Reduces disconnect time when roaming between nodes. Recommended."
msgstr "大幅减少节点切换时的断线时间，推荐开启。"

msgid "Mobility Domain ID"
msgstr "漫游域 ID"

msgid "4-digit hex. Must be identical on all nodes."
msgstr "4 位十六进制字符串，所有节点必须一致。"

msgid "802.11k Neighbor Report"
msgstr "802.11k 邻居报告"

msgid "Tells devices about nearby nodes for proactive roaming."
msgstr "向设备通报附近节点，辅助主动漫游。"

msgid "802.11v BSS Transition Mgmt"
msgstr "802.11v BSS 过渡管理"

msgid "Actively steers weak-signal devices to a better node."
msgstr "主动引导信号弱的设备切换到更好的节点。"

msgid "FT over DS"
msgstr "802.11r FT over DS"

msgid "Pre-negotiate keys over wired backbone for faster transition."
msgstr "通过有线骨干预协商密钥，切换更快。如遇问题可关闭。"

msgid "Reassociation Deadline (ms)"
msgstr "重关联超时（毫秒）"

# ══════════════════════════════════════════════════════════════════════════════
# overview.js — 高级 tab
# ══════════════════════════════════════════════════════════════════════════════

msgid "Enable DFS Channels"
msgstr "启用 DFS 信道"

msgid "Include radar-protected 5 GHz DFS channels in ACS scan."
msgstr "在 ACS 扫描中加入受雷达保护的 5 GHz DFS 信道（52–140）。"

msgid "batman-adv Routing Algorithm"
msgstr "batman-adv 路由算法"

msgid "default, best compatibility"
msgstr "默认，兼容性最好"

msgid "more accurate, needs kernel support"
msgstr "更精确，需要内核支持"

msgid "802.11s Native Forwarding"
msgstr "802.11s 原生转发"

msgid "Enable 802.11s path selection alongside batman-adv. Normally off."
msgstr "在 batman-adv 之外启用 802.11s 自身路径选择。通常禁用。"

msgid "Dedicated Backhaul Radio (Tri-band)"
msgstr "专用回程频段（三频）"

msgid "Reserve second 5 GHz radio exclusively for backhaul."
msgstr "将第二块 5 GHz radio 专用于节点间回程，仅对三频硬件有效。"

msgid "Backhaul Radio Band"
msgstr "回程频段"

msgid "Second 5 GHz radio (recommended)"
msgstr "第二个 5GHz 频段（推荐）"

msgid "First 5 GHz radio"
msgstr "第一个 5GHz 频段"

msgid "Backhaul Channel"
msgstr "回程信道"

msgid "Fixed channel for dedicated backhaul. 149/153/157/161 recommended."
msgstr "专用回程 radio 的固定信道，推荐使用 149/153/157/161。"

