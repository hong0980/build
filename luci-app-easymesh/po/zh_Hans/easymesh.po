msgid "Live topology map. Link color = signal quality: green ≥70%, yellow ≥40%, red <40%. Hover nodes for details."
msgstr "实时拓扑图。连线颜色表示信号质量：绿色 ≥70%，黄色 ≥40%，红色 <40%。悬停节点可查看详情。"

msgid "No topology data yet. Waiting for mesh to form..."
msgstr "暂无拓扑数据，等待 Mesh 网络形成……"

msgid "≥ 70% (Good)"
msgstr "≥70%（良好）"

msgid "40–69% (Fair)"
msgstr "40–69%（一般）"

